# Test de bloques anidados - replicar estructura de gradient_boosting.jasb

principal
    entero n = 10

    # Simular estructura problemática
    entero j = 0
    mientras j < n hacer
        entero k = j + 1
        mientras k < n hacer
            entero v1 = j
            entero v2 = k
            si v2 < v1 entonces
                # Bloque interno con while
                entero m = 0
                mientras m < n hacer
                    si m == j entonces
                        imprimir("Caso j")
                    sino
                        si m == k entonces
                            imprimir("Caso k")
                        sino
                            imprimir("Caso otro")
                        fin_si
                    fin_si
                    m = m + 1
                fin_mientras
                imprimir("Despues del while interno")
            fin_si
            k = k + 1
        fin_mientras
        j = j + 1
    fin_mientras

    imprimir("Test completado")
fin_principal
