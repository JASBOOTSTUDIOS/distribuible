funcion jd_tema_activo() retorna texto
    retornar estructura_tema("#2563eb", "#0f172a", "#f8fafc", "#0f172a", "16px", "16px")
fin_funcion

funcion jd_vista_Inicio(texto solicitud) retorna texto
    texto jd_hijos_0 = ""
    jd_hijos_0 = concatenar(jd_hijos_0, estructura_titulo("Cesar"))
    jd_hijos_0 = concatenar(jd_hijos_0, estructura_texto("Panel SaaS seguro construido con `.jd` y runtime Estructa."))
    texto jd_hijos_2 = ""
    jd_hijos_2 = concatenar(jd_hijos_2, estructura_texto("El sistema renderiza por SSR, escapa contenido y limita acciones del cliente."))
    texto jd_bloque_3 = estructura_tarjeta_visual("Estado", "primaria", jd_hijos_2)
    jd_hijos_0 = concatenar(jd_hijos_0, jd_bloque_3)
    jd_hijos_0 = concatenar(jd_hijos_0, estructura_divisor())
    texto jd_bloque_1 = estructura_columna(jd_hijos_0)
    texto cuerpo = jd_bloque_1
    texto panel = estructura_seccion_titulo("Resumen ejecutivo", "Metrica, estado y actividad del producto.")
    panel = concatenar(panel, estructura_saas_kpis())
    panel = concatenar(panel, estructura_tarjeta("Actividad", concatenar(estructura_texto("3 despliegues correctos en las ultimas 24h."), estructura_badge("Seguro por defecto"))))
    cuerpo = estructura_saas_shell(solicitud, concatenar(cuerpo, panel))
    retornar cuerpo
fin_funcion

