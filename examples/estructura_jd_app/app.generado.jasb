funcion jd_app(texto solicitud) retorna texto
    texto nav = ""
    nav = concatenar(nav, "<a data-estructa-ruta=\"/\" href=\"/\">Inicio</a>")
    nav = concatenar(nav, "<a data-estructa-ruta=\"/clientes\" href=\"/clientes\">Clientes</a>")
    nav = concatenar(nav, "<a data-estructa-ruta=\"/facturacion\" href=\"/facturacion\">Facturacion</a>")
    nav = concatenar(nav, "<a data-estructa-ruta=\"/configuracion\" href=\"/configuracion\">Configuracion</a>")
    texto ruta = estructura_ruta_sin_query(solicitud)
    si api_metodo(solicitud) == "GET" entonces
        si ruta == "/" entonces
            retornar estructura_responder_tema("MiAppJD", nav, jd_vista_Inicio(solicitud), jd_tema_activo())
        fin_si
        si ruta == "/clientes" entonces
            retornar estructura_responder_tema("MiAppJD", nav, jd_vista_Clientes(solicitud), jd_tema_activo())
        fin_si
        si ruta == "/facturacion" entonces
            retornar estructura_responder_tema("MiAppJD", nav, jd_vista_Facturacion(solicitud), jd_tema_activo())
        fin_si
        si ruta == "/configuracion" entonces
            retornar estructura_responder_tema("MiAppJD", nav, jd_vista_Configuracion(solicitud), jd_tema_activo())
        fin_si
    fin_si
    retornar estructura_no_encontrado_tema("MiAppJD", nav, jd_tema_activo())
fin_funcion

principal
    socket srv = tcp_escuchar("127.0.0.1", 18232)
    entero i = 0
    imprimir "MiAppJD"
    imprimir "app jd activa en http://127.0.0.1:18232"
    si srv == 0 entonces
        imprimir api_alerta_puerto_en_uso("127.0.0.1", 18232, "HTTP")
    sino
        mientras i < 100 hacer
            socket cli = tcp_aceptar(srv)
            si cli == 0 entonces
            sino
                texto solicitud_http = api_leer_solicitud_http(cli)
                texto respuesta = jd_app(solicitud_http)
                api_tcp_enviar_texto_completo(cli, respuesta)
                tcp_cerrar(cli)
                i = i + 1
            fin_si
        fin_mientras
        tcp_cerrar(srv)
    fin_si
fin_principal