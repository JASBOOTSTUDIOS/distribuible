# Test de verificación - Estructura corregida del bubble sort
# Este test verifica que el workaround para el bug del compilador funciona

principal
    # Crear una lista de valores para ordenar
    lista valores = crear_lista()
    lista_agregar(valores, 5)
    lista_agregar(valores, 2)
    lista_agregar(valores, 8)
    lista_agregar(valores, 1)
    lista_agregar(valores, 9)

    imprimir("Lista original:")
    entero idx = 0
    mientras idx < lista_tamano(valores) hacer
        elemento val = lista_obtener(valores, idx)
        imprimir(val)
        idx = idx + 1
    fin_mientras

    # Bubble sort con estructura corregida (sin si-sino-si anidado)
    entero j = 0
    mientras j < lista_tamano(valores) hacer
        entero k = j + 1
        mientras k < lista_tamano(valores) hacer
            elemento v1 = lista_obtener(valores, j)
            elemento v2 = lista_obtener(valores, k)
            si v2 < v1 entonces
                # Intercambiar - usando la estructura CORREGIDA
                lista nueva = crear_lista()
                entero m = 0
                mientras m < lista_tamano(valores) hacer
                    # Workaround para bug del compilador con si-sino-si anidados
                    elemento valor_a_agregar = lista_obtener(valores, m)
                    si m == j entonces
                        valor_a_agregar = v2
                    fin_si
                    si m == k entonces
                        valor_a_agregar = v1
                    fin_si
                    lista_agregar(nueva, valor_a_agregar)
                    m = m + 1
                fin_mientras
                valores = nueva
            fin_si
            k = k + 1
        fin_mientras
        j = j + 1
    fin_mientras

    imprimir("Lista ordenada:")
    entero idx2 = 0
    mientras idx2 < lista_tamano(valores) hacer
        elemento val = lista_obtener(valores, idx2)
        imprimir(val)
        idx2 = idx2 + 1
    fin_mientras

    imprimir("Test completado exitosamente!")
fin_principal
