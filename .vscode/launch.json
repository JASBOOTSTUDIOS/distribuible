{
  "version": "0.2.0",
  "configurations": [
    
    auto
    {
      "name": "Depurar Jasboot",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/.vscode/run-jasb.cjs",
      "args": ["${file}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "JASBOOT_REPO_ROOT": "${workspaceFolder}"
      }
    },
    {
      "name": "Ejecutar Jasboot (sin depuración)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/.vscode/run-jasb.cjs",
      "args": ["${file}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "noDebug": true,
      "env": {
        "JASBOOT_REPO_ROOT": "${workspaceFolder}"
      }
    },
    {
      "name": "Ejecutar Jasboot (AOT / transpilador C)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/.vscode/run-jasb.cjs",
      "args": ["${file}", "--aot"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "noDebug": true,
      "env": {
        "JASBOOT_REPO_ROOT": "${workspaceFolder}"
      }
    }
  ]
}
