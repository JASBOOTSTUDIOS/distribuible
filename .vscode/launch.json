{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Jasboot: ejecutar .jasb (jbc)",
      "type": "pwa-node",
      "request": "launch",
      "program": "${fileWorkspaceFolder}/.vscode/run-jasb.cjs",
      "args": ["${file}"],
      "cwd": "${fileWorkspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
