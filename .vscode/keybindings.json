[
  {
    "key": "f5",
    "command": "workbench.action.debug.start",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "ctrl+f5",
    "command": "workbench.action.debug.run",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
      "text": "node '${workspaceFolder}/.vscode/run-jasb.cjs' '${file}'\u000D"
    },
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.runTask",
    "args": "jasboot-compile"
  },
  {
    "key": "ctrl+shift+r",
    "command": "workbench.action.tasks.runTask",
    "args": "jasboot-run"
  },
  {
    "key": "ctrl+shift+l",
    "command": "jasboot.toggleLogging",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "f6",
    "command": "workbench.action.tasks.runTask",
    "args": "Jasboot: ejecutar con transpilador (AOT)",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "ctrl+shift+alt+s",
    "command": "workbench.action.tasks.runTask",
    "args": "Ejecutar con Compilador Soberano",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  },
  {
    "key": "ctrl+shift+d",
    "command": "jasboot.openDocumentation",
    "when": "editorTextFocus && (editorLangId == 'jasboot' || resourceExtname == '.jasb' || resourceExtname == '.jd')"
  }
]
