# Texto + LCG (`usar todo` sobre modulo numerico).
usar todo de "m01_lcg.jasb"

enviar funcion texto_digest(texto s) retorna entero
    entero acc = 0
    entero i = 0
    mientras i < longitud(s) hacer
        acc = acc + codigo_caracter(str_extraer_caracter(s, i))
        acc = mad_lcg(acc, i)
        i += 1
    fin_mientras
    retornar acc
fin_funcion
