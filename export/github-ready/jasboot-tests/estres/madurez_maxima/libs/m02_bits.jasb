# Bits (`usar { }` nominal sobre semilla).
usar { MAD_SEED } de "m00_seeds.jasb"

enviar funcion bit_mix(entero v) retorna entero
    entero u = v + (MAD_SEED % 65536)
    entero sh = (u % 5) + 1
    entero mix_l = bit_shl(u % 16, sh)
    entero mix_r = bit_shr(u, 2)
    retornar mix_l + mix_r
fin_funcion
