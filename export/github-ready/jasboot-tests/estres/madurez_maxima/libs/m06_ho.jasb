# Orden superior: funcion como parametro (`enviar` x2).

enviar funcion mad_inc(entero z) retorna entero
    retornar z + 1
fin_funcion

enviar funcion mad_apply_n(funcion f, entero x, entero n) retorna entero
    entero r = x
    entero k = 0
    mientras k < n hacer
        r = f(r)
        k += 1
    fin_mientras
    retornar r
fin_funcion
