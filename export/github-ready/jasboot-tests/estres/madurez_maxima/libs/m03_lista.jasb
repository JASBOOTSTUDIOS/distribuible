# Listas: agregar / obtener / tamano en bucle (cadena sobre LCG + cap).
usar todas de "m01_lcg.jasb"
usar { MAD_CAP_LISTA } de "m00_seeds.jasb"

enviar funcion lista_checksum(entero n) retorna entero
    si n < 1 entonces
        retornar 0
    fin_si
    si n > MAD_CAP_LISTA entonces
        n = MAD_CAP_LISTA
    fin_si
    lista L = crear_lista()
    entero i = 0
    entero acc = 0
    mientras i < n hacer
        entero v = mad_lcg(i * 31, i)
        mem_lista_agregar(L, v)
        acc = acc + v
        i += 1
    fin_mientras
    entero j = 0
    mientras j < n hacer
        acc = acc + mem_lista_obtener(L, j)
        j += 1
    fin_mientras
    retornar acc + mem_lista_tamano(L)
fin_funcion
