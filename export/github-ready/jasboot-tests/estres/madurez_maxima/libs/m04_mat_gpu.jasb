# "GPU logica": pipeline mat4 + vec4 en CPU (misma API que escenas 3D documentadas).
# No hay driver GPU desde Jasboot; esto maximiza FPU y opcodes matriciales.

enviar constante entero GPU_MAT_ROUNDS = 22

enviar funcion mad_gpu_checksum() retorna flotante
    mat4 A
    mat4 B
    mat4 C
    vec4 vin
    vec4 vout
    mat4_identidad(A)
    mat4_identidad(B)
    A.e0 = 1.02
    A.e5 = 0.98
    B.e12 = 0.07
    B.e13 = -0.04
    flotante s = 0.0
    entero u = 0
    mientras u < GPU_MAT_ROUNDS hacer
        A.e10 = A.e10 + 0.015
        mat4_mul(C, A, B)
        vin.x = 0.25
        vin.y = -0.18
        vin.z = 0.09
        vin.w = 1.0
        mat4_mul_vec4(vout, C, vin)
        si vout.x > vout.y entonces
            s = s + vout.x * 0.7 + vout.z * 0.2
        sino
            s = s + vout.y * 0.6 + vout.w * 0.1
        fin_si
        u += 1
    fin_mientras
    retornar s
fin_funcion
