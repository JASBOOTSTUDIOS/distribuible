# Suite madurez_maxima — integracion amplia (CPU, listas, texto, FPU/mat4, modulos).
#
# Modulos: 11 bibliotecas en libs/ + este main. Variantes: usar todas / usar todo / usar { } de /
# activar_modulo todas de. Ver README.md (mapa y como subir carga).
#
# Salida: checksum entero; tamano lista scratch; GPU_MAT_ROUNDS; flotante gpu_s; tag texto.
# Valores exactos del checksum dependen de MAD_CPU_OUTER (ajustar README tras primera corrida).

usar todas de "libs/m07_chain.jasb"
usar todo de "libs/m05_texto.jasb"
usar { mad_gpu_checksum, GPU_MAT_ROUNDS } de "libs/m04_mat_gpu.jasb"
usar { wrap_lcg } de "libs/m10_wrap.jasb"
usar { mad_apply_n, mad_inc } de "libs/m06_ho.jasb"
usar { bit_mix } de "libs/m02_bits.jasb"
usar { MAD_CPU_OUTER } de "libs/m00_seeds.jasb"
activar_modulo todas de "libs/m08_side_a.jasb"
activar_modulo todas de "libs/m09_side_b.jasb"

registro MadU
    entero cpu_acc
    entero lista_extra
fin_registro

funcion fib_local(entero n) retorna entero
    si n <= 1 entonces
        retornar n
    fin_si
    retornar fib_local(n - 1) + fib_local(n - 2)
fin_funcion

principal
    macro bump = (q) => q + 3

    MadU st
    st.cpu_acc = 0
    st.lista_extra = 0

    st.cpu_acc = st.cpu_acc + texto_digest("madurez_maxima_v1")
    st.cpu_acc = st.cpu_acc + (SIDE_A % 1000) + (SIDE_B % 1000)
    st.cpu_acc = st.cpu_acc + mad_apply_n(mad_inc, 0, 28)
    st.cpu_acc = st.cpu_acc + wrap_lcg(19, 23)
    st.cpu_acc = st.cpu_acc + fib_local(12)
    st.cpu_acc = st.cpu_acc + bump(900)

    intentar
        lanzar "boom"
    atrapar e
        st.cpu_acc = st.cpu_acc + longitud(e)
    final
        st.cpu_acc = st.cpu_acc + 2
    fin_intentar

    entero k = 0
    mientras k < MAD_CPU_OUTER hacer
        st.cpu_acc = st.cpu_acc + mega_mix(k)
        st.cpu_acc = st.cpu_acc + bit_mix(k)
        si k % 17 == 0 entonces
            st.cpu_acc = st.cpu_acc + wrap_lcg(k, k % 89)
        fin_si
        st.cpu_acc = st.cpu_acc + bit_shl(k % 8, (k % 4) + 1)
        k += 1
    fin_mientras

    lista buf_scratch = crear_lista()
    entero z = 0
    mientras z < 300 hacer
        entero vz = mad_lcg(z % 4096, z % 211)
        mem_lista_agregar(buf_scratch, vz)
        z += 1
    fin_mientras
    entero tam_buf = mem_lista_tamano(buf_scratch)
    st.lista_extra = tam_buf

    flotante gpu_s = mad_gpu_checksum()

    entero sel = st.cpu_acc % 5
    seleccionar sel hacer
        caso 0
            st.cpu_acc = st.cpu_acc + 11
        caso 1
            st.cpu_acc = st.cpu_acc + 13
        defecto
            st.cpu_acc = st.cpu_acc + 17
    fin_seleccionar

    entero c2 = 0
    hacer
        st.cpu_acc = st.cpu_acc + c2 % 3
        c2 += 1
    mientras c2 < 9 fin_hacer

    entero r3 = 0
    mientras r3 < 60 hacer
        si r3 % 9 == 0 entonces
            r3 += 1
            continuar
        fin_si
        si r3 > 51 entonces
            romper
        fin_si
        st.cpu_acc = st.cpu_acc + (r3 % 7)
        r3 += 1
    fin_mientras

    bool ok = st.cpu_acc > 100000
    texto tag = ok ? "ok" : "low"

    imprimir st.cpu_acc
    imprimir ""
    imprimir st.lista_extra
    imprimir ""
    imprimir GPU_MAT_ROUNDS
    imprimir ""
    imprimir_flotante(gpu_s)
    imprimir ""
    imprimir tag
fin_principal
