# Simulacion tipo cajero / banco: orden superior (funcion recibe funcion).
# Sin registro; solo entero, texto, si, mientras, globales y punteros a funcion.
# Salidas esperadas (lineas consecutivas con imprimir):
#   700
#   550
#   450
#   550
#   575
#   13
#   8
#   (ultima linea: texto con "OK")
#
# Nota compilador: las funciones admiten como maximo 4 parametros en la firma;
# por eso el retiro encadenado usa monto fijo 200 en el cuerpo de encadenar_mov.

funcion aplicar_mov(funcion op, entero saldo, entero monto) retorna entero
    retornar op(saldo, monto)
fin_funcion

funcion op_deposito(entero s, entero m) retorna entero
    retornar s + m
fin_funcion

funcion op_retiro(entero s, entero m) retorna entero
    si s >= m entonces
        retornar s - m
    sino
        retornar s
    fin_si
fin_funcion

funcion encadenar_mov(funcion primera, funcion segunda, entero s, entero monto_dep) retorna entero
    entero t
    t = primera(s, monto_dep)
    retornar segunda(t, 200)
fin_funcion

funcion aplicar_uno(funcion f, entero v) retorna entero
    retornar f(v)
fin_funcion

funcion estrategia_par(entero x, entero m) retorna entero
    retornar x + m
fin_funcion

funcion estrategia_impar(entero x, entero m) retorna entero
    retornar x - m
fin_funcion

funcion elegir_por_parity(funcion si_par, funcion si_impar, entero k, entero m) retorna entero
    entero r
    r = k - (k / 2) * 2
    si r == 0 entonces
        retornar si_par(k, m)
    sino
        retornar si_impar(k, m)
    fin_si
fin_funcion

principal
    entero saldo
    entero i
    entero puntos
    entero r_par
    entero r_imp
    funcion h_bonus
    entero saldo_tras_bonus

    saldo = 500

    saldo = aplicar_mov(op_deposito, saldo, 200)
    imprimir saldo

    saldo = aplicar_mov(op_retiro, saldo, 150)
    imprimir saldo

    saldo = encadenar_mov(op_deposito, op_retiro, saldo, 100)
    imprimir saldo

    i = 0
    mientras i < 100 hacer
        saldo = aplicar_mov(op_deposito, saldo, 1)
        i = i + 1
    fin_mientras
    imprimir saldo

    h_bonus = (entero t) => t + 25
    saldo_tras_bonus = aplicar_uno(h_bonus, saldo)
    imprimir saldo_tras_bonus

    puntos = 10
    r_par = elegir_por_parity(estrategia_par, estrategia_impar, puntos, 3)
    imprimir r_par

    puntos = 11
    r_imp = elegir_por_parity(estrategia_par, estrategia_impar, puntos, 3)
    imprimir r_imp

    imprimir "P1_20_1 banco+rifa HOF OK"
fin_principal
