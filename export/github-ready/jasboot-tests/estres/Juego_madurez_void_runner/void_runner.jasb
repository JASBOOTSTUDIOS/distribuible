# VOID RUNNER — juego interactivo de madurez del lenguaje (modulos, registro, macros,
# bucles anidados, ingreso_inmediato, limpiar_consola, interpolacion, flotantes, llamar).
# Objetivo: esquivar obstaculos "#" que caen; "@ eres tu. a/A izquierda, d/D derecha, q fin.
# Cada fotograma ejecuta VOID_PERF_ITER mezclas LCG (`mod_void_mix`) para estresar CPU.
# Victoria de aguante si llegas a VOID_LIM_TICKS ticks sin impacto. Ver README.md (modo benchmark).

usar todas de "mod_void_core.jasb"

constante entero VOID_LIM_TICKS = 25000

registro EstadoVoid
    entero puntos
    entero ticks
    entero col_jug
    entero vivo
fin_registro

principal
    macro bonus_tick = (t) => t + 1

    EstadoVoid st
    st.puntos = 0
    st.ticks = 0
    st.col_jug = VOID_ANCHO / 2
    st.vivo = 1

    entero perf_acum = 7919

    entero o1x = 0
    entero o1y = 0
    entero o1a = 0
    entero o2x = 0
    entero o2y = 0
    entero o2a = 0
    entero o3x = 0
    entero o3y = 0
    entero o3a = 0
    entero o4x = 0
    entero o4y = 0
    entero o4a = 0
    entero o5x = 0
    entero o5y = 0
    entero o5a = 0
    entero o6x = 0
    entero o6y = 0
    entero o6a = 0
    entero o7x = 0
    entero o7y = 0
    entero o7a = 0
    entero o8x = 0
    entero o8y = 0
    entero o8a = 0

    entero fila_jug = VOID_ALTO - 2
    entero fin_por = 0

    limpiar_consola
    imprimir "\negrVOID RUNNER\norm — a/d mover, q salir. Nucleo perf = ${VOID_PERF_ITER} iter/tick.\n"

    mientras st.vivo == 1 y st.ticks < VOID_LIM_TICKS hacer
        entero w = 0
        mientras w < VOID_PERF_ITER hacer
            perf_acum = llamar mod_void_mix(perf_acum, w)
            w = bonus_tick(w)
        fin_mientras

        limpiar_consola
        flotante intensidad = convertir_flotante(str_desde_numero(st.ticks % 100)) * 0.01
        imprimir "\ncianTick ${st.ticks}  col ${st.col_jug}  perf_acum mod 1000 = ${perf_acum % 1000}\norm\n"
        imprimir "intensidad~ "
        imprimir_flotante(intensidad)
        imprimir "\n\n"

        entero fila = 0
        mientras fila < VOID_ALTO hacer
            texto linea = ""
            entero col = 0
            mientras col < VOID_ANCHO hacer
                texto cel = "."
                si fila == fila_jug y col == st.col_jug entonces
                    cel = "@"
                fin_si
                si o1a == 1 y o1x == col y o1y == fila entonces
                    cel = "#"
                fin_si
                si o2a == 1 y o2x == col y o2y == fila entonces
                    cel = "#"
                fin_si
                si o3a == 1 y o3x == col y o3y == fila entonces
                    cel = "#"
                fin_si
                si o4a == 1 y o4x == col y o4y == fila entonces
                    cel = "#"
                fin_si
                si o5a == 1 y o5x == col y o5y == fila entonces
                    cel = "#"
                fin_si
                si o6a == 1 y o6x == col y o6y == fila entonces
                    cel = "#"
                fin_si
                si o7a == 1 y o7x == col y o7y == fila entonces
                    cel = "#"
                fin_si
                si o8a == 1 y o8x == col y o8y == fila entonces
                    cel = "#"
                fin_si
                linea = concatenar(linea, cel)
                col += 1
            fin_mientras
            imprimir linea
            fila += 1
        fin_mientras

        imprimir "\n[a izq] [d der] [q fin] — hasta 1 s por turno (espera activa)\n"
        # limpiar_consola()
        texto cmd = ""
        entero t_inicio = obtener_timestamp()
        mientras longitud(cmd) == 0 y diferencia_en_segundos(t_inicio, obtener_timestamp()) < 1 hacer
            ingreso_inmediato cmd
        fin_mientras

        seleccionar cmd hacer
            caso "q", "Q"
                st.vivo = 0
                fin_por = 1
            caso "a", "A"
                st.col_jug = st.col_jug - 1
                st.col_jug = llamar mod_void_clamp(st.col_jug, 0, VOID_ANCHO - 1)
            caso "d", "D"
                st.col_jug = st.col_jug + 1
                st.col_jug = llamar mod_void_clamp(st.col_jug, 0, VOID_ANCHO - 1)
            defecto
                si longitud(cmd) > 0 entonces
                    perf_acum = llamar mod_void_mix(perf_acum, codigo_caracter(cmd))
                fin_si
        fin_seleccionar

        si o1a == 1 entonces
            o1y = o1y + 1
            si o1y >= VOID_ALTO entonces
                o1a = 0
            fin_si
        fin_si
        si o2a == 1 entonces
            o2y = o2y + 1
            si o2y >= VOID_ALTO entonces
                o2a = 0
            fin_si
        fin_si
        si o3a == 1 entonces
            o3y = o3y + 1
            si o3y >= VOID_ALTO entonces
                o3a = 0
            fin_si
        fin_si
        si o4a == 1 entonces
            o4y = o4y + 1
            si o4y >= VOID_ALTO entonces
                o4a = 0
            fin_si
        fin_si
        si o5a == 1 entonces
            o5y = o5y + 1
            si o5y >= VOID_ALTO entonces
                o5a = 0
            fin_si
        fin_si
        si o6a == 1 entonces
            o6y = o6y + 1
            si o6y >= VOID_ALTO entonces
                o6a = 0
            fin_si
        fin_si
        si o7a == 1 entonces
            o7y = o7y + 1
            si o7y >= VOID_ALTO entonces
                o7a = 0
            fin_si
        fin_si
        si o8a == 1 entonces
            o8y = o8y + 1
            si o8y >= VOID_ALTO entonces
                o8a = 0
            fin_si
        fin_si

        entero intervalo = llamar mod_void_dificultad(st.ticks)
        si llamar mod_void_mod(st.ticks, intervalo) == 0 entonces
            entero sem = perf_acum + st.ticks * 17
            entero nx = llamar mod_void_mod(llamar mod_void_mix(sem, st.col_jug), VOID_ANCHO)
            si st.ticks < 20 y nx == st.col_jug entonces
                nx = llamar mod_void_mod(nx + 4 + st.ticks, VOID_ANCHO)
            fin_si
            si o1a == 0 entonces
                o1a = 1
                o1x = nx
                o1y = 0
            sino si o2a == 0 entonces
                o2a = 1
                o2x = nx
                o2y = 0
            sino si o3a == 0 entonces
                o3a = 1
                o3x = nx
                o3y = 0
            sino si o4a == 0 entonces
                o4a = 1
                o4x = nx
                o4y = 0
            sino si o5a == 0 entonces
                o5a = 1
                o5x = nx
                o5y = 0
            sino si o6a == 0 entonces
                o6a = 1
                o6x = nx
                o6y = 0
            sino si o7a == 0 entonces
                o7a = 1
                o7x = nx
                o7y = 0
            sino si o8a == 0 entonces
                o8a = 1
                o8x = nx
                o8y = 0
            fin_si
        fin_si

        entero choc = 0
        si o1a == 1 y o1x == st.col_jug y o1y == fila_jug entonces
            choc = 1
        fin_si
        si o2a == 1 y o2x == st.col_jug y o2y == fila_jug entonces
            choc = 1
        fin_si
        si o3a == 1 y o3x == st.col_jug y o3y == fila_jug entonces
            choc = 1
        fin_si
        si o4a == 1 y o4x == st.col_jug y o4y == fila_jug entonces
            choc = 1
        fin_si
        si o5a == 1 y o5x == st.col_jug y o5y == fila_jug entonces
            choc = 1
        fin_si
        si o6a == 1 y o6x == st.col_jug y o6y == fila_jug entonces
            choc = 1
        fin_si
        si o7a == 1 y o7x == st.col_jug y o7y == fila_jug entonces
            choc = 1
        fin_si
        si o8a == 1 y o8x == st.col_jug y o8y == fila_jug entonces
            choc = 1
        fin_si
        si choc == 1 entonces
            st.vivo = 0
            fin_por = 2
        fin_si

        st.puntos = st.ticks
        st.ticks = st.ticks + 1
    fin_mientras

    limpiar_consola
    si st.ticks >= VOID_LIM_TICKS entonces
        imprimir "\verdRESISTENCIA: limite ${VOID_LIM_TICKS} ticks — VM y compilador en ritmo sostenido.\norm\n"
    sino si fin_por == 2 entonces
        imprimir "\rojoIMPACTO — nucleo de mezcla y rejilla no bastaron.\norm\n"
    sino si fin_por == 1 entonces
        imprimir "\amarSalida voluntaria (q).\norm\n"
    sino
        imprimir "\amarFin de sesion.\norm\n"
    fin_si
    entero pa_m = perf_acum % 1000000
    imprimir "Ticks sobrevividos: ${st.puntos}  perf_acum_mod = ${pa_m}\n"
fin_principal
