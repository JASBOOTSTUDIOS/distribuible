

principal

    texto menu = ""

    mientras menu no es igual a "salir" hacer
        limpiar_consola
        imprimir " ================ Cajero ATM ================"
        imprimir "1. Registrarse"
        imprimir "2. Iniciar sesión"
        imprimir "3. Salir"
        imprimir_sin_salto "Ingrese una opcion: "
        ingresar_texto menu
        seleccionar menu hacer
            caso 1
                imprimir "Reagistrado exitosamente"
                
            caso 2
                imprimir "Sesion iniciada exitosamente"
            caso 3
                menu = "salir"
            defecto
                imprimir "Opcion no valida"
        fin_seleccionar
    fin_mientras

fin_principal