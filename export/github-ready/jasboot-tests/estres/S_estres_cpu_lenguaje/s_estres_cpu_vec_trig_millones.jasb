# S: estrés — 4e7 iteraciones: vec3_normalizar + vec3_dot + sin/cos por vuelta.
# Esperado (jb): 0.6077, 0.7941, 0.0088, 8.0000 y linea vacia (float32; VM actual).
# Carga: ~1.6e8 ops flotantes aprox; puede tardar ~1–3 min segun CPU.

principal
    vec3 base
    vec3 nu
    vec3 luz
    vec3 luz_u
    flotante ang
    flotante acu
    entero k

    base = vec3(3.0, 4.0, 0.0)
    luz = vec3(0.25, 0.35, 0.9)
    vec3_normalizar(luz_u, luz)
    acu = 0.0
    k = 0
    mientras k < 40000000 hacer
        ang = (k % 360) * 0.01745329252
        base.x = cos(ang) + 2.0
        base.y = sin(ang) + 3.0
        base.z = (k % 7) * 0.01
        vec3_normalizar(nu, base)
        acu = acu + vec3_dot(nu, luz_u) * 0.000001
        k = k + 1
    fin_mientras
    imprimir nu.x
    imprimir ""
    imprimir nu.y
    imprimir ""
    imprimir nu.z
    imprimir ""
    imprimir acu
    imprimir ""
fin_principal
