# S: estrés — 600000 ciclos: mat3_mul_vec3 + mat4_mul_vec4 + mat3_mul + cos/sin por vuelta.
# Esperado (jb): 600588.0625 y linea vacia (acumulador tr).

principal
    mat3 r3
    mat3 p3
    mat4 m4
    vec3 v3
    vec3 w3
    vec4 v4
    vec4 w4
    flotante co
    flotante sn
    flotante tr
    entero k

    mat4_identidad(m4)
    m4.e3 = 0.5
    m4.e7 = -0.25
    v4 = vec4(1.0, 1.0, 0.0, 1.0)

    r3.e0 = 1.0
    r3.e1 = 0.0
    r3.e2 = 0.0
    r3.e3 = 0.0
    r3.e4 = 1.0
    r3.e5 = 0.0
    r3.e6 = 0.0
    r3.e7 = 0.0
    r3.e8 = 1.0

    v3 = vec3(1.0, 0.0, 0.0)
    tr = 0.0
    k = 0
    mientras k < 600000 hacer
        co = cos((k % 90) * 0.06981317008)
        sn = sin((k % 90) * 0.06981317008)
        r3.e0 = co
        r3.e1 = 0.0 - sn
        r3.e3 = sn
        r3.e4 = co
        mat3_mul_vec3(w3, r3, v3)
        mat4_mul_vec4(w4, m4, v4)
        mat3_mul(p3, r3, r3)
        tr = tr + p3.e0 + p3.e4 + p3.e8 + w3.x * 0.000001 + w4.x * 0.000001
        k = k + 1
    fin_mientras
    imprimir tr
    imprimir ""
fin_principal
