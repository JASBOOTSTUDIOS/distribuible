principal
    entero num_a = 0
    entero num_i = 0
    mientras num_i < 1000 hacer
        si num_i % 3 == 0 entonces
            si num_i % 5 == 0 entonces
                num_a = num_a + 1
            sino
                num_a = num_a + 2
            fin_si
        sino si num_i % 5 == 0 entonces
            num_a = num_a + 3
        sino
            num_a = num_a + 4
        fin_si
        num_i = num_i + 1
    fin_mientras
    imprimir num_a
fin_principal