principal
    # Prueba de cortocircuito con 'y' (AND)
    entero num_a = 0
    entero cero = 0
    
    # Si la primera parte es falsa (0), no se evalua la segunda parte,
    # por lo que no deberia fallar por division por cero en runtime.
    si num_a == 1 y (10 / cero) == 1 entonces
        imprimir 999
    fin_si
    
    imprimir 1  # Deberia llegar aqui sin crashear
    
    # Otro test para asegurar que si es verdadero, si se evalua el derecho
    si verdadero y verdadero entonces
        imprimir 10
    fin_si
fin_principal