principal
    entero num_a = 1
    entero num_b = 0

    si no (num_a > 0 y num_b == 0) entonces
        imprimir "mal"
    sino
        imprimir "bien compuesto"
    fin_si

    si no (num_a < 0 o num_b != 0) entonces
        imprimir "bien compuesto 2"
    sino
        imprimir "mal"
    fin_si
fin_principal