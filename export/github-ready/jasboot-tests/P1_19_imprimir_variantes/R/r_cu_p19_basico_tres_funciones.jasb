# R: imprimir_sin_salto + imprimir_flotante + imprimir_id.
# imprimir_flotante no anade salto de linea (solo printf en VM); imprimir_id tampoco.
# Salida: linea ABC; linea 2.5000; linea hola; linea vacia

principal
    imprimir_sin_salto "A"
    imprimir_sin_salto "B"
    imprimir "C"
    flotante x = 2.5
    imprimir_flotante(x)
    imprimir ""
    texto saludo = "hola"
    imprimir_id(saludo)
    imprimir ""
fin_principal
