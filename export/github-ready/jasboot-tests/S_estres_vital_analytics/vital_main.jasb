# S_estres_vital_analytics — bench modular tipo “pipeline de eventos” (mapa + lista + funciones + intentar + texto).
#
# Qué modela: muchas lecturas sintéticas, histograma (mapa), ventana acotada (lista + limpiar),
#   despacho round-robin de funciones (mapa de funciones), recuperación de error capturable,
#   salida numérica + línea texto con escala.
#
# Ejecutar desde ESTA carpeta (rutas relativas de `usar`):
#   Set-Location tests\S_estres_vital_analytics
#   & ..\..\sdk-dependiente\jas-compiler-c\bin\jbc.exe vital_main.jasb -e
#
# Subir carga: edita solo `v00_escala.jasb` (VITAL_OUTER, VITAL_RING_MAX, VITAL_KINDS).

usar { VITAL_OUTER, VITAL_RING_MAX, VITAL_KINDS } de "v00_escala.jasb"
usar todo de "v01_evento.jasb"
usar { vital_bootstrap_freq, vital_inc_freq, vital_max_bin } de "v02_frecuencias.jasb"
usar { vital_aplicar_contrib, vital_cont_a, vital_cont_b, vital_cont_c } de "v03_contrib.jasb"

principal
    mapa hist = mapa_crear()
    mapa ops = mapa_crear()
    lista ventana = crear_lista()
    vital_bootstrap_freq(hist, VITAL_KINDS)
    mapa_poner(ops, 0, vital_cont_a)
    mapa_poner(ops, 1, vital_cont_b)
    mapa_poner(ops, 2, vital_cont_c)

    entero acc = 0
    entero picos = 0
    entero i = 0
    mientras i < VITAL_OUTER hacer
        entero ev = vital_tick_evento(i)
        entero bucket = ev % VITAL_KINDS
        vital_inc_freq(hist, bucket)
        entero vmuestra = ev % 65536
        mem_lista_agregar(ventana, vmuestra)
        si mem_lista_tamano(ventana) > VITAL_RING_MAX entonces
            lista_limpiar(ventana)
            picos += 1
        fin_si
        funcion g = mapa_obtener(ops, i % 3)
        acc += vital_aplicar_contrib(g, ev)
        si i % 4091 == 0 entonces
            intentar
                entero z = mapa_obtener(hist, 999999)
                acc += z
            atrapar err
                acc += longitud(err)
            fin_intentar
        fin_si
        i += 1
    fin_mientras

    entero topbin = vital_max_bin(hist, VITAL_KINDS)
    entero escala_ticks = VITAL_OUTER
    texto num_ticks = str_desde_numero(escala_ticks)
    texto banner = concatenar("ticks=", num_ticks)

    imprimir acc
    imprimir ""
    imprimir topbin
    imprimir ""
    imprimir picos
    imprimir ""
    imprimir mem_lista_tamano(ventana)
    imprimir ""
    imprimir banner
    imprimir ""

    entero sel = acc % 4
    seleccionar sel hacer
        caso 0
            imprimir "vital:ok"
        caso 1
            imprimir "vital:ok"
        defecto
            imprimir "vital:ok"
    fin_seleccionar
    imprimir ""
fin_principal
