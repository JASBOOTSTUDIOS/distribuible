# Histograma en mapa: claves 0..kinds-1 con conteo inicial 0; incremento seguro (clave siempre existe).
enviar funcion vital_bootstrap_freq(mapa m, entero kinds) retorna entero
    entero j = 0
    mientras j < kinds hacer
        mapa_poner(m, j, 0)
        j += 1
    fin_mientras
    retornar kinds
fin_funcion

enviar funcion vital_inc_freq(mapa m, entero k) retorna entero
    entero c = mapa_obtener(m, k)
    mapa_poner(m, k, c + 1)
    retornar c + 1
fin_funcion

enviar funcion vital_max_bin(mapa m, entero kinds) retorna entero
    entero top = 0
    entero kk = 0
    mientras kk < kinds hacer
        entero fk = mapa_obtener(m, kk)
        si fk > top entonces
            top = fk
        fin_si
        kk += 1
    fin_mientras
    retornar top
fin_funcion
