# R: str_extraer_caracter por indice 0-based; codigo_caracter del fragmento.
# Salida: 72 105 (H e i de "Hi")

principal
    texto s = "Hi"
    texto h = str_extraer_caracter(s, 0)
    texto i = str_extraer_caracter(s, 1)
    imprimir(codigo_caracter(h))
    imprimir(codigo_caracter(i))
fin_principal
