# R: caracter literal ('x'), codigo_caracter, caracter_a_texto, byte_a_caracter / caracter_a_byte (identidad).
# Salida: 88, 89, Y

principal
    caracter cx = 'X'
    entero nx = codigo_caracter(caracter_a_texto(cx))
    imprimir(nx)
    caracter cy = byte_a_caracter(caracter_a_byte('Y'))
    entero ny = codigo_caracter(caracter_a_texto(cy))
    imprimir(ny)
    texto sy = caracter_a_texto(ny)
    imprimir(sy)
fin_principal
