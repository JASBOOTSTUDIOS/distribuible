funcion es_primo(entero n) retorna bool
    si n <= 1 entonces
        retornar falso
    fin_si
    entero i = 2
    mientras i * i <= n hacer
        si n % i == 0 entonces
            retornar falso
        fin_si
        i++
    fin_mientras
    retornar verdadero
fin_funcion

principal
    imprimir "\n--- Iniciando Prueba de Estres 5: Busqueda de Primos ---"
    entero maximo = 500
    entero contador = 0
    texto primos_encontrados = ""
    entero suma_primos = 0

    entero j = 2
    mientras j <= maximo hacer
        si es_primo(j) entonces
            primos_encontrados = primos_encontrados + j + ","
            contador++
            suma_primos += j
        fin_si
        j++
    fin_mientras

    macro analizar_resultado = (entero c, entero suma) => {
        texto analisis = "Suma es " + (suma % 2 == 0 ? "par" : "impar")
        retornar "Analisis final: " + c + " primos. " + analisis
    }

    imprimir "Se encontraron " + contador + " numeros primos hasta " + maximo
    imprimir "La suma de todos ellos es: " + suma_primos
    imprimir "Lista parcial de primos: " + primos_encontrados
    imprimir analizar_resultado(contador, suma_primos)
    imprimir "--- Fin de la Prueba de Estres 5 ---"
fin_principal