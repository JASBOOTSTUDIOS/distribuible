funcion transicion_estado(texto estado_actual, entero input) retorna texto
    seleccionar estado_actual hacer
        caso "INICIO"
            si input == 1 entonces
                retornar "PROCESANDO"
            sino
                retornar "ERROR"
            fin_si
        caso "PROCESANDO"
            seleccionar input hacer
                caso 2
                    retornar "ESPERANDO"
                defecto
                    retornar "PROCESANDO"
            fin_seleccionar
        caso "ESPERANDO"
            retornar input == 9 ? "FINALIZADO" : "ESPERANDO"
        caso "ERROR"
            retornar "INICIO"
        defecto
            retornar "INICIO"
    fin_seleccionar
fin_funcion

principal
    imprimir "\n--- Iniciando Prueba de Estres 6: Maquina de Estados ---"
    texto estado = "INICIO"
    
    // Simular una secuencia de inputs
    macro aplicar_input = (entero v) => {
        imprimir "Estado anterior: " + estado + " | Input: " + v
        estado = transicion_estado(estado, v)
        imprimir "Nuevo estado: " + estado
        retornar estado
    }
    
    aplicar_input(1)
    aplicar_input(0)
    aplicar_input(2)
    aplicar_input(9)
    aplicar_input(99)
    aplicar_input(1)
    // aplicar_input(3)
    
    imprimir "Estado final de la maquina: " + estado
    imprimir "--- Fin de la Prueba de Estres 6 ---"
fin_principal