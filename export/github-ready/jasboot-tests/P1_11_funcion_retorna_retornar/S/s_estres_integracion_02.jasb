funcion generar_reporte(entero id, entero puntaje) retorna texto
    texto estado = puntaje > 100 ? "CRITICO" : (puntaje > 50 ? "ADVERTENCIA" : "NORMAL")
    retornar "[ID: ${id}] - Puntaje: ${puntaje} - Estado: ${estado}"
fin_funcion

principal
    imprimir "\n\nIniciando estres 2: Cadenas, Interpolacion y Condicionales"
    
    texto log = ""
    entero j = 10
    mientras j > 0 hacer
        texto rep = generar_reporte(j, j * 15)
        log = log + rep + " |\n"
        j--
    fin_mientras
    
    imprimir log
    
    macro procesar_log = (texto l, entero factor) => {
        si factor % 2 == 0 entonces
            retornar "Log procesado con factor par: " + factor
        sino
            retornar "Log procesado con factor impar: " + factor
        fin_si
    }
    
    imprimir procesar_log(log, 15)
    imprimir procesar_log(log, 20)
    
    imprimir "Fin de la prueba 2"
fin_principal
