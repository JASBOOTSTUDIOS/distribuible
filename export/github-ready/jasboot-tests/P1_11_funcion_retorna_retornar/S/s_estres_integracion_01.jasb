funcion fibonacci(entero n) retorna entero
    si n <= 1 entonces
        retornar n
    fin_si
    entero f1 = fibonacci(n - 1)
    entero f2 = fibonacci(n - 2)
    retornar f1 + f2
fin_funcion

funcion es_primo(entero num) retorna bool
    si num <= 1 entonces
        retornar falso
    fin_si
    entero i = 2
    mientras i * i <= num hacer
        si num % i == 0 entonces
            retornar falso
        fin_si
        i++
    fin_mientras
    retornar verdadero
fin_funcion

principal
    imprimir "Iniciando estres 1: Funciones, Mates y Bucles"
    macro cuadrado = (entero x) => x * x
    
    entero suma_primos = 0
    entero i = 1
    mientras i <= 50 hacer
        si es_primo(i) entonces
            suma_primos += cuadrado(i)
        fin_si
        i++
    fin_mientras
    
    imprimir "La suma de los cuadrados de los primos hasta 50 es: " + suma_primos
    
    entero fib_10 = fibonacci(10)
    imprimir "Fibonacci de 10 es: " + fib_10
    
    texto resultado = fib_10 > 50 ? "Mayor a 50" : "Menor o igual a 50"
    imprimir "Condicion ternaria: ${resultado}"
    
    entero contador = 0
    hacer
        contador += 5
        si contador % 2 == 0 entonces
            continuar
        fin_si
        si contador > 20 entonces
            romper
        fin_si
    mientras contador < 100 fin_hacer
    
    imprimir "Fin de la prueba 1"
fin_principal
