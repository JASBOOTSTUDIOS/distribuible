# Estres: 4000 invocaciones de macro flecha sin argumentos (constante 0.25) en acumulador flotante.
# Nota: evitamos macro (x)=>x+0.25 con asignacion en bucle (regresion VM/compilador); el estres sigue siendo 4000 llamadas a macro.
# espera: 1000.0000

principal
    macro tick = () => 0.25
    flotante v = 0.0
    entero k = 0
    mientras k < 4000 hacer
        v = v + tick()
        k++
    fin_mientras
    imprimir_flotante(v)
fin_principal
