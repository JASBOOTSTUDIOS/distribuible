# P1_14 usar + P1_15 flotante: `usar todas de` y llamadas a funciones importadas.
# El modulo usa `si`/`sino` en su interior; aqui el principal tambien ramifica antes de imprimir.
# Salida esperada (4 lineas imprimir_flotante):
#   0.0000   clamp_pos(-3.5)
#   12.0000  clamp_pos(12.0)
#   2.5200   iva_de(12.0)
#   2.2500   max_fl(1.5, 2.25)

usar todas de "m_flotante_usar.jasb"

principal
    flotante n1 = -3.5
    flotante n2 = 12.0
    imprimir_flotante(clamp_pos(n1))
    imprimir_flotante(clamp_pos(n2))
    imprimir_flotante(iva_de(n2))
    flotante u = 1.5
    flotante v = 2.25
    si u < v entonces
        imprimir_flotante(max_fl(u, v))
    sino
        imprimir_flotante(0.0)
    fin_si
fin_principal
