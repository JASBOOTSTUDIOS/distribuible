# decimal(flotante, entero): retorna texto con N digitos fraccionarios (redondeo como printf %.*f).
# VM: OP_STR_FLOTANTE_PREC; precision 0..20 (segundo arg literal o expresion entera).
# Salida esperada (tres lineas imprimir + interpolacion):
#   3.14
#   3.1416
#   Pi~3.1

principal
    flotante x = 3.14159
    imprimir(decimal(x, 2))
    imprimir(decimal(x, 4))
    imprimir("Pi~${decimal(x, 1)}")
fin_principal
