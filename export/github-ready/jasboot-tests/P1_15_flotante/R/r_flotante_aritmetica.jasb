# Aritmetica basica en flotante: + - * / y literales.
# Salida esperada (orden):
#   3.2500  (fa + fb = 1.25 + 2.0)
#   linea de texto con la suma interpolada (mismo valor)
#   0.7500  (fb - fa)
#   linea texto resta
#   5.0000  (fa * 4.0)
#   linea texto multiplicacion
#   0.5000  (fb / 4.0)
#   linea texto division
# La VM imprime flotantes con 4 decimales; las lineas con imprimir "\n..." dependen del formato de texto.

principal
    flotante fa = 1.25
    flotante fb = 2.0
    # espera: 3.2500
    imprimir_flotante(fa + fb)
    imprimir "\n${fa} + ${fb} = ${fa + fb}"
    # espera: 0.7500
    imprimir_flotante(fb - fa)
    imprimir "\n${fb} - ${fa} = ${fb - fa}"
    # espera: 5.0000
    imprimir_flotante(fa * 4.0)
    imprimir "\n${fa} * 4.0 = ${fa * 4.0}"
    # espera: 0.5000
    imprimir_flotante(fb / 4.0)
    imprimir "\n${fb} / 4.0 = ${fb / 4.0}"
fin_principal
