# Comparadores flotantes: < > == != <= >= con variables, negativos, cero y literales a la izquierda.
# Transcripcion completa esperada (40 digitos, uno por cada imprimir): ver NOTAS_R.md en esta carpeta.
# Resumen: bloque1 doce lineas 111111000000; bloque2 100110; bloque3 110001; bloque4 111111; bloque5 1111; bloque6 000000.

principal
    # x=1.5, flotante_y=2.5, flotante_z=1.5 (evitar nombre 'y': palabra reservada logica)
    flotante x = 1.5
    flotante flotante_y = 2.5
    flotante flotante_z = 1.5

    # esperado: 111111000000
    imprimir "Bloque 1a: condiciones verdaderas deben imprimir 1 -> resultado:111111"
    # --- Bloque 1a: condicion verdadera debe imprimir 1 ---
    si x < flotante_y entonces imprimir 1 sino imprimir 0 fin_si                    # -> 1  (1.5 < 2.5)
    si flotante_y > x entonces imprimir 1 sino imprimir 0 fin_si                    # -> 1  (2.5 > 1.5)
    si x == flotante_z entonces imprimir 1 sino imprimir 0 fin_si                   # -> 1  (1.5 == 1.5)
    si x != flotante_y entonces imprimir 1 sino imprimir 0 fin_si                   # -> 1  (1.5 != 2.5)
    si x <= flotante_z entonces imprimir 1 sino imprimir 0 fin_si                   # -> 1  (1.5 <= 1.5)
    si flotante_y >= x entonces imprimir 1 sino imprimir 0 fin_si                   # -> 1  (2.5 >= 1.5)

#Bloque 1b: condiciones falsas deben imprimir 0 -> resultado:000000
    imprimir "Bloque 1b: condiciones falsas deben imprimir 0 -> resultado:000000"
    # --- Bloque 1b: condiciones falsas deben imprimir 0 ---
    si x < flotante_y entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                    # -> 0
    si flotante_y > x entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                    # -> 0
    si x == flotante_z entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                   # -> 0
    si x != flotante_y entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                   # -> 0
    si x <= flotante_z entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                   # -> 0
    si flotante_y >= x entonces imprimir "si verdadero resultado esperado 0" sino imprimir 1 fin_si                   # -> 0
    

    imprimir "\n Bloque 2: reflexividad sobre u = 3.25 -> 100110"
    # --- Bloque 2: reflexividad sobre u = 3.25 ---
    flotante u = 3.25
    si u == u entonces imprimir 1 sino imprimir 0 fin_si                            # -> 1
    si u < u entonces imprimir 1 sino imprimir 0 fin_si                             # -> 0
    si u > u entonces imprimir 1 sino imprimir 0 fin_si                             # -> 0
    si u <= u entonces imprimir 1 sino imprimir 0 fin_si                            # -> 1
    si u >= u entonces imprimir 1 sino imprimir 0 fin_si                            # -> 1
    si u != u entonces imprimir 1 sino imprimir 0 fin_si                            # -> 0  (mismo valor: no desigual)

    imprimir "\n Bloque 3: neg_a=-5, neg_b=-2 (orden en la recta real) -> 110001"
    # --- Bloque 3: neg_a=-5, neg_b=-2 (orden en la recta real) ---
    flotante neg_a = -5.0
    flotante neg_b = -2.0
    si neg_a < neg_b entonces imprimir 1 sino imprimir 0 fin_si                     # -> 1  (-5 < -2)
    si neg_b > neg_a entonces imprimir 1 sino imprimir 0 fin_si                     # -> 1  (-2 > -5)
    si neg_b <= neg_a entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (-2 <= -5 es falso)
    si neg_a >= neg_b entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (-5 >= -2 es falso)
    si neg_a == neg_b entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0
    si neg_a != neg_b entonces imprimir 1 sino imprimir 0 fin_si                    # -> 1

    # esperado: 110001
    imprimir "Bloque 4: cero, epsilon y signos -> 111111"
    # --- Bloque 4: cero, epsilon y signos ---
    flotante val_cero = 0.0
    flotante val_eps = 0.001
    flotante val_menos_uno = -1.0
    flotante cero_ref = 0.0
    si val_cero == cero_ref entonces imprimir 1 sino imprimir 0 fin_si              # -> 1
    si val_cero < val_eps entonces imprimir 1 sino imprimir 0 fin_si                # -> 1
    si val_eps > val_cero entonces imprimir 1 sino imprimir 0 fin_si                # -> 1
    si val_menos_uno < val_cero entonces imprimir 1 sino imprimir 0 fin_si          # -> 1  (-1 < 0)
    si val_cero > val_menos_uno entonces imprimir 1 sino imprimir 0 fin_si          # -> 1  (0 > -1)
    si val_cero != val_eps entonces imprimir 1 sino imprimir 0 fin_si               # -> 1

    # esperado: 111111
    imprimir "Bloque 5: literal flotante a la izquierda del operador -> 1111"
    # --- Bloque 5: literal flotante a la izquierda del operador ---
    si 10.5 > flotante_y entonces imprimir 1 sino imprimir 0 fin_si                 # -> 1
    si 1.5 == x entonces imprimir 1 sino imprimir 0 fin_si                          # -> 1
    si 0.0 < flotante_y entonces imprimir 1 sino imprimir 0 fin_si                  # -> 1
    si -0.5 < x entonces imprimir 1 sino imprimir 0 fin_si                           # -> 1  (-0.5 < 1.5)

    # esperado: 1111
    imprimir "Bloque 6: comparaciones necesariamente falsas con x / flotante_y / flotante_z -> 000000"
    # --- Bloque 6: comparaciones necesariamente falsas con x / flotante_y / flotante_z ---
    si flotante_y < x entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (2.5 < 1.5 falso)
    si x > flotante_y entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0
    si x == flotante_y entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0
    si x != flotante_z entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0  (1.5 == 1.5)
    si flotante_y <= x entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0
    si flotante_z < x entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (1.5 < 1.5 falso)

    # esperado: 000000
    imprimir "Bloque 7: comparaciones imposibles con x / flotante_y / flotante_z -> 000000"
    # --- Bloque 7: comparaciones imposibles con x / flotante_y / flotante_z ---
    si flotante_z < x entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (1.5 < 1.5 falso)
    si x > flotante_y entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0
    si x == flotante_y entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0
    si x != flotante_z entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0  (1.5 == 1.5)
    si flotante_y <= x entonces imprimir 1 sino imprimir 0 fin_si                   # -> 0
    si flotante_z < x entonces imprimir 1 sino imprimir 0 fin_si                    # -> 0  (1.5 < 1.5 falso)
fin_principal
