# E (ejecución): índice >= tamano en lista existente — compila; la VM debe terminar con código != 0.
# Esperado: jbc compila OK; stderr con mensaje "indice fuera de rango en lista";
#   no debe imprimirse la línea no_deberia.

principal
    lista buf = crear_lista()
    mem_lista_agregar(buf, 1)
    imprimir mem_lista_obtener(buf, 99)
    imprimir "no_deberia\n"
fin_principal
