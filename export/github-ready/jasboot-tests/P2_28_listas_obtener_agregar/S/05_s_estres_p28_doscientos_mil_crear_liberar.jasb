# S (05): 200 000 iteraciones crear_lista + un agregar + mem_lista_liberar (pool JMN bajo presion).
#   Sin intentar; comprueba que no se agota el pool de 10k slots al reciclar.
#
# Salida esperada, linea a linea:
#   1) 200000 — contador de vueltas completadas
#   2) linea vacia
#   3) 42 — lista final: un elemento
#   4) linea vacia

principal
    entero c = 0
    mientras c < 200000 hacer
        lista tmp = crear_lista()
        mem_lista_agregar(tmp, c)
        mem_lista_liberar(tmp)
        c += 1
    fin_mientras
    imprimir c
    imprimir ""
    lista u = crear_lista()
    mem_lista_agregar(u, 42)
    imprimir mem_lista_obtener(u, 0)
    imprimir ""
fin_principal
