# S (04): lista de 1000 elementos (valores 0..999); 1 000 000 de mem_lista_obtener con indice i % 1000
#   y acumulacion. Cada bloque de 1000 indices suma 0+1+...+999 = 499500; hay 1000 bloques.
#   Acumulado = 1000 * 499500 = 499500000 (cabe en entero de 32 bits con margen).
#
# Salida esperada, linea a linea:
#   1) 499500000
#   2) linea vacia

principal
    lista v = crear_lista()
    entero t = 0
    mientras t < 1000 hacer
        mem_lista_agregar(v, t)
        t += 1
    fin_mientras
    entero acum = 0
    entero k = 0
    entero idx = 0
    mientras k < 1000000 hacer
        idx = k % 1000
        acum += mem_lista_obtener(v, idx)
        k += 1
    fin_mientras
    imprimir acum
    imprimir ""
fin_principal
