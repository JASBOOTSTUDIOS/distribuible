# S (03): 2 000 000 incrementos dentro de intentar (sin fallo) — estresa OP_TRY_ENTER/LEAVE + bucle.
#
# Salida esperada, linea a linea:
#   1) 2000000
#   2) linea vacia
#   3) hecho
#   4) linea vacia

principal
    intentar
        entero n = 0
        entero j = 0
        mientras j < 2000000 hacer
            n += 1
            j += 1
        fin_mientras
        imprimir n
        imprimir ""
        imprimir "hecho"
        imprimir ""
    atrapar e
        imprimir "fallo"
        imprimir ""
        imprimir "${e}"
        imprimir ""
    fin_intentar
fin_principal
