# S: 500000 iteraciones mezclando bit_shl, << y >>.
# Esperado (jb): 31343500030 y linea vacia (checksum entero; recalibrar si cambia la VM).

principal
    entero k
    entero acc
    entero t

    acc = 0
    k = 0
    mientras k < 500000 hacer
        t = k % 31
        acc = acc + bit_shl(t, k % 6)
        acc = acc + (t << 1)
        acc = acc + (k >> 2)
        k = k + 1
    fin_mientras
    imprimir acc
    imprimir ""
fin_principal
