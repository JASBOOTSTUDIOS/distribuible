// r_llamar_retornar — retornar con subexpresion que empieza por llamar
// Esperado: compila; cuadruple(5) -> 20.
funcion doble(entero k) retorna entero
    imprimir k
    retornar k * 2
fin_funcion

funcion cuadruple(entero n) retorna entero
    imprimir n
    retornar llamar doble(llamar doble(n))
fin_funcion

principal
    imprimir llamar cuadruple(5)
fin_principal
