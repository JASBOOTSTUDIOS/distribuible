principal
    entero contador = 5
    imprimir contador
    
    contador = contador + 1
    imprimir contador
    
    contador = contador * 2
    imprimir contador
    
    contador = contador - 4
    imprimir contador
    
    contador = contador / 2
    imprimir contador
    
    contador = contador % 3
    imprimir contador
fin_principal
