principal
    # Casos de uso de modulo
    entero num = 17
    entero div1 = 5
    entero div2 = 2
    entero div3 = 10
    
    entero res1 = num % div1
    imprimir res1 # 17 % 5 = 2
    
    entero res2 = num % div2
    imprimir res2 # 17 % 2 = 1 (impar)
    
    entero res3 = num % div3
    imprimir res3 # 17 % 10 = 7 (ultimo digito)
    
    entero res4 = num % num
    imprimir res4 # 17 % 17 = 0
    
    entero res5 = (num + 3) % div3
    imprimir res5 # (17 + 3) % 10 = 20 % 10 = 0
fin_principal
