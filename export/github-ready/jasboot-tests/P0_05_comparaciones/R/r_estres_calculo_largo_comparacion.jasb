principal
    entero base1 = 100
    entero base2 = 200
    entero base3 = 300
    entero multi = 5
    entero divisor = 2
    entero mod = 7

    # Expresion gigante en el lado izquierdo vs expresion gigante en el lado derecho
    # Izquierda: 100 + (200 * 5) - (300 / 2) + (100 % 7)
    # = 100 + 1000 - 150 + 2 = 1100 - 150 + 2 = 952
    
    # Derecha: (300 - 200) * 5 + (100 * 2) + 252
    # = 100 * 5 + 200 + 252 = 500 + 200 + 252 = 952

    si base1 + (base2 * multi) - (base3 / divisor) + (base1 % mod) == (base3 - base2) * multi + (base1 * divisor) + 252 entonces
        imprimir 1
    sino
        imprimir 0
    fin_si

    # Ahora una negacion con el mismo nivel de complejidad, pero la parte derecha es un poco mas grande
    # Derecha: 952 + 1 = 953
    si base1 + (base2 * multi) - (base3 / divisor) + (base1 % mod) no es igual a (base3 - base2) * multi + (base1 * divisor) + 253 entonces
        imprimir 1
    sino
        imprimir 0
    fin_si

    # Desigualdades con expresiones masivas
    # 952 <= 953 -> verdadero
    si base1 + (base2 * multi) - (base3 / divisor) + (base1 % mod) es menor o igual a (base3 - base2) * multi + (base1 * divisor) + 253 entonces
        imprimir 1
    sino
        imprimir 0
    fin_si

    # 952 > 953 -> falso, entra al sino
    si base1 + (base2 * multi) - (base3 / divisor) + (base1 % mod) es mayor que (base3 - base2) * multi + (base1 * divisor) + 253 entonces
        imprimir 0
    sino
        imprimir 1
    fin_si
fin_principal
