    # Mayor que
    si num_b > num_a entonces
        imprimir 1 # Debe imprimir 1
    sino
        imprimir 0
    fin_si
    
    # Menor o igual
    si num_a <= num_c entonces
        imprimir 1 # Debe imprimir 1
    sino
