principal
    entero num_a = 10
    entero num_b = 20
    entero num_c = 10
    
    # Igualdad
    si num_a es igual a num_c entonces
        imprimir 1
    fin_si
    
    # Desigualdad (distinto/diferente)
    si num_a es distinto a num_b entonces
        imprimir 1
    fin_si
    
    si num_a es diferente a num_b entonces
        imprimir 1
    fin_si
    
    # Menor que
    si num_a es menor que num_b entonces
        imprimir 1
    fin_si
    
    # Mayor que
    si num_b es mayor que num_a entonces
        imprimir 1
    fin_si
    
    # Menor o igual
    si num_a es menor o igual a num_c entonces
        imprimir 1
    fin_si
    
    # Mayor o igual
    si num_b es mayor o igual a num_a entonces
        imprimir 1
    fin_si

    # Negados
    si num_a no es igual a num_b entonces
        imprimir 1
    fin_si
fin_principal
