# Produccion: todas las formas == != < > <= >= en ramas calientes repetidas.
principal
    entero acc = 0
    entero idx = 0
    mientras idx < 12000 hacer
        si idx == 0 entonces
            acc = acc + 1
        fin_si
        si idx != -1000 entonces
            acc = acc + 1
        fin_si
        si idx < 2000000 entonces
            acc = acc + 1
        fin_si
        si idx > -500 entonces
            acc = acc + 1
        fin_si
        si idx <= 11999 entonces
            acc = acc + 1
        fin_si
        si idx >= 0 entonces
            acc = acc + 1
        fin_si
        si (idx % 97 == 0) o no (idx % 101 == 0) entonces
            acc = acc + 2
        fin_si
        idx += 1
    fin_mientras
    imprimir acc
fin_principal
