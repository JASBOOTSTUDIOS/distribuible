// r_flecha_multilinea_llamadas — bloque flecha con función externa y ramas
// Esperado: compila y ejecuta; saludos, mayor de edad, acceso concedido.
// Mide: macro con bloque que llama `funcion` declarada, `si`/`sino`/`fin_si`, tipos en parámetros.

funcion saludar(texto nombre) retorna texto
    retornar "Hola " + nombre
fin_funcion

principal
    macro procesar = (texto nombre, edad) => {
        imprimir "Iniciando procesamiento de usuario..."
        texto saludo = saludar(nombre)
        imprimir saludo
        
        si edad >= 18 entonces
            imprimir nombre + " es mayor de edad."
            retornar verdadero
        sino
            imprimir nombre + " es menor de edad."
            retornar falso
        fin_si
    }

    bool puede_entrar = procesar("Carlos", 25)
    
    si puede_entrar entonces
        imprimir "Acceso concedido."
    sino
        imprimir "Acceso denegado."
    fin_si
fin_principal
