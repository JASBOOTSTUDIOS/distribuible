// r_flecha_multilinea — macro con cuerpo bloque `{ ... }`
// Esperado: compila y ejecuta; varios imprimir y resultado final 16 ( (5+3)*2 ).
// Mide: lambda multilínea, statements en bloque, `retornar` desde macro-flecha.

principal
    macro operar = (x, b) => {
        imprimir "Calculando suma y multiplicacion para: " + x + " y " + b
        entero suma = x + b
        imprimir "La suma es: " + suma
        retornar suma * 2
    }

    entero resultado = operar(5, 3)
    imprimir "Resultado final: " + resultado
fin_principal
