// s_estres_p12_presupuesto_hogar — integración P0–P1_12: macros/flecha + funciones + bucles anidados + interpolación + aritmética
// Esperado: compila y termina; imprime cabecera, varias líneas de detalle con ${...} y un resumen con totales coherentes.
// Mide: muchas macros (expresión y bloque), IIFE dentro de cadenas, llamadas a funcion desde principal y desde cuerpo de macro,
//       triple bucle anidado + micro-bucle hacer/mientras, ternarios y acumuladores (escenario cotidiano tipo hoja de gastos).

funcion minimo(entero u, entero v) retorna entero
    si u < v entonces
        retornar u
    fin_si
    retornar v
fin_funcion

funcion maximo(entero u, entero v) retorna entero
    si u > v entonces
        retornar u
    fin_si
    retornar v
fin_funcion

funcion fibonacci(entero n) retorna entero
    si n <= 1 entonces
        retornar n
    fin_si
    entero f1 = fibonacci(n - 1)
    entero f2 = fibonacci(n - 2)
    retornar f1 + f2
fin_funcion

funcion nombre_categoria(entero c) retorna texto
    si c == 1 entonces
        retornar "Alimentacion"
    fin_si
    si c == 2 entonces
        retornar "Servicios"
    fin_si
    si c == 3 entonces
        retornar "Ocio"
    fin_si
    retornar "Otros"
fin_funcion

principal
    macro cuadrado = (x) => x * x
    macro triple = (x) => x * 3
    macro mitad = (x) => x / 2
    macro abs_diff = (u, v) => u > v ? u - v : v - u
    macro base_gasto = (cat, sem, dia) => ((cat * 31 + sem * 7 + dia * 11) % 75) + 12
    macro con_iva = (base_iva) => base_iva + (base_iva * 21) / 100
    macro bonificar = (monto, pct) => monto - (monto * pct) / 100
    macro porcentaje = (parte, tot) => tot > 0 ? (parte * 100) / tot : 0
    macro ajuste_dia = (kk) => ((q) => q * 2 + 1)(kk)
    macro sumar = (u, v) => u + v

    macro clasificar_rango = (gasto, tope) => {
        si gasto > tope entonces
            retornar "alto"
        fin_si
        si gasto * 2 > tope entonces
            retornar "medio"
        fin_si
        retornar "bajo"
    }

    macro linea_mes = (sem, dia, texto cat_txt, bruto, neto, texto nivel) => {
        texto detalle = "${sem}" + "s" + "${dia}" + "d"
        retornar cat_txt + " " + detalle + " bruto=" + bruto + " neto=" + neto + " [" + nivel + "]"
    }

    imprimir "=== Presupuesto hogar (simulacion mensual) ==="
    imprimir "Fibonacci(10) referencia matematica: ${fibonacci(10)}"
    imprimir "Formula rapida IIFE: doble de 14 = ${((q) => q + q)(14)}"

    entero total_alim = 0
    entero total_serv = 0
    entero total_ocio = 0
    entero picos = 0
    entero tope_dia = 95

    entero cat = 1
    mientras cat <= 3 hacer
        entero sem = 1
        mientras sem <= 5 hacer
            entero dia = 1
            mientras dia <= 7 hacer
                entero bruto = base_gasto(cat, sem, dia)
                entero pct_desc = (sem + dia) % 12
                entero tras_desc = bonificar(bruto, pct_desc)
                entero neto = con_iva(tras_desc)
                entero extra = 0
                entero k = 0
                hacer
                    k++
                    extra += ajuste_dia(k)
                    si k % 2 == 0 entonces
                        continuar
                    fin_si
                    si k >= 3 entonces
                        romper
                    fin_si
                mientras k < 10 fin_hacer
                neto += mitad(extra)
                texto nivel = clasificar_rango(bruto, tope_dia)
                si nivel == "alto" entonces
                    picos++
                fin_si
                si cat == 1 entonces
                    total_alim += neto
                fin_si
                si cat == 2 entonces
                    total_serv += neto
                fin_si
                si cat == 3 entonces
                    total_ocio += neto
                fin_si
                si sem == 3 y dia == 4 entonces
                    texto nm = nombre_categoria(cat)
                    imprimir linea_mes(sem, dia, nm, bruto, neto, nivel)
                fin_si
                dia++
            fin_mientras
            sem++
        fin_mientras
        cat++
    fin_mientras

    entero gran_total = total_alim + total_serv + total_ocio
    entero ref_cuad = cuadrado(minimo(8, maximo(3, 5)))
    entero ref_tri = triple(4)

    imprimir "--- Totales por categoria (enteros, IVA aprox incluido) ---"
    imprimir "Alimentacion: ${total_alim}  (${porcentaje(total_alim, gran_total)}% del total)"
    imprimir "Servicios:    ${total_serv}  (${porcentaje(total_serv, gran_total)}% del total)"
    imprimir "Ocio:         ${total_ocio}  (${porcentaje(total_ocio, gran_total)}% del total)"
    imprimir "Gran total:   ${gran_total}"
    imprimir "Dias/picos sobre tope bruto: ${picos}  |  tope referencia: ${tope_dia}"
    imprimir "Checks: cuadrado(min/max)=${ref_cuad} triple(4)=${ref_tri} abs_diff(40,15)=${abs_diff(40, 15)}"
    imprimir "=== Fin simulacion ==="
fin_principal
