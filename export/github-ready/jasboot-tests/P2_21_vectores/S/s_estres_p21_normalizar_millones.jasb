# S: millones de vec3_normalizar sobre el mismo vector (3,4,0); resultado estable unitario.
#     Salida final: tres imprimir de componentes (~0.6, ~0.8, 0) segun float32. Ver S/NOTAS_S.md.

principal
    vec3 v
    vec3 n
    entero i

    v = vec3(3.0, 4.0, 0.0)
    i = 0
    mientras i < 1000000 hacer
        vec3_normalizar(n, v)
        i = i + 1
    fin_mientras
    imprimir n.x
    imprimir ""
    imprimir n.y
    imprimir ""
    imprimir n.z
    imprimir ""
fin_principal
