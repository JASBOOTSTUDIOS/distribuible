# R: mezcla lineal de colores RGBA — c = c0*w0 + c1*w1 con pesos 0.5 / 0.5.
#     Rojo + verde -> amarillo medio (0.5, 0.5, 0, 1).

principal
    vec4 rojo
    vec4 verde
    vec4 p0
    vec4 p1
    vec4 mezcla

    rojo = vec4(1.0, 0.0, 0.0, 1.0)
    verde = vec4(0.0, 1.0, 0.0, 1.0)
    p0 = rojo * 0.5
    p1 = verde * 0.5
    mezcla = p0 + p1
    imprimir mezcla.x
    imprimir mezcla.y
    imprimir mezcla.z
    imprimir mezcla.w
    imprimir ""
fin_principal
