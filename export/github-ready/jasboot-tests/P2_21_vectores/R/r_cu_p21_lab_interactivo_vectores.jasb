# R (interactivo): laboratorio de vec2/vec3/vec4 — menu por teclado (entrada_flotante).
#     Ejecutar: .\bin\jb.cmd tests\P2_21_vectores\R\r_cu_p21_lab_interactivo_vectores.jasb
#     Prueba: longitud+normalizar, dot+cross, distancia 2D, mezcla vec4, proyeccion vec3.
#     Opcion 0 = salir. Vector casi nulo: aviso sin normalizar.

principal
    entero seguir
    flotante menu
    vec3 va
    vec3 vb
    vec3 vc
    vec3 vtmp
    vec3 eje_u
    vec2 pa
    vec2 pb
    vec2 ab
    vec4 c0
    vec4 c1
    vec4 p0
    vec4 p1
    vec4 mezcla
    flotante len
    flotante d
    flotante w
    flotante uno_menos_w
    flotante t
    flotante fx
    flotante fy
    flotante fz

    seguir = 1
    imprimir "\n=== Laboratorio de vectores (P2-21) ===\n"
    imprimir "1  Longitud y normalizar (vec3, introduce x y z)\n"
    imprimir "2  Producto escalar y vectorial (dos vec3)\n"
    imprimir "3  Distancia en el plano (dos vec2)\n"
    imprimir "4  Mezcla lineal vec4 (rojo <-> azul, peso w)\n"
    imprimir "5  Proyeccion de vec3 sobre eje (vector u y eje)\n"
    imprimir "0  Salir\n"

    mientras seguir == 1 hacer
        imprimir "\n[1 len+norm vec3] [2 dot+cross] [3 dist 2D] [4 mezcla vec4] [5 proyeccion] [0 salir]\nOpcion: "
        menu = entrada_flotante()

        si menu == 0.0 entonces
            seguir = 0
            imprimir "Fin.\n"
        sino si menu == 1.0 entonces
            imprimir "Componentes del vector v (tres numeros, cada uno tras Enter):\n"
            imprimir "  x: "
            fx = entrada_flotante()
            imprimir "  y: "
            fy = entrada_flotante()
            imprimir "  z: "
            fz = entrada_flotante()
            va = vec3(fx, fy, fz)
            len = vec3_longitud(va)
            imprimir "  longitud = "
            imprimir_flotante(len)
            imprimir "\n"
            si len < 0.0000001 entonces
                imprimir "  (casi cero: no se normaliza)\n"
            sino
                vec3_normalizar(vtmp, va)
                imprimir "  normalizado: x="
                imprimir_flotante(vtmp.x)
                imprimir " y="
                imprimir_flotante(vtmp.y)
                imprimir " z="
                imprimir_flotante(vtmp.z)
                imprimir "\n"
            fin_si
        sino si menu == 2.0 entonces
            imprimir "Primer vec3 (x,y,z con Enter tras cada uno):\n"
            imprimir "  ax: "
            fx = entrada_flotante()
            imprimir "  ay: "
            fy = entrada_flotante()
            imprimir "  az: "
            fz = entrada_flotante()
            va = vec3(fx, fy, fz)
            imprimir "Segundo vec3:\n"
            imprimir "  bx: "
            fx = entrada_flotante()
            imprimir "  by: "
            fy = entrada_flotante()
            imprimir "  bz: "
            fz = entrada_flotante()
            vb = vec3(fx, fy, fz)
            d = vec3_dot(va, vb)
            imprimir "  vec3_dot = "
            imprimir_flotante(d)
            imprimir "\n"
            vec3_cross(vc, va, vb)
            imprimir "  vec3_cross (x,y,z): "
            imprimir_flotante(vc.x)
            imprimir " "
            imprimir_flotante(vc.y)
            imprimir " "
            imprimir_flotante(vc.z)
            imprimir "\n"
        sino si menu == 3.0 entonces
            imprimir "Punto A (x y):\n"
            imprimir "  ax: "
            fx = entrada_flotante()
            imprimir "  ay: "
            fy = entrada_flotante()
            pa = vec2(fx, fy)
            imprimir "Punto B:\n"
            imprimir "  bx: "
            fx = entrada_flotante()
            imprimir "  by: "
            fy = entrada_flotante()
            pb = vec2(fx, fy)
            ab = pb - pa
            len = vec2_longitud(ab)
            imprimir "  distancia ||B-A|| = "
            imprimir_flotante(len)
            imprimir "\n"
        sino si menu == 4.0 entonces
            c0 = vec4(1.0, 0.0, 0.0, 1.0)
            c1 = vec4(0.0, 0.0, 1.0, 1.0)
            imprimir "Peso w en [0,1] para mezclar rojo->azul: "
            w = entrada_flotante()
            uno_menos_w = 1.0 - w
            p0 = c0 * w
            p1 = c1 * uno_menos_w
            mezcla = p0 + p1
            imprimir "  RGBA mezcla: "
            imprimir_flotante(mezcla.x)
            imprimir " "
            imprimir_flotante(mezcla.y)
            imprimir " "
            imprimir_flotante(mezcla.z)
            imprimir " "
            imprimir_flotante(mezcla.w)
            imprimir "\n"
        sino si menu == 5.0 entonces
            imprimir "Vector u (x,y,z):\n"
            imprimir "  ux: "
            fx = entrada_flotante()
            imprimir "  uy: "
            fy = entrada_flotante()
            imprimir "  uz: "
            fz = entrada_flotante()
            va = vec3(fx, fy, fz)
            imprimir "Eje de proyeccion (se normaliza internamente):\n"
            imprimir "  ex: "
            fx = entrada_flotante()
            imprimir "  ey: "
            fy = entrada_flotante()
            imprimir "  ez: "
            fz = entrada_flotante()
            vb = vec3(fx, fy, fz)
            len = vec3_longitud(vb)
            si len < 0.0000001 entonces
                imprimir "  eje casi nulo: no hay proyeccion definida\n"
            sino
                vec3_normalizar(eje_u, vb)
                t = vec3_dot(va, eje_u)
                vc = eje_u * t
                imprimir "  proyeccion (x,y,z): "
                imprimir_flotante(vc.x)
                imprimir " "
                imprimir_flotante(vc.y)
                imprimir " "
                imprimir_flotante(vc.z)
                imprimir "\n"
            fin_si
        sino
            imprimir "Opcion no reconocida. Use 0..5.\n"
        fin_si
    fin_mientras
fin_principal
