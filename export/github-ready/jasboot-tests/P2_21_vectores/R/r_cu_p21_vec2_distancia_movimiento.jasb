# R: uso 2D — distancia entre puntos (||B-A||) y paso de Euler pos += v*dt.
#     Salidas (no vacias): 5; 1; -0.5. Lineas en blanco entre imprimir.

principal
    vec2 pa
    vec2 pb
    vec2 ab
    vec2 pos
    vec2 vel
    vec2 paso
    flotante dt

    pa = vec2(1.0, 2.0)
    pb = vec2(4.0, 6.0)
    ab = pb - pa
    imprimir vec2_longitud(ab)
    imprimir ""

    pos = vec2(0.0, 0.0)
    vel = vec2(10.0, -5.0)
    dt = 0.1
    paso = vel * dt
    pos = pos + paso
    imprimir pos.x
    imprimir pos.y
    imprimir ""
fin_principal
