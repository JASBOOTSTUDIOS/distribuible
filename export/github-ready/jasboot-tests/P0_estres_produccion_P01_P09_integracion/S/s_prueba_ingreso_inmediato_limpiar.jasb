principal
    limpiar_consola()
    imprimir "Prueba ingreso_inmediato: presiona una tecla (q para salir)"
    entero i = 0
    mientras i < 10 hacer
        texto tecla = ""
        ingreso_inmediato tecla
        si tecla != "" entonces
            imprimir "tecla=${tecla}"
        fin_si
        si tecla == "q" entonces
            romper
        fin_si
        i += 1
    fin_mientras
    imprimir "fin"
fin_principal
