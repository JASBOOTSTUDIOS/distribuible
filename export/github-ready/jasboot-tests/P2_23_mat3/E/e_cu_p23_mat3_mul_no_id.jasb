# E: mat3_mul exige tres mat3 identificador; miembro no vale.
# Esperado: jbc termina con codigo != 0 (error semantico: mizq.e1 no es identificador mat3).

principal
    mat3 mizq
    mat3 mder
    mat3 d
    mizq.e0 = 1.0
    mizq.e4 = 1.0
    mizq.e8 = 1.0
    mder.e0 = 1.0
    mder.e4 = 1.0
    mder.e8 = 1.0
    mat3_mul(d, mizq.e1, mder)
fin_principal
