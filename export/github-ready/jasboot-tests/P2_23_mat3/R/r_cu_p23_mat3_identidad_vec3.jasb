# R: mat3 identidad manual + mat3_mul_vec3 conserva el vector.
# Esperado (jb / stdout; cada imprimir "" es una linea vacia):
#   3.0000
#   <linea vacia>
#   4.0000
#   <linea vacia>
#   5.0000
#   <linea vacia>

principal
    mat3 m
    vec3 v
    vec3 sal

    m.e0 = 1.0
    m.e1 = 0.0
    m.e2 = 0.0
    m.e3 = 0.0
    m.e4 = 1.0
    m.e5 = 0.0
    m.e6 = 0.0
    m.e7 = 0.0
    m.e8 = 1.0
    v = vec3(3.0, 4.0, 5.0)
    mat3_mul_vec3(sal, m, v)
    imprimir sal.x
    imprimir ""
    imprimir sal.y
    imprimir ""
    imprimir sal.z
    imprimir ""
fin_principal
