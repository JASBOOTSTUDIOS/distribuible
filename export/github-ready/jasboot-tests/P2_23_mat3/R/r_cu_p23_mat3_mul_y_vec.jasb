# R: mat3_mul_vec3 con escala en X; mat3_mul(L, I) copia L (comprueba e1).
# Esperado (jb; entre cada numero y el siguiente hay imprimir ""):
#   2.0000  <vacio>  1.0000  <vacio>  0.0000  <vacio>  2.0000  <vacio>


principal
    mat3 s
    mat3 l
    mat3 r
    mat3 prod
    vec3 v
    vec3 sal

    s.e0 = 2.0
    s.e1 = 0.0
    s.e2 = 0.0
    s.e3 = 0.0
    s.e4 = 1.0
    s.e5 = 0.0
    s.e6 = 0.0
    s.e7 = 0.0
    s.e8 = 1.0
    v = vec3(1.0, 1.0, 0.0)
    mat3_mul_vec3(sal, s, v)
    imprimir sal.x
    imprimir ""
    imprimir sal.y
    imprimir ""
    imprimir sal.z
    imprimir ""

    l.e0 = 1.0
    l.e1 = 2.0
    l.e2 = 0.0
    l.e3 = 0.0
    l.e4 = 1.0
    l.e5 = 0.0
    l.e6 = 0.0
    l.e7 = 0.0
    l.e8 = 1.0
    r.e0 = 1.0
    r.e1 = 0.0
    r.e2 = 0.0
    r.e3 = 0.0
    r.e4 = 1.0
    r.e5 = 0.0
    r.e6 = 0.0
    r.e7 = 0.0
    r.e8 = 1.0
    mat3_mul(prod, l, r)
    imprimir prod.e1
    imprimir ""
fin_principal
