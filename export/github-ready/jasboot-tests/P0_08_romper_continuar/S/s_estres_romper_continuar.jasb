principal
    entero num_a = 0
    entero num_b = 0
    entero acum = 0
    mientras num_a < 40 hacer
        num_b = 0
        mientras num_b < 40 hacer
            num_b = num_b + 1
            si num_b % 17 == 0 entonces
                continuar
            fin_si
            si num_a + num_b > 2000 entonces
                romper
            fin_si
            acum = acum + 1
        fin_mientras
        si num_a > 18 entonces
            romper
        fin_si
        num_a = num_a + 1
    fin_mientras
    imprimir acum
fin_principal
