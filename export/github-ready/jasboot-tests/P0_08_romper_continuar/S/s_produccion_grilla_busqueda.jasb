# Produccion: grilla 2D con continuar en multiples y romper por presupuesto (tablas / escaneo).
principal
    entero acc = 0
    entero fila = 0
    mientras fila < 120 hacer
        entero col = 0
        mientras col < 120 hacer
            si col % 19 == 0 entonces
                col += 1
                continuar
            fin_si
            si fila * col > 8500 entonces
                romper
            fin_si
            acc = acc + (fila + col) % 37
            col += 1
        fin_mientras
        si fila > 95 entonces
            romper
        fin_si
        fila += 1
    fin_mientras
    imprimir acc
fin_principal
