principal
    entero num_x = 0
    entero num_y = 0
    entero cnt = 0
    mientras num_x < 3 hacer
        num_y = 0
        mientras num_y < 3 hacer
            num_y = num_y + 1
            si num_y == 2 entonces
                continuar
            fin_si
            cnt = cnt + 1
        fin_mientras
        num_x = num_x + 1
    fin_mientras
    imprimir cnt
fin_principal
