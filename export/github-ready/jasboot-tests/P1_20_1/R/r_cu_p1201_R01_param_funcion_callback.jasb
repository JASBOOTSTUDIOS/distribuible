# R: funcion de orden superior recibe `funcion f` y un `entero v`; aplica `f(v)`.
#     Paso de funcion global por nombre (`duplicar`). Salida esperada: 42

funcion duplicar(entero x) retorna entero
    retornar x * 2
fin_funcion

funcion aplicar_uno(funcion f, entero v) retorna entero
    retornar f(v)
fin_funcion

principal
    entero r
    r = aplicar_uno(duplicar, 21)
    imprimir r
fin_principal
