# R: orden superior aplica el mismo parametro-funcion dos veces seguidas (composicion manual).
#     Salida esperada: 7 (5+1+1)

funcion inc(entero x) retorna entero
    retornar x + 1
fin_funcion

funcion dos_veces(funcion f, entero v) retorna entero
    entero t
    t = f(v)
    retornar f(t)
fin_funcion

principal
    imprimir dos_veces(inc, 5)
fin_principal
