principal
    entero i = 0
    entero vacias = 0
    entero no_vacias = 0
    entero t_inicio = obtener_timestamp()
    mientras i < 15000 hacer
        limpiar_consola()
        texto tecla = ""
        ingreso_inmediato tecla

        si tecla == "" y diferencia_en_segundos(t_inicio, obtener_timestamp()) < 1 entonces
            vacias += 1
        sino
            no_vacias += 1
        fin_si
        i += 1
    fin_mientras
    imprimir "polling terminado"
    imprimir "vacias=${vacias} no_vacias=${no_vacias}"
fin_principal

