# S: estres sin/cos/exp en bucle (80k) con acumulador.
# Esperado (jb): 8.0766 y linea vacia (checksum float32; recalibrar si cambia la VM).

principal
    flotante kf
    flotante ang
    flotante suma

    suma = 0.0
    kf = 0.0
    mientras kf < 80000.0 hacer
        ang = kf * 0.01745329252
        suma = suma + sin(ang) * 0.001 + cos(ang) * 0.001 + exp(kf * 0.00000001) * 0.0001
        kf = kf + 1.0
    fin_mientras
    imprimir suma
    imprimir ""
fin_principal
