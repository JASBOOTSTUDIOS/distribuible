# S1 — Estres: 500 iteraciones sumando convertir_entero(str_desde_numero(idx)) (P0 bucles + texto + P1_16).
# Suma 0..499 = 124750. Salida: 124750

principal
    entero suma = 0
    entero idx = 0
    mientras idx < 500 hacer
        texto t = str_desde_numero(idx)
        suma = suma + convertir_entero(t)
        idx++
    fin_mientras
    imprimir(suma)
fin_principal
