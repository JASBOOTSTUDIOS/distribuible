# S2 — Estres: doble mientras 25x25; cada celda suma convertir_entero("1") => 625.
# Salida: 625

principal
    entero suma = 0
    entero i = 0
    mientras i < 25 hacer
        entero j = 0
        mientras j < 25 hacer
            suma = suma + convertir_entero("1")
            j++
        fin_mientras
        i++
    fin_mientras
    imprimir(suma)
fin_principal
