# S3 — Estres: 300 veces sumar convertir_flotante("0.25") (flotante + P1_16).
# 300 * 0.25 = 75. Salida: 75.00

principal
    flotante acc = 0.0
    entero k = 0
    mientras k < 300 hacer
        acc = acc + convertir_flotante("0.25")
        k++
    fin_mientras
    imprimir(decimal(acc, 2))
fin_principal
