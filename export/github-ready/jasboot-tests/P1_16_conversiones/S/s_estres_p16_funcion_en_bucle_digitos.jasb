# S4 — Estres: funcion + modulo + str_desde_numero + convertir; 400 iteraciones.
# sum_{i=0}^{399} (i % 10) = 40 * (0+..+9) = 40*45 = 1800. Salida: 1800

funcion digito(entero k) retorna entero
    retornar convertir_entero(str_desde_numero(k % 10))
fin_funcion

principal
    entero suma = 0
    entero q = 0
    mientras q < 400 hacer
        suma = suma + digito(q)
        q++
    fin_mientras
    imprimir(suma)
fin_principal
