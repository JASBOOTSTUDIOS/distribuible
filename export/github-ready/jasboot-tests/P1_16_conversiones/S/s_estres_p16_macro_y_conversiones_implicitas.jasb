# S5 — Estres: macro flecha (P1_12) + convertir_entero en argumento; 150 iteraciones.
# dup(x)=x+x con x=convertir_entero("3") => 6 por vuelta => 900. Salida: 900

principal
    macro dup = (x) => x + x
    entero suma = 0
    entero q = 0
    mientras q < 150 hacer
        suma = suma + dup(convertir_entero("3"))
        q++
    fin_mientras
    imprimir(suma)
fin_principal
