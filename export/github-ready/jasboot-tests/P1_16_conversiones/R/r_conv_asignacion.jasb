# Conversiones en asignacion = (no solo en declaracion inicial).
# na = fx+2.5 (F2I -> 5); luego fx = na con na entero 4 (I2F -> 4.0).
# Salida: 5  y  4.0000

principal
    flotante fx = 2.75
    entero na = 0
    na = fx + 2.5
    imprimir na
    na = 4
    fx = na
    imprimir(decimal(fx, 4))
fin_principal
