# 7 — mientras: sumar convertir_entero(str_desde_numero(idx)) para idx 0..19 (bucles P0).
# Suma 0+1+...+19 = 190. Salida: 190

principal
    entero suma = 0
    entero idx = 0
    mientras idx < 20 hacer
        texto t = str_desde_numero(idx)
        suma = suma + convertir_entero(t)
        idx++
    fin_mientras
    imprimir(suma)
fin_principal
