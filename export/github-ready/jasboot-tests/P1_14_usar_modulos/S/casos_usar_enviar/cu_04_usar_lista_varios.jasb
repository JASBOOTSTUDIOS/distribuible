// Caso: `usar { a, b, c } de` — lista nominal: funcion + constante + macro en un solo `usar`.
// checksum = exp_fn(0) + EXP_C + exp_mac(0) = 42 + 42 + 1 = 85
// Esperado: 85

usar { exp_fn, EXP_C, exp_mac } de "m_export_mix.jasb"

principal
    entero checksum = llamar exp_fn(0) + EXP_C + exp_mac(0)
    imprimir "${checksum}\n"
fin_principal
