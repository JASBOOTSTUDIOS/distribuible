// Caso: dos directivas `usar { ... } de` a *distintos* modulos (cada archivo se carga una vez).
// El mismo modulo cargado dos veces no vuelve a fusionar nombres nuevos en la segunda linea.
// SIDE_A + SIDE_B = 10 + 32 = 42
// Esperado: 42

usar { SIDE_A } de "m_side_a.jasb"
usar { SIDE_B } de "m_side_b.jasb"

principal
    entero r = SIDE_A + SIDE_B
    imprimir "${r}\n"
fin_principal
