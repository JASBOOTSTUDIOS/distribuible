// Biblioteca de demostracion: mezcla de simbolos con `enviar` y sin el.
// - Exportados: EXP_C, exp_fn, exp_mac
// - Internos: PRIV_C, priv_fn (no deben aparecer en `usar { ... }` ni en el arbol fusionado con lista).
// Nota: el cuerpo de exp_fn usa el literal 42 (igual que EXP_C) para que `usar { exp_fn }` solo
//   funcione sin exigir que EXP_C este fusionada en el programa que importa.

enviar constante entero EXP_C = 42

constante entero PRIV_C = 1

enviar funcion exp_fn(entero k) retorna entero
    retornar k + 42
fin_funcion

funcion priv_fn(entero k) retorna entero
    retornar k + PRIV_C
fin_funcion

enviar macro exp_mac = (t) => t + 1
