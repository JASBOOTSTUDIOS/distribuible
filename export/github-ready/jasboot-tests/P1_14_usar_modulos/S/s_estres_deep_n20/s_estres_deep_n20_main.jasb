// Estres P1_14: app tipo produccion con 20 carpetas anidadas (nest/01/02/.../20).
// Cada nivel exporta constante DEEP_Lxx_K y funcion deep_svc_xx que delega en la capa inferior.
// Referencia: desde esta carpeta, `jbc s_estres_deep_n20_main.jasb -e` debe imprimir cadena=310 sumK=210.

usar todas de "nest/01/mod.jasb"

principal
    entero cadena = llamar deep_svc_01(5)
    entero t01 = DEEP_L01_K
    entero t03 = DEEP_L03_K
    entero t20 = DEEP_L20_K
    imprimir "deep_n20 cadena=${cadena} t01=${t01} t03=${t03} t20=${t20}\n"
fin_principal
