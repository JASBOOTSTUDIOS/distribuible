# E (ejecucion): texto no entero en `str_a_entero` — compila; sin `intentar`, la VM aborta (codigo != 0).
# stderr debe mencionar "str_a_entero" y "no es un entero decimal valido"; no debe imprimirse no_deberia.
# Entrada stdin: gg\n

principal
    ingresar_texto buf
    entero n = str_a_entero(buf)
    imprimir n
    imprimir "no_deberia"
fin_principal
