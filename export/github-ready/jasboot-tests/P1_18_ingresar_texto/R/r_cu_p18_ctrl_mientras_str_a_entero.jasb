# R: leer entero desde texto y `mientras` por contador.
# Entrada: 3\n
# Salida: 1, 2, 3, 9 y linea vacia.

principal
    ingresar_texto buf
    entero lim = str_a_entero(buf)
    entero k = 1
    mientras k <= lim hacer
        imprimir k
        k += 1
    fin_mientras
    imprimir 9
    imprimir ""
fin_principal
