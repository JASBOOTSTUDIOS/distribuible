# R: linea solo numerica sigue siendo texto: comparacion con literal "0".
# Entrada: 0\n
# Salida: 88 y linea vacia (regresion VM: no guardar entero 0 en variable texto).

principal
    ingresar_texto dig
    si dig == "0" entonces
        imprimir 88
    sino
        imprimir 77
    fin_si
    imprimir ""
fin_principal
