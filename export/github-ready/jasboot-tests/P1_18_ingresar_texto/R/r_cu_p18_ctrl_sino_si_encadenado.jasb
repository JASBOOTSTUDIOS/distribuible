# R: cadena `si` / `sino si` / `sino` con entrada de texto.
# Entrada: b\n
# Salida: 20 y linea vacia.

principal
    ingresar_texto tag
    si tag == "a" entonces
        imprimir 10
    sino si tag == "b" entonces
        imprimir 20
    sino si tag == "c" entonces
        imprimir 30
    sino
        imprimir 99
    fin_si
    imprimir ""
fin_principal
