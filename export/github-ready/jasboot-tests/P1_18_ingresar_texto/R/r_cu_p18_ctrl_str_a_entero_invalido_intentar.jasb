# R: `str_a_entero` con texto no numerico dispara error capturable con `intentar`/`atrapar`.
# Entrada: gg\n
# Salida: ok, linea vacia, texto de error (contiene "str_a_entero" y "no es un entero"), linea vacia, fin, linea vacia.

principal
    ingresar_texto buf
    intentar
        entero n = str_a_entero(buf)
        imprimir n
        imprimir "no_deberia"
    atrapar err
        imprimir "ok"
        imprimir ""
        imprimir "\rojo${err} \norm"
        imprimir ""
        imprimir "fin"
        imprimir ""
    fin_intentar
fin_principal
