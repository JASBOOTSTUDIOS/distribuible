# R: segunda lectura sobrescribe variable; condicion usa ultimo valor.
# Entrada: uno\ndos\n
# Salida: 2 (ultimo == "dos") y linea vacia.

principal
    texto w = "go"
    mientras w no es igual a "FIN" hacer
        ingresar_texto w
        si w == "uno" entonces
            ingresar_texto w
            si w == "dos" entonces
                imprimir 2
            sino
                imprimir 0
            fin_si
            romper
        fin_si
    fin_mientras
    imprimir ""
fin_principal
