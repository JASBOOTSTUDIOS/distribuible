# R: registro anidado; volcado muestra campos. texto/caracter sin asignar (handle/codigo 0) -> "indefinido".

registro Cordenadas
    flotante cord_y
    flotante cord_x
fin_registro

registro Punto
    Cordenadas cordenadas
    flotante radio
    texto color
fin_registro

principal

    Punto p
    p.cordenadas.cord_y = 3.90
    p.cordenadas.cord_x = 2.0
    p.radio = 1.5
    imprimir p.cordenadas.cord_y
    imprimir p.radio
    imprimir "\n${p}\n"

fin_principal
