# R: traslacion homogenea en columna 3 (e3, e7, e11) + mat4_mul_vec4.
#     I con T.e3=2, T.e7=1 y v=(1,0,0,1) -> (3,1,0,1).
# Esperado (jb): 3.0000  1.0000  0.0000  1.0000  (cada uno seguido de linea vacia por imprimir "").

principal
    mat4 t
    vec4 v
    vec4 sal

    mat4_identidad(t)
    t.e3 = 2.0
    t.e7 = 1.0
    v = vec4(1.0, 0.0, 0.0, 1.0)
    mat4_mul_vec4(sal, t, v)
    imprimir sal.x
    imprimir ""
    imprimir sal.y
    imprimir ""
    imprimir sal.z
    imprimir ""
    imprimir sal.w
    imprimir ""
fin_principal
