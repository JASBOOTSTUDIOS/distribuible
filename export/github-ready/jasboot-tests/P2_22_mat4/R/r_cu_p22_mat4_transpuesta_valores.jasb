# R: mat4_transpuesta con matriz no diagonal (e1 y e4 distintos de cero).
#     M.e1=7, M.e4=3 -> T.e1=3, T.e4=7 (intercambio fila0col1 <-> fila1col0).
# Esperado (jb): 3.0000  <vacio>  7.0000  <vacio>

principal
    mat4 m
    mat4 t

    mat4_identidad(m)
    m.e1 = 7.0
    m.e4 = 3.0
    mat4_transpuesta(t, m)
    imprimir t.e1
    imprimir ""
    imprimir t.e4
    imprimir ""
fin_principal
