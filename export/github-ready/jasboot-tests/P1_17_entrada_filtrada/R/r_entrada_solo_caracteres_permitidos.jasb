# Lee por teclado caracter a caracter; solo se acumulan los que aparecen en la cadena
# que el usuario indica al inicio. Enter finaliza y se muestra el texto acumulado.

principal
    imprimir "Escriba los caracteres permitidos y pulse Enter (ej: 0123456789 o abc):\n"
    texto permitidos = leer_entrada()
    texto acumulado = ""
    imprimir "Ahora escriba; las demas teclas se ignoran. Enter para terminar.\n"
    entero terminado = 0
    mientras terminado == 0 hacer
        texto tecla = percibir_teclado()
        si longitud(tecla) == 0 entonces
            continuar
        fin_si
        entero c = codigo_caracter(tecla)
        si c == 13 o c == 10 entonces
            terminado = 1
        sino si contiene_texto(permitidos, tecla) entonces
            acumulado = concatenar(acumulado, tecla)
            imprimir_sin_salto(tecla)
        fin_si
    fin_mientras
    imprimir "\n--- Texto aceptado ---\n"
    imprimir acumulado
    imprimir "\n"
fin_principal
