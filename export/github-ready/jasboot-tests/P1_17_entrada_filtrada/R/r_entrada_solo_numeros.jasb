    # Solo digitos 0-9; Retroceso borra el ultimo. Enter termina.

principal
    texto digitos = "0123456789"
    texto acumulado = ""
    imprimir "Escriba solo numeros (Retroceso borra). Enter para terminar.\n"
    entero terminado = 0
    mientras terminado == 0 hacer
        texto tecla = percibir_teclado()
        si longitud(tecla) == 0 entonces
            continuar
        fin_si
        entero c = codigo_caracter(tecla)
        si c == 13 o c == 10 entonces
            terminado = 1
        sino si c == 8 entonces
            entero n = longitud(acumulado)
            si n > 0 entonces
                acumulado = extraer_subtexto(acumulado, 0, n - 1)
                # imprimir_sin_salto "\b \b"
                limpiar_consola
                imprimir "Escriba solo numeros (Retroceso borra). Enter para terminar.\n"
                imprimir_sin_salto(acumulado)
            fin_si
        sino si contiene_texto(digitos, tecla) entonces
            acumulado = concatenar(acumulado, tecla)
            limpiar_consola
            imprimir "Escriba solo numeros (Retroceso borra). Enter para terminar.\n"
            imprimir_sin_salto(acumulado)
        fin_si
    fin_mientras
    imprimir "\n--- Numero capturado ---\n"
    imprimir acumulado
    imprimir "\n"
fin_principal
