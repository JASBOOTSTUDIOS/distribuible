# S (01): 30 000 claves consecutivas; valor = clave; suma de mapa_obtener(m,i) para i en 0..29999.
#   Suma = 0+1+...+29999 = 29999*30000/2 = 449985000.
#
# Salida esperada, linea a linea:
#   1) 449985000
#   2) linea vacia

principal
    mapa m = mapa_crear()
    entero i = 0
    mientras i < 30000 hacer
        mapa_poner(m, i, i)
        i += 1
    fin_mientras
    entero s = 0
    entero j = 0
    mientras j < 30000 hacer
        s += mapa_obtener(m, j)
        j += 1
    fin_mientras
    imprimir s
    imprimir ""
fin_principal
