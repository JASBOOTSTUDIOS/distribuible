# R (02): indexacion m[clave] equivale a mapa_obtener (NODE_INDEX_ACCESS + tipo mapa).
#
# Salida esperada, linea a linea:
#   1) 7
#   2) linea vacia
#   3) 7 — misma lectura con mapa_obtener
#   4) linea vacia

principal
    mapa m = mapa_crear()
    mapa_poner(m, 5, 7)
    imprimir m[5]
    imprimir ""
    imprimir mapa_obtener(m, 5)
    imprimir ""
fin_principal
