principal
    entero num_a = 11
    entero b
    // b = 10

    si b esta vacia entonces
        imprimir "b no esta vacia"
    sino
        imprimir "b esta vacia"
    fin_si

    si num_a es mayor que b entonces 
        imprimir "num_a es mayor que b" 

    sino si num_a es menor o igual a b o num_a es igual a b entonces 
        imprimir "num_a es menor que b <=" 

    sino si num_a es igual a b entonces  
        imprimir "num_a es igual a b" 

    fin_si 

    si num_a es diferente a b o num_a es igual a 11 entonces
        imprimir "num_a es diferente a b"
    sino
        imprimir "num_a es igual a b"
    fin_si

    si num_a no es mayor que b entonces
        imprimir "num_a no es mayor que b"

    sino si num_a no es menor o igual a b o num_a no es igual a b entonces
        imprimir "num_a no es menor o igual a b o num_a no es igual a b"

    sino
        imprimir "num_a es menor o igual a b o num_a es igual a b"

    fin_si

    imprimir "Fin"
fin_principal