# S: en cada iteracion se crea una lista nueva (handle local) y se pierde al siguiente giro;
#     estresa tabla/hash de listas en JMN y el bucle (PC saltando al condicion).
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 1200 — mem_lista_tamano(principal_lista)
#   2) línea vacía
#   3) 0 — mem_lista_obtener(principal_lista, 0)
#   4) línea vacía
#   5) 1199 — mem_lista_obtener(principal_lista, 1199)
#   6) línea vacía

principal
    lista principal_lista = crear_lista()
    entero i = 0
    mientras i < 1200 hacer
        lista huerfana = crear_lista()
        mem_lista_agregar(huerfana, i)
        mem_lista_agregar(principal_lista, i)
        i += 1
    fin_mientras
    imprimir mem_lista_tamano(principal_lista)
    imprimir ""
    imprimir mem_lista_obtener(principal_lista, 0)
    imprimir ""
    imprimir mem_lista_obtener(principal_lista, 1199)
    imprimir ""
fin_principal
