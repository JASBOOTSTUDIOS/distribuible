# R (03): dos variables lista comparten id (asignacion); mutar por una, leer por la otra.
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 2 — lista_tamano(prim)
#   2) línea vacía
#   3) 200 — lista_obtener(sec, 1)
#   4) línea vacía

principal
    lista prim = crear_lista()
    lista sec = prim
    lista_agregar(sec, 100)
    lista_agregar(prim, 200)
    imprimir lista_tamano(prim)
    imprimir ""
    imprimir lista_obtener(sec, 1)
    imprimir ""
fin_principal
