# R (09): segundo argumento de mem_lista_agregar puede ser una llamada (lista en temporal antes del valor).
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 2 — mem_lista_tamano(x) tras dos agregar (0 y tamano previo = 1)
#   2) línea vacía
#   3) 1 — mem_lista_obtener(x, 1)
#   4) línea vacía

principal
    lista x = crear_lista()
    mem_lista_agregar(x, 0)
    mem_lista_agregar(x, mem_lista_tamano(x))
    imprimir mem_lista_tamano(x)
    imprimir ""
    imprimir mem_lista_obtener(x, 1)
    imprimir ""
fin_principal
