# R (11): `lista_filtrar` y `lista_mapear` con funciones globales (Fase C).
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 2 — tamano tras filtrar no ceros (5 y 7)
#   2) 10 — doble del primer elemento
#   3) 14 — doble del segundo
#   4) línea vacía

funcion id_val(entero x) retorna entero
    retornar x
fin_funcion

funcion doble(entero x) retorna entero
    retornar x * 2
fin_funcion

principal
    lista L = crear_lista()
    mem_lista_agregar(L, 0)
    mem_lista_agregar(L, 5)
    mem_lista_agregar(L, 0)
    mem_lista_agregar(L, 7)
    lista F = lista_filtrar(L, id_val)
    imprimir mem_lista_tamano(F)
    lista M = lista_mapear(F, doble)
    imprimir mem_lista_obtener(M, 0)
    imprimir mem_lista_obtener(M, 1)
    imprimir ""
fin_principal
