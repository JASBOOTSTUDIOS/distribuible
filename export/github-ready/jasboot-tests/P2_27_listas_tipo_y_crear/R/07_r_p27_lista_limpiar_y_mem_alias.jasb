# R (07): lista_limpiar y mem_lista_limpiar vacian elementos (tamano 0); mismo handle.
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 2 — mem_lista_tamano tras dos agregar
#   2) línea vacía
#   3) 0 — mem_lista_tamano tras lista_limpiar
#   4) línea vacía
#   5) 7 — mem_lista_obtener tras nuevo agregar
#   6) línea vacía
#   7) 0 — mem_lista_tamano tras mem_lista_limpiar
#   8) línea vacía

principal
    lista buf = crear_lista()
    mem_lista_agregar(buf, 1)
    mem_lista_agregar(buf, 2)
    imprimir mem_lista_tamano(buf)
    imprimir ""
    lista_limpiar(buf)
    imprimir mem_lista_tamano(buf)
    imprimir ""
    mem_lista_agregar(buf, 7)
    imprimir mem_lista_obtener(buf, 0)
    imprimir ""
    mem_lista_limpiar(buf)
    imprimir mem_lista_tamano(buf)
    imprimir ""
fin_principal
