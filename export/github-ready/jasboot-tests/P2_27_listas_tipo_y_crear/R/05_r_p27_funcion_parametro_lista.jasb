# R (05): funcion con parametro tipo lista (paso por handle).
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 42 — p27_sumar_tam_y_cabeza(buf) = tamano(2) + obtener(..., 0) = 2 + 40
#   2) línea vacía

funcion p27_sumar_tam_y_cabeza(lista datos) retorna entero
    entero t = lista_tamano(datos)
    si t == 0 entonces
        retornar 0
    fin_si
    retornar t + lista_obtener(datos, 0)
fin_funcion

principal
    lista buf = crear_lista()
    lista_agregar(buf, 40)
    lista_agregar(buf, 50)
    imprimir p27_sumar_tam_y_cabeza(buf)
    imprimir ""
fin_principal
