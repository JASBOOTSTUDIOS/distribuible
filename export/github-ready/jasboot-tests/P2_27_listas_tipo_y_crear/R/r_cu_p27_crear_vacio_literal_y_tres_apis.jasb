# R: tipo lista, [] vacio, crear_lista / mem_lista_crear / lista_crear; tamano y obtener.
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 0 — mem_lista_tamano(vacia)
#   2) línea vacía
#   3) 1 — mem_lista_tamano(lista_a)
#   4) línea vacía
#   5) 1 — mem_lista_tamano(lista_b)
#   6) línea vacía
#   7) 1 — mem_lista_tamano(lista_c)
#   8) línea vacía
#   9) 40 — mem_lista_obtener(lista_a, 0)
#  10) línea vacía
#  11) 50 — mem_lista_obtener(lista_b, 0)
#  12) línea vacía
#  13) 60 — mem_lista_obtener(lista_c, 0)
#  14) línea vacía

principal
    lista vacia = []
    lista lista_a = crear_lista()
    lista lista_b = mem_lista_crear()
    lista lista_c = lista_crear()
    mem_lista_agregar(lista_a, 40)
    mem_lista_agregar(lista_b, 50)
    mem_lista_agregar(lista_c, 60)
    imprimir mem_lista_tamano(vacia)
    imprimir ""
    imprimir mem_lista_tamano(lista_a)
    imprimir ""
    imprimir mem_lista_tamano(lista_b)
    imprimir ""
    imprimir mem_lista_tamano(lista_c)
    imprimir ""
    imprimir mem_lista_obtener(lista_a, 0)
    imprimir ""
    imprimir mem_lista_obtener(lista_b, 0)
    imprimir ""
    imprimir mem_lista_obtener(lista_c, 0)
    imprimir ""
fin_principal
