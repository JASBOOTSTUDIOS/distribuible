# R (04): indexacion buf[indice] -> OP_MEM_LISTA_OBTENER (equivalente a lista_obtener).
#
# Salida esperada en consola (jasboot-ir-vm tras `jbc`), línea a línea:
#   1) 11 — buf[0]
#   2) línea vacía
#   3) 22 — buf[idx]
#   4) línea vacía
#   5) 2 — buf.tamano
#   6) línea vacía

principal
    lista buf = crear_lista()
    mem_lista_agregar(buf, 11)
    mem_lista_agregar(buf, 22)
    entero idx = 1
    imprimir buf[0]
    imprimir ""
    imprimir buf[idx]
    imprimir ""
    imprimir buf.tamano
    imprimir ""
fin_principal
