# Módulo de Test 2 - Para reproducir bug de scope
clase TestModulo2
    funcion funcionA() retorna entero
        entero c = 20
        entero resultado_calc = c + 5
        retornar resultado_calc
    fin_funcion

    funcion funcionB() retorna entero
        entero c = 15
        retornar c * 2
    fin_funcion

    funcion funcionC() retorna entero
        entero c = 100
        retornar c
    fin_funcion
fin_clase

enviar { TestModulo2 }
