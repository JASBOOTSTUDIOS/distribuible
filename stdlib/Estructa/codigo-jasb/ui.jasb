fin_funcion

enviar funcion estructura_columna_visual(texto espacio, texto alineacion, texto hijos) retorna texto
    texto estilo = ""
    si longitud_texto(espacio) > 0 entonces
        estilo = concatenar(estilo, "gap:")
        estilo = concatenar(estilo, estructura_escapar(espacio))
        estilo = concatenar(estilo, ";")
    fin_si
    si longitud_texto(alineacion) > 0 entonces
        estilo = concatenar(estilo, "align-items:")
        estilo = concatenar(estilo, estructura_escapar(alineacion))
        estilo = concatenar(estilo, ";")
    fin_si

    texto html = "<section class=\"es-columna\""
    si longitud_texto(estilo) > 0 entonces
        html = concatenar(html, " style=\"")
        html = concatenar(html, estilo)
        html = concatenar(html, "\"")
    fin_si
    html = concatenar(html, ">")
    html = concatenar(html, hijos)
    html = concatenar(html, "</section>")
    retornar html
fin_funcion

enviar funcion estructura_fila(texto hijos) retorna texto
    retornar concatenar("<section class=\"es-fila\" style=\"display:flex;flex-wrap:wrap;gap:16px\">", concatenar(hijos, "</section>"))
fin_funcion

enviar funcion estructura_fila_visual(texto espacio, texto alineacion, texto hijos) retorna texto
    texto estilo = "display:flex;flex-wrap:wrap;"
    si longitud_texto(espacio) > 0 entonces
        estilo = concatenar(estilo, "gap:")
        estilo = concatenar(estilo, estructura_escapar(espacio))
        estilo = concatenar(estilo, ";")
    sino
        estilo = concatenar(estilo, "gap:16px;")
    fin_si
    si longitud_texto(alineacion) > 0 entonces
        estilo = concatenar(estilo, "align-items:")
        estilo = concatenar(estilo, estructura_escapar(alineacion))
        estilo = concatenar(estilo, ";")
    fin_si
    texto html = "<section class=\"es-fila\" style=\""
    html = concatenar(html, estilo)
    html = concatenar(html, "\">")
    html = concatenar(html, hijos)
    html = concatenar(html, "</section>")
    retornar html
fin_funcion

enviar funcion estructura_tarjeta(texto titulo, texto hijos) retorna texto
    texto html = "<article>"
    si longitud_texto(titulo) > 0 entonces
        html = concatenar(html, "<h3>")
        html = concatenar(html, estructura_escapar(titulo))
        html = concatenar(html, "</h3>")
    fin_si
    html = concatenar(html, hijos)
    html = concatenar(html, "</article>")
    retornar html
fin_funcion

enviar funcion estructura_tarjeta_visual(texto titulo, texto variante, texto hijos) retorna texto
    texto html = "<article"
    si longitud_texto(variante) > 0 entonces
        si variante == "primaria" entonces
            html = concatenar(html, " style=\"background:#eff6ff;border-color:#bfdbfe\"")
        fin_si
        si variante == "oscura" entonces
            html = concatenar(html, " style=\"background:#0f172a;color:#f8fafc;border-color:#1e293b\"")
        fin_si
    fin_si
    html = concatenar(html, ">")
    si longitud_texto(titulo) > 0 entonces
        html = concatenar(html, "<h3>")
        html = concatenar(html, estructura_escapar(titulo))
        html = concatenar(html, "</h3>")
    fin_si
    html = concatenar(html, hijos)
    html = concatenar(html, "</article>")
    retornar html
fin_funcion

enviar funcion estructura_tema(texto color_primario, texto color_secundario, texto color_fondo, texto color_texto, texto radio_base, texto espacio_base) retorna texto
    texto css = ":root{"
    css = concatenar(css, "--es-color-primario:")
    css = concatenar(css, color_primario)
    css = concatenar(css, ";--es-color-secundario:")
    css = concatenar(css, color_secundario)
    css = concatenar(css, ";--es-color-fondo:")
    css = concatenar(css, color_fondo)
    css = concatenar(css, ";--es-color-superficie:#ffffff;--es-color-texto:")
    css = concatenar(css, color_texto)
    css = concatenar(css, ";--es-color-borde:#dbe4f0;--es-radio:")
    css = concatenar(css, radio_base)
    css = concatenar(css, ";--es-espacio:")
    css = concatenar(css, espacio_base)
    css = concatenar(css, ";}")
    retornar css
fin_funcion

