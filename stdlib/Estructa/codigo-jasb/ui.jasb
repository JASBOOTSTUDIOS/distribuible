usar todas de "..\\..\\api\\api_basica.jasb"
usar todas de ".\\identidad.jasb"

enviar funcion estructura_escapar(texto contenido) retorna texto
    entero i = 0
    texto salida = ""
    mientras i < longitud_texto(contenido) hacer
        texto parte = extraer_subtexto(contenido, i, 1)
        texto reemplazo = parte
        si parte == "&" entonces
            reemplazo = "&amp;"
        fin_si
        si parte == "<" entonces
            reemplazo = "&lt;"
        fin_si
        si parte == ">" entonces
            reemplazo = "&gt;"
        fin_si
        si parte == `"` entonces
            reemplazo = "&quot;"
        fin_si
        si parte == "'" entonces
            reemplazo = "&#39;"
        fin_si
        salida = concatenar(salida, reemplazo)
        i = i + 1
    fin_mientras
    retornar salida
fin_funcion

// Escape explicito para atributos HTML. Mantiene el mismo contrato seguro por defecto.
enviar funcion estructura_escapar_atributo(texto contenido) retorna texto
    retornar estructura_escapar(contenido)
fin_funcion

enviar funcion estructura_texto_seguro(texto contenido, texto por_defecto) retorna texto
    si longitud_texto(contenido) == 0 entonces
        retornar por_defecto
    fin_si
    retornar contenido
fin_funcion

enviar funcion estructura_id_seguro(texto entrada_id, texto por_defecto) retorna texto
    texto id = estructura_texto_seguro(entrada_id, por_defecto)
    entero i = 0
    texto salida = ""
    mientras i < longitud_texto(id) hacer
        texto c = extraer_subtexto(id, i, 1)
        si contiene_texto("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_", c) entonces
            salida = concatenar(salida, c)
        fin_si
        i = i + 1
    fin_mientras
    si longitud_texto(salida) == 0 entonces
        retornar por_defecto
    fin_si
    retornar salida
fin_funcion

enviar funcion estructura_ruta_segura(texto ruta) retorna texto
    texto base = estructura_texto_seguro(ruta, "/")
    si longitud_texto(base) == 0 entonces
        retornar "/"
    fin_si
    si extraer_subtexto(base, 0, 1) != "/" entonces
        retornar "/"
    fin_si
    retornar base
fin_funcion

enviar funcion estructura_mensaje_accion_seguro(texto mensaje) retorna texto
    texto limpio = estructura_texto_seguro(mensaje, "")
    si longitud_texto(limpio) > 240 entonces
        retornar extraer_subtexto(limpio, 0, 240)
    fin_si
    retornar limpio
fin_funcion

// Punto de escape manual e intencional. Solo usar cuando el programador acepta el riesgo.
enviar funcion estructura_html_crudo_inseguro(texto html) retorna texto
    retornar html
fin_funcion

enviar funcion estructura_estilos_base() retorna texto
    texto css = ":root{--es-color-primario:#2563eb;--es-color-secundario:#0f172a;--es-color-fondo:#f8fafc;--es-color-superficie:#ffffff;--es-color-texto:#0f172a;--es-color-borde:#dbe4f0;--es-radio:16px;--es-espacio:16px;--es-sombra:0 18px 45px rgba(15,23,42,.08)}"
    css = concatenar(css, "body{margin:0;background:var(--es-color-fondo);color:var(--es-color-texto);font:16px Segoe UI,Arial,sans-serif}")
    css = concatenar(css, ".es-shell{max-width:1120px;margin:0 auto;padding:32px 20px 48px 20px}")
    css = concatenar(css, ".es-nav{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:24px;padding:18px 20px;background:var(--es-color-superficie);border:1px solid var(--es-color-borde);border-radius:var(--es-radio);box-shadow:var(--es-sombra)}")
    css = concatenar(css, ".es-marca{font-size:20px;font-weight:700;color:var(--es-color-secundario)}")
    css = concatenar(css, ".es-nav-links{display:flex;flex-wrap:wrap;gap:10px}")
    css = concatenar(css, ".es-nav-links a,.fui-boton,.fui-submit{display:inline-flex;align-items:center;justify-content:center;padding:10px 14px;border-radius:12px;border:1px solid transparent;text-decoration:none;font-weight:600;transition:all .2s ease}")
    css = concatenar(css, ".es-nav-links a,.fui-boton,.fui-submit{background:var(--es-color-primario);color:#fff}")
    css = concatenar(css, ".es-nav-links a:hover,.fui-boton:hover,.fui-submit:hover{filter:brightness(.96);transform:translateY(-1px)}")
    css = concatenar(css, ".fui-boton-sec{background:transparent;color:var(--es-color-secundario);border-color:var(--es-color-borde)}")
    css = concatenar(css, ".fui-boton-sec:hover{background:#eef4ff}")
    css = concatenar(css, ".es-contenido{display:block}")
    css = concatenar(css, "section{display:grid;gap:16px}")
    css = concatenar(css, "article{background:var(--es-color-superficie);border:1px solid var(--es-color-borde);border-radius:var(--es-radio);padding:20px;box-shadow:var(--es-sombra)}")
    css = concatenar(css, "h1,h2,h3,p{margin:0}h1,h2,h3{color:var(--es-color-secundario)}p{line-height:1.6}")
    css = concatenar(css, ".fui-campo{display:grid;gap:8px}.fui-etiqueta-campo{font-weight:600;color:var(--es-color-secundario)}")
    css = concatenar(css, ".fui-entrada{width:100%;box-sizing:border-box;padding:12px 14px;border-radius:12px;border:1px solid var(--es-color-borde);background:#fff}")
    css = concatenar(css, "hr{border:none;border-top:1px solid var(--es-color-borde);margin:8px 0}")
    css = concatenar(css, "[hidden]{display:none!important}")
    retornar css
fin_funcion

