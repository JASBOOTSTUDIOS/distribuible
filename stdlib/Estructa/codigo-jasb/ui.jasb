enviar funcion estructura_enlace_ruta(texto ruta, texto etiqueta) retorna texto
    texto ruta_segura = estructura_escapar_atributo(estructura_ruta_segura(ruta))
    texto texto_enlace = estructura_escapar(etiqueta)
    texto html = "<a data-estructa-ruta=\""
    html = concatenar(html, ruta_segura)
    html = concatenar(html, "\" href=\"")
    html = concatenar(html, ruta_segura)
    html = concatenar(html, "\">")
    html = concatenar(html, texto_enlace)
    html = concatenar(html, "</a>")
    retornar html
fin_funcion

