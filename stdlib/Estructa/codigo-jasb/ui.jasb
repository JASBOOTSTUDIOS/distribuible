enviar funcion estructura_estado_vacio(texto titulo, texto mensaje) retorna texto
    texto cuerpo = "<article>"
    cuerpo = concatenar(cuerpo, "<h3>")
    cuerpo = concatenar(cuerpo, estructura_escapar(titulo))
    cuerpo = concatenar(cuerpo, "</h3>")
    cuerpo = concatenar(cuerpo, estructura_texto(mensaje))
    cuerpo = concatenar(cuerpo, "</article>")
    retornar cuerpo
fin_funcion

enviar funcion estructura_responder_error(texto titulo, texto navegacion, texto mensaje) retorna texto
    texto cuerpo = estructura_titulo("Error")
    cuerpo = concatenar(cuerpo, estructura_texto(mensaje))
    retornar api_respuesta("400 Bad Request", "text/html; charset=utf-8", estructura_layout_base(titulo, navegacion, cuerpo))
fin_funcion

enviar funcion estructura_badge(texto etiqueta) retorna texto
    texto html = "<span class=\"fui-etiqueta\" style=\"display:inline-flex;padding:6px 10px;border-radius:999px;background:#e2e8f0;color:#0f172a;font-size:12px;font-weight:700\">"
    html = concatenar(html, estructura_escapar(etiqueta))
    html = concatenar(html, "</span>")
    retornar html
fin_funcion

enviar funcion estructura_kpi(texto etiqueta, texto dato, texto ayuda) retorna texto
    texto html = "<article><p style=\"font-size:13px;color:#475569\">"
    html = concatenar(html, estructura_escapar(etiqueta))
    html = concatenar(html, "</p><h3 style=\"font-size:28px;margin-top:8px\">")
    html = concatenar(html, estructura_escapar(dato))
    html = concatenar(html, "</h3>")
    si longitud_texto(ayuda) > 0 entonces
        html = concatenar(html, estructura_texto(ayuda))
    fin_si
    html = concatenar(html, "</article>")
    retornar html
fin_funcion

enviar funcion estructura_seccion_titulo(texto titulo, texto subtitulo) retorna texto
    texto html = "<section class=\"es-columna\">"
    html = concatenar(html, estructura_titulo(titulo))
    si longitud_texto(subtitulo) > 0 entonces
        html = concatenar(html, estructura_texto(subtitulo))
    fin_si
    html = concatenar(html, "</section>")
    retornar html
fin_funcion

enviar funcion estructura_tabla_simple(texto encabezados, texto filas) retorna texto
    texto html = "<article style=\"overflow:auto\"><table style=\"width:100%;border-collapse:collapse\">"
    html = concatenar(html, "<thead><tr>")
    html = concatenar(html, encabezados)
    html = concatenar(html, "</tr></thead><tbody>")
    html = concatenar(html, filas)
    html = concatenar(html, "</tbody></table></article>")
    retornar html
fin_funcion

enviar funcion estructura_tabla_encabezado(texto etiqueta) retorna texto
    texto html = "<th style=\"text-align:left;padding:10px;border-bottom:1px solid #dbe4f0\">"
    html = concatenar(html, estructura_escapar(etiqueta))
    html = concatenar(html, "</th>")
    retornar html
fin_funcion

enviar funcion estructura_tabla_celda(texto dato) retorna texto
    texto html = "<td style=\"padding:10px;border-bottom:1px solid #e2e8f0\">"
    html = concatenar(html, estructura_escapar(dato))
    html = concatenar(html, "</td>")
    retornar html
fin_funcion

enviar funcion estructura_tabla_fila(texto celdas) retorna texto
    retornar concatenar("<tr>", concatenar(celdas, "</tr>"))
fin_funcion

enviar funcion estructura_panel_shell(texto barra_lateral, texto contenido) retorna texto
    texto html = "<section class=\"es-fila\" style=\"display:grid;grid-template-columns:260px 1fr;gap:20px\">"
    html = concatenar(html, "<aside>")
    html = concatenar(html, barra_lateral)
    html = concatenar(html, "</aside><section>")
    html = concatenar(html, contenido)
    html = concatenar(html, "</section></section>")
    retornar html
fin_funcion

enviar funcion estructura_menu_lateral_item(texto ruta, texto etiqueta, texto solicitud) retorna texto
    texto segura = estructura_ruta_segura(ruta)
    texto activa = ""
    si estructura_ruta_sin_query(solicitud) == segura entonces
        activa = " style=\"box-shadow:inset 0 0 0 2px #bfdbfe\""
    fin_si
    texto html = "<div"
    html = concatenar(html, activa)
    html = concatenar(html, ">")
    html = concatenar(html, estructura_boton_secundario(segura, etiqueta))
    html = concatenar(html, "</div>")
    retornar html
fin_funcion

enviar funcion estructura_no_encontrado_tema(texto titulo, texto navegacion, texto tema_css) retorna texto
    texto cuerpo = estructura_titulo("404")
    cuerpo = concatenar(cuerpo, estructura_texto("Ruta no encontrada"))
    retornar estructura_responder_tema(titulo, navegacion, cuerpo, tema_css)
fin_funcion

enviar funcion estructura_resolver_ruta_simple(texto solicitud, texto r0, funcion v0, texto r1, funcion v1, texto r2, funcion v2, texto r3, funcion v3, texto titulo, texto navegacion) retorna texto
    texto ruta = estructura_ruta_sin_query(solicitud)
    si api_metodo(solicitud) == "GET" entonces
        si ruta == r0 entonces
            retornar estructura_responder(titulo, navegacion, v0(solicitud))
        fin_si
        si ruta == r1 entonces
            retornar estructura_responder(titulo, navegacion, v1(solicitud))
        fin_si
        si ruta == r2 entonces
            retornar estructura_responder(titulo, navegacion, v2(solicitud))
        fin_si
        si ruta == r3 entonces
            retornar estructura_responder(titulo, navegacion, v3(solicitud))
        fin_si
    fin_si
    retornar estructura_no_encontrado(titulo, navegacion)
fin_funcion

// Camino estable de V1: resuelve rutas sobre cuerpos ya construidos, sin pasar vistas como funciones.
// Esto evita varios problemas del runtime actual con funciones de orden superior y respuestas compuestas.
enviar funcion estructura_resolver_ruta_cuerpos(texto solicitud, texto r0, texto c0, texto r1, texto c1, texto r2, texto c2, texto r3, texto c3, texto titulo, texto navegacion) retorna texto
    texto ruta = estructura_ruta_sin_query(solicitud)
    si api_metodo(solicitud) == "GET" entonces
        si ruta == r0 entonces
            retornar estructura_responder(titulo, navegacion, c0)
        fin_si
        si ruta == r1 entonces
            retornar estructura_responder(titulo, navegacion, c1)
        fin_si
        si ruta == r2 entonces
            retornar estructura_responder(titulo, navegacion, c2)
        fin_si
        si ruta == r3 entonces
            retornar estructura_responder(titulo, navegacion, c3)
        fin_si
    fin_si
    retornar estructura_no_encontrado(titulo, navegacion)
fin_funcion

enviar funcion estructura_es_get(texto solicitud, texto ruta) retorna entero
    si api_metodo(solicitud) == "GET" entonces
        si estructura_ruta_sin_query(solicitud) == ruta entonces
            retornar 1
        fin_si
    fin_si
    retornar 0
fin_funcion

enviar funcion estructura_vista_ruta(texto ruta, texto titulo, texto subtitulo, texto cuerpo) retorna texto
    texto html = "<section data-estructa-vista=\""
    html = concatenar(html, estructura_escapar(ruta))
    html = concatenar(html, "\" hidden><h1>")
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</h1>")
    si longitud_texto(subtitulo) > 0 entonces
        html = concatenar(html, "<p>")
        html = concatenar(html, estructura_escapar(subtitulo))
        html = concatenar(html, "</p>")
    fin_si
    html = concatenar(html, cuerpo)
    html = concatenar(html, "</section>")
    retornar html
fin_funcion

enviar funcion estructura_router_script() retorna texto
    retornar "<script>(function(){function g(){return location.pathname||'/'}function a(){var x=g(),v=document.querySelectorAll('[data-estructa-vista]'),l=document.querySelectorAll('[data-estructa-ruta]'),i,o=document.querySelector('[data-estructa-vista=\"'+x+'\"]')||document.querySelector('[data-estructa-vista=\"/\"]');for(i=0;i<v.length;i++)v[i].hidden=1;if(o)o.hidden=0;for(i=0;i<l.length;i++)l[i].style.fontWeight=l[i].getAttribute('data-estructa-ruta')==x?'700':'400'}function p(id){if(!id)return null;return document.querySelector('[data-estructa-id=\"'+id+'\"]')}document.addEventListener('click',function(e){var t=e.target.closest('[data-estructa-ruta],[data-estructa-accion]');if(!t)return;if(t.hasAttribute('data-estructa-ruta')){e.preventDefault();history.pushState({},'',t.getAttribute('data-estructa-ruta')||'/');a();return}var accion=t.getAttribute('data-estructa-accion')||'';var destino=t.getAttribute('data-estructa-destino')||'';var nodo=p(destino);if(accion==='alerta'){alert(t.getAttribute('data-estructa-mensaje')||'');return}if(!nodo)return;if(accion==='mostrar')nodo.hidden=false;else if(accion==='ocultar')nodo.hidden=true;else if(accion==='alternar')nodo.hidden=!nodo.hidden});addEventListener('popstate',a);a()})();</script>"
fin_funcion

enviar funcion estructura_app_rutas(texto titulo, texto navegacion, texto vistas) retorna texto
    texto html = "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>"
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</title><style>")
    html = concatenar(html, estructura_estilos_base())
    html = concatenar(html, "</style></head><body><nav>")
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, " ")
    html = concatenar(html, navegacion)
    html = concatenar(html, "</nav><main>")
    html = concatenar(html, vistas)
    html = concatenar(html, "</main>")
    html = concatenar(html, estructura_router_script())
    html = concatenar(html, "</body></html>")
    retornar api_respuesta("200 OK", "text/html; charset=utf-8", html)
fin_funcion

enviar funcion estructura_documento(texto titulo, texto subtitulo, texto cuerpo) retorna texto
    texto html = "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>"
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</title><style>")
    html = concatenar(html, estructura_estilos_base())
    html = concatenar(html, "</style></head><body><h1>")
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</h1><p>")
    html = concatenar(html, estructura_escapar(subtitulo))
    html = concatenar(html, "</p>")
    html = concatenar(html, cuerpo)
    html = concatenar(html, estructura_router_script())
    html = concatenar(html, "</body></html>")
    retornar html
fin_funcion

enviar funcion estructura_pagina(texto titulo, texto subtitulo, texto cuerpo) retorna texto
    texto documento = estructura_documento(titulo, subtitulo, cuerpo)
    texto respuesta = api_respuesta("200 OK", "text/html; charset=utf-8", documento)
    retornar respuesta
fin_funcion

enviar funcion estructura_http_bucle(texto host, entero puerto, entero max_solicitudes, funcion app) retorna entero
    socket srv = tcp_escuchar(host, puerto)
    entero i = 0
    entero acc = 0
    si srv == 0 entonces
        retornar api_alerta_puerto_en_uso(host, puerto, "HTTP")
    fin_si

    mientras i < max_solicitudes hacer
        socket cli = tcp_aceptar(srv)
        si cli == 0 entonces
        sino
            texto solicitud = api_leer_solicitud_http(cli)
            texto respuesta = app(solicitud)
            api_tcp_enviar_texto_completo(cli, respuesta)
            tcp_cerrar(cli)
            acc = acc + longitud_texto(solicitud)
            i = i + 1
        fin_si
    fin_mientras

    tcp_cerrar(srv)
    retornar acc
fin_funcion
