enviar funcion estructura_lista_textos(lista items) retorna texto
    entero i = 0
    texto html = "<section>"
    mientras i < mem_lista_tamano(items) hacer
        texto item = mem_lista_obtener(items, i)
        html = concatenar(html, "<div>")
        html = concatenar(html, estructura_escapar(item))
        html = concatenar(html, "</div>")
        i = i + 1
    fin_mientras
    html = concatenar(html, "</section>")
    retornar html
fin_funcion

enviar funcion estructura_ruta_sin_query(texto solicitud) retorna texto
    texto ruta = api_ruta(solicitud)
    si contiene_texto(ruta, "?") entonces
        retornar extraer_antes_de(ruta, "?")
    fin_si
    retornar ruta
fin_funcion

enviar funcion estructura_estado_texto(texto solicitud, texto clave, texto por_defecto) retorna texto
    texto ruta = api_ruta(solicitud)
    si contiene_texto(ruta, "?") entonces
        texto query = extraer_despues_de(ruta, "?")
        mientras longitud_texto(query) > 0 hacer
            texto parte = query
            si contiene_texto(query, "&") entonces
                parte = extraer_antes_de(query, "&")
                query = extraer_despues_de(query, "&")
            sino
                query = ""
            fin_si
            si contiene_texto(parte, "=") entonces
                texto nombre = extraer_antes_de(parte, "=")
                texto dato = extraer_despues_de(parte, "=")
                si nombre == clave entonces
                    retornar dato
                fin_si
            fin_si
        fin_mientras
    fin_si
    retornar por_defecto
fin_funcion

enviar funcion estructura_estado_entero(texto solicitud, texto clave, entero por_defecto) retorna entero
    texto dato = estructura_estado_texto(solicitud, clave, "")
    si longitud_texto(dato) == 0 entonces
        retornar por_defecto
    fin_si
    retornar str_a_entero(dato)
fin_funcion

enviar funcion estructura_boton_entero(texto ruta_base, texto clave, entero numero, texto etiqueta) retorna texto
    texto ruta = concatenar(estructura_ruta_segura(ruta_base), "?")
    ruta = concatenar(ruta, clave)
    ruta = concatenar(ruta, "=")
    ruta = concatenar(ruta, str_desde_numero(numero))
    retornar estructura_boton(ruta, etiqueta)
fin_funcion

enviar funcion estructura_layout_base(texto titulo, texto navegacion, texto cuerpo) retorna texto
    texto html = "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>"
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</title><style>")
    html = concatenar(html, estructura_estilos_base())
    html = concatenar(html, "</style></head><body><div class=\"es-shell\">")
    html = concatenar(html, "<nav class=\"es-nav\"><div class=\"es-marca\">")
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</div><div class=\"es-nav-links\">")
    html = concatenar(html, navegacion)
    html = concatenar(html, "</div></nav><main class=\"es-contenido\">")
    html = concatenar(html, cuerpo)
    html = concatenar(html, "</main>")
    html = concatenar(html, estructura_router_script())
    html = concatenar(html, "</div></body></html>")
    retornar html
fin_funcion

enviar funcion estructura_layout_base_tema(texto titulo, texto navegacion, texto cuerpo, texto tema_css) retorna texto
    texto html = "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><title>"
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</title><style>")
    html = concatenar(html, tema_css)
    html = concatenar(html, estructura_estilos_base())
    html = concatenar(html, "</style></head><body><div class=\"es-shell\">")
    html = concatenar(html, "<nav class=\"es-nav\"><div class=\"es-marca\">")
    html = concatenar(html, estructura_escapar(titulo))
    html = concatenar(html, "</div><div class=\"es-nav-links\">")
    html = concatenar(html, navegacion)
    html = concatenar(html, "</div></nav><main class=\"es-contenido\">")
    html = concatenar(html, cuerpo)
    html = concatenar(html, "</main>")
    html = concatenar(html, estructura_router_script())
    html = concatenar(html, "</div></body></html>")
    retornar html
fin_funcion

enviar funcion estructura_nav_simple(texto etiqueta_inicio, texto etiqueta_productos, texto etiqueta_equipo, texto etiqueta_contacto) retorna texto
    texto nav = estructura_enlace_ruta("/", etiqueta_inicio)
    nav = concatenar(nav, estructura_enlace_ruta("/productos", etiqueta_productos))
    nav = concatenar(nav, estructura_enlace_ruta("/equipo", etiqueta_equipo))
    nav = concatenar(nav, estructura_enlace_ruta("/contacto", etiqueta_contacto))
    retornar nav
fin_funcion

