# =============================================================================
# LIBRERÍA DE ANALÍTICA NEURONAL (PUNTO DE ENTRADA V1.0 - REGISTRO COMPLETO)
# =============================================================================
# Versión: 1.0.0
# Fecha: 2024-04-20
# Estado: COMPLETO - Incluye todos los módulos de ML avanzado
# =============================================================================

usar todas de "./base.jasb"
usar todas de "./math_lib.jasb"

# =============================================================================
# IMPORTACIÓN DE MÓDULOS EXISTENTES
# =============================================================================
usar { EstadisticaDescriptiva } de "./estadistica/estadistica_descriptiva.jasb"
usar { Probabilidad } de "./probabilidad/probabilidad_basica.jasb"
usar { InferenciaEstadistica } de "./inferencia/inferencia_estadistica.jasb"
usar { SeriesTemporales } de "./series_temporales/analisis_series_temporales.jasb"
usar { MachineLearning } de "./machine_learning/algoritmos_ml.jasb"
usar { ProcesadorLenguajeNatural } de "./machine_learning/nlp_basico.jasb"
usar { VisualizadorAnalitico } de "./visualizacion/graficos_analiticos.jasb"
usar { ModelosPrediccion } de "./prediccion/modelos_prediccion.jasb"

# =============================================================================
# IMPORTACIÓN DE NUEVOS MÓDULOS - FASE 1: FUNDAMENTOS
# =============================================================================
usar { MetricasRegresion } de "./metricas/metricas_regresion.jasb"
usar { MetricasClasificacion } de "./metricas/metricas_clasificacion.jasb"
usar { MetricasClustering } de "./metricas/metricas_clustering.jasb"
usar { SplitDatos } de "./validacion/split_datos.jasb"
usar { CrossValidation } de "./validacion/cross_validation.jasb"
usar { Normalizacion } de "./preprocesamiento/normalizacion.jasb"

# =============================================================================
# IMPORTACIÓN DE NUEVOS MÓDULOS - FASE 2: MODELOS AVANZADOS
# =============================================================================
usar { ArbolesDecision } de "./machine_learning/arboles_decision.jasb"
usar { RandomForest } de "./machine_learning/random_forest.jasb"
usar { ARIMA } de "./series_temporales/arima.jasb"

# =============================================================================
# IMPORTACIÓN DE NUEVOS MÓDULOS - FASE 3: TÉCNICAS AVANZADAS
# =============================================================================
usar { GradientBoosting } de "./machine_learning/gradient_boosting.jasb"
usar { RedesNeuronales } de "./machine_learning/redes_neuronales.jasb"
usar { SeleccionFeatures } de "./preprocesamiento/seleccion_features.jasb"

# =============================================================================
# IMPORTACIÓN DE NUEVOS MÓDULOS - FASE 4: COMPLEMENTOS
# =============================================================================
usar { ClusteringAvanzado } de "./machine_learning/clustering_avanzado.jasb"
usar { ReduccionDimensionalidad } de "./preprocesamiento/reduccion_dim.jasb"
usar { SVM } de "./machine_learning/svm.jasb"

# =============================================================================
# REGISTRO DE FACHADA COMPLETA V1.0
# =============================================================================
registro AnaliticaFachada
    # Módulos Core (existentes)
    EstadisticaDescriptiva estadistica
    Probabilidad probabilidad
    InferenciaEstadistica inferencia
    SeriesTemporales series
    MachineLearning ml
    ProcesadorLenguajeNatural nlp
    ModelosPrediccion prediccion
    VisualizadorAnalitico visualizacion

    # NUEVOS MÓDULOS - Métricas
    MetricasRegresion metricas_reg
    MetricasClasificacion metricas_clf
    MetricasClustering metricas_cluster

    # NUEVOS MÓDULOS - Validación
    SplitDatos split
    CrossValidation cv

    # NUEVOS MÓDULOS - Preprocesamiento
    Normalizacion normalizacion
    SeleccionFeatures seleccion_features
    ReduccionDimensionalidad pca

    # NUEVOS MÓDULOS - ML Avanzado
    ArbolesDecision arboles
    RandomForest random_forest
    GradientBoosting gradient_boosting
    RedesNeuronales redes_neuronales
    SVM svm
    ClusteringAvanzado clustering_avanzado

    # NUEVOS MÓDULOS - Series Temporales Avanzadas
    ARIMA arima
fin_registro

# Instancia Global
AnaliticaFachada g_analitica

# =============================================================================
# FUNCIÓN DE INICIALIZACIÓN V1.0
# =============================================================================
funcion inicializar_fachada() retorna entero
    # Crear instancia de la fachada primero
    g_analitica = AnaliticaFachada()

    # =========================================================================
    # MÓDULOS CORE (Existentes)
    # =========================================================================
    g_analitica.estadistica = EstadisticaDescriptiva()
    g_analitica.probabilidad = Probabilidad()
    g_analitica.inferencia = InferenciaEstadistica()
    g_analitica.series = SeriesTemporales()
    g_analitica.ml = MachineLearning()
    g_analitica.nlp = ProcesadorLenguajeNatural()
    g_analitica.prediccion = ModelosPrediccion()
    g_analitica.visualizacion = VisualizadorAnalitico()

    # Inicializar módulos core
    g_analitica.estadistica.inicializar()
    g_analitica.probabilidad.inicializar()
    g_analitica.inferencia.inicializar()
    g_analitica.series.inicializar()
    g_analitica.ml.inicializar()
    g_analitica.nlp.inicializar()
    g_analitica.prediccion.inicializar()
    g_analitica.visualizacion.inicializar()

    # =========================================================================
    # NUEVOS MÓDULOS - MÉTRICAS
    # =========================================================================
    g_analitica.metricas_reg = MetricasRegresion()
    g_analitica.metricas_clf = MetricasClasificacion()
    g_analitica.metricas_cluster = MetricasClustering()

    g_analitica.metricas_reg.inicializar()
    g_analitica.metricas_clf.inicializar()
    g_analitica.metricas_cluster.inicializar()

    # =========================================================================
    # NUEVOS MÓDULOS - VALIDACIÓN
    # =========================================================================
    g_analitica.split = SplitDatos()
    g_analitica.cv = CrossValidation()

    g_analitica.split.inicializar()
    g_analitica.cv.inicializar()

    # =========================================================================
    # NUEVOS MÓDULOS - PREPROCESAMIENTO
    # =========================================================================
    g_analitica.normalizacion = Normalizacion()
    g_analitica.seleccion_features = SeleccionFeatures()
    g_analitica.pca = ReduccionDimensionalidad()

    g_analitica.normalizacion.inicializar()
    g_analitica.seleccion_features.inicializar()
    g_analitica.pca.inicializar()

    # =========================================================================
    # NUEVOS MÓDULOS - ML AVANZADO
    # =========================================================================
    g_analitica.arboles = ArbolesDecision()
    g_analitica.random_forest = RandomForest()
    g_analitica.gradient_boosting = GradientBoosting()
    g_analitica.redes_neuronales = RedesNeuronales()
    g_analitica.svm = SVM()
    g_analitica.clustering_avanzado = ClusteringAvanzado()

    g_analitica.arboles.inicializar()
    # g_analitica.random_forest.inicializar() # Esta clase usa constructor por defecto
    g_analitica.gradient_boosting.inicializar()
    g_analitica.redes_neuronales.inicializar()
    g_analitica.svm.inicializar()
    g_analitica.clustering_avanzado.inicializar()

    # =========================================================================
    # NUEVOS MÓDULOS - SERIES TEMPORALES AVANZADAS
    # =========================================================================
    g_analitica.arima = ARIMA()
    g_analitica.arima.inicializar()

    imprimir "=== ANALÍTICA NEURONAL V1.0 INICIALIZADA ==="
    imprimir "✅ Módulos Core: 8"
    imprimir "✅ Módulos de Métricas: 3"
    imprimir "✅ Módulos de Validación: 2"
    imprimir "✅ Módulos de Preprocesamiento: 3"
    imprimir "✅ Módulos de ML Avanzado: 6"
    imprimir "✅ Módulos de Series Temporales: 2"
    imprimir "📊 Total: 24 módulos cargados"
    imprimir "=========================================="

    retornar 1
fin_funcion

# =============================================================================
# WRAPPERS DE COMPATIBILIDAD V1.0
# =============================================================================

funcion inicializar_analitica_neuronal() retorna bool
    imprimir "Sistema de Analítica Neuronal V2.1 (Capa Compatibilidad) Inicializado."

    # Asegurar instancia de la fachada
    g_analitica = AnaliticaFachada()

    entero dummy = 0
    dummy = inicializar_fachada()
    retornar verdadero
fin_funcion

funcion analisis_completo_dataset(lista datos) retorna mapa
    mapa res = mapa_crear()
    mapa stats = g_analitica.estadistica.resumen_estadistico_completo(datos)
    mapa_poner(res, "estadisticas", stats)

    lista atipicos = g_analitica.estadistica.detectar_valores_atipicos(datos, 1.5)
    mapa_poner(res, "atipicos", atipicos)

    retornar res
fin_funcion

