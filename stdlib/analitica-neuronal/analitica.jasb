# Funcion helper para normalizacion automatica
funcion normalizar_datos_auto(lista X, texto metodo) retorna mapa
    mapa res = mapa_crear()

    si metodo == "minmax" entonces
        mapa scaler = g_analitica.normalizacion.min_max_scaler_fit(X)
        lista X_norm = g_analitica.normalizacion.min_max_scaler_transform(X, scaler)
        mapa_poner(res, "scaler", scaler)
        mapa_poner(res, "datos_normalizados", X_norm)
    sino si metodo == "standard" entonces
        mapa scaler = g_analitica.normalizacion.standard_scaler_fit(X)
        lista X_norm = g_analitica.normalizacion.standard_scaler_transform(X, scaler)
        mapa_poner(res, "scaler", scaler)
        mapa_poner(res, "datos_normalizados", X_norm)
    sino si metodo == "robust" entonces
        mapa scaler = g_analitica.normalizacion.robust_scaler_fit(X)
        lista X_norm = g_analitica.normalizacion.robust_scaler_transform(X, scaler)
        mapa_poner(res, "scaler", scaler)
        mapa_poner(res, "datos_normalizados", X_norm)
    fin_si

    retornar res
fin_funcion

# =============================================================================
# EXPORTACIÓN DE MÓDULO V1.0
# =============================================================================
enviar {
    g_analitica,
    AnaliticaFachada,
    inicializar_fachada,
    inicializar_analitica_neuronal,
    analisis_completo_dataset,
    prediccion_modelo_completo,
    aprender_patrones_estadisticos,
    mejorar_predicciones_con_memoria,
    pipeline_ml_completo,
    normalizar_datos_auto
}
