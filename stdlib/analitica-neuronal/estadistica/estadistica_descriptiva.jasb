# =============================================================================
# MÓDULO DE ESTADÍSTICA DESCRIPTIVA
# =============================================================================
# Propósito: Proporcionar una clase con métodos de estadística descriptiva para
#           el análisis de conjuntos de datos numéricos.
#
# Funcionalidades principales:
# 1. Medidas de tendencia central (media, mediana, moda)
# 2. Medidas de dispersión (varianza, desviación estándar, rango)
# 3. Medidas de posición (cuartiles, percentiles, deciles)
# 4. Medidas de forma (asimetría, curtosis)
# 5. Resúmenes estadísticos completos
# =============================================================================

usar todas de "../base.jasb"

clase EstadisticaDescriptiva extiende AnalizadorBase

    # Constructor
    funcion inicializar()
        padre.inicializar("Estadística Descriptiva", "V1.5")
    fin_funcion

    # =============================================================================
    # MÉTODOS AUXILIARES
    # =============================================================================
    
    # Método: validar_datos_numericos
    # Propósito: Verificar que todos los elementos sean números válidos
    # Parámetros: lista a validar
    # Retorna: bool indicando si todos son números válidos
    funcion validar_datos_numericos(lista datos) retorna bool
        si datos == nulo entonces
            imprimir "DEBUG: validar_datos_numericos - datos es nulo"
            retornar falso
        fin_si
        entero n = lista_tamano(datos)
        si n == 0 entonces
            imprimir "DEBUG: validar_datos_numericos - lista vacia"
            retornar falso
        fin_si
        
        entero i = 0
        mientras i < n hacer
            elemento elemento_valor = lista_obtener(datos, i)
            si elemento_valor == nulo o elemento_valor == "indefinido" entonces
                imprimir "DEBUG: validar_datos_numericos - dato en indice " + str_desde_numero(i) + " es invalido"
                retornar falso
            fin_si
            i = i + 1
        fin_mientras
        
        retornar verdadero
    fin_funcion

    # Método: ordenar_datos
    # Propósito: Ordenar lista numérica en orden ascendente
    # Parámetros: lista de números
    # Retorna: nueva lista ordenada
    funcion ordenar_datos(lista<flotante> datos) retorna lista<flotante>
        si datos == nulo entonces
            retornar crear_lista()
        fin_si
        entero n_orig = lista_tamano(datos)
        si n_orig == 0 entonces
            retornar crear_lista()
        fin_si
        
        lista<flotante> _res_lista = crear_lista()
        entero i = 0
        mientras i < n_orig hacer
            lista_agregar(_res_lista, lista_obtener(datos, i))
            i = i + 1
        fin_mientras
        
        # Algoritmo de ordenamiento simple (bubble sort)
        entero n = lista_tamano(_res_lista)
        entero j = 0
        mientras j < n - 1 hacer
            entero k = 0
            mientras k < n - j - 1 hacer
                flotante val1 = lista_obtener(_res_lista, k)
                flotante val2 = lista_obtener(_res_lista, k + 1)
                si val1 > val2 entonces
                    # Intercambiar
                    lista_poner(_res_lista, k, val2)
                    lista_poner(_res_lista, k + 1, val1)
                fin_si
                k = k + 1
            fin_mientras
            j = j + 1
        fin_mientras
        
        retornar _res_lista
    fin_funcion

    # =============================================================================
    # MÉTODOS DE TENDENCIA CENTRAL
    # =============================================================================
    
    # Método: calcular_media_aritmetica
    # Propósito: Calcular el promedio de un conjunto de datos numéricos
    # Parámetros: lista de números (flotantes o enteros)
    # Retorna: valor flotante representando la media aritmética
    # Notas: Maneja listas vacías retornando indefinido
    funcion calcular_media_aritmetica(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        flotante suma = 0.0
        flotante nf = 0.0
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            suma = suma + elemento_valor
            nf = nf + 1.0
            i = i + 1
        fin_mientras
        
        flotante media = suma / nf
        retornar media
    fin_funcion

    
    # Método: calcular_media_geometrica
    # Propósito: Calcular la media geométrica para datos multiplicativos
    # Parámetros: lista de números positivos
    # Retorna: valor flotante representando la media geométrica
    # Notas: Requiere todos los valores > 0, útil para tasas de crecimiento
    funcion calcular_media_geometrica(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        flotante producto = 1.0
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            si elemento_valor <= 0.0 entonces
                retornar -999999.0
            fin_si
            producto = producto * elemento_valor
            i = i + 1
        fin_mientras
        
        flotante media_geo = exp(log(producto) * (1.0 / convertir_flotante(n)))
        retornar media_geo
    fin_funcion
    
    # Método: calcular_media_armonica
    # Propósito: Calcular la media armónica para tasas y velocidades
    # Parámetros: lista de números no nulos
    # Retorna: valor flotante representando la media armónica
    # Notas: Útil para promediar velocidades o tasas
    funcion calcular_media_armonica(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        flotante suma_inversos = 0.0
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            si elemento_valor == 0.0 entonces
                retornar -999999.0
            fin_si
            suma_inversos = suma_inversos + (1.0 / elemento_valor)
            i = i + 1
        fin_mientras
        
        flotante media_armonica = convertir_flotante(n) / suma_inversos
        retornar media_armonica
    fin_funcion
    
    # Método: calcular_mediana
    # Propósito: Calcular el valor central del conjunto de datos ordenado
    # Parámetros: lista de números
    # Retorna: valor flotante representando la mediana
    # Notas: Para listas pares, retorna el promedio de los dos valores centrales
    funcion calcular_mediana(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        lista datos_ordenados = este.ordenar_datos(datos)
        
        si n % 2 == 1 entonces
            # Impar: retornar el valor central
            entero indice_medio = n / 2
            retornar lista_obtener(datos_ordenados, indice_medio)
        sino
            # Par: promedio de los dos valores centrales
            entero indice1 = (n / 2) - 1
            entero indice2 = n / 2
            flotante valor1 = lista_obtener(datos_ordenados, indice1)
            flotante valor2 = lista_obtener(datos_ordenados, indice2)
            retornar (valor1 + valor2) / 2.0
        fin_si
    fin_funcion
    
    # Método: calcular_moda
    # Propósito: Encontrar el valor(s) más frecuente en el conjunto
    # Parámetros: lista de números
    # Retorna: lista de valores modales (puede ser multimodal)
    # Notas: Retorna lista vacía si no hay moda (todos valores únicos)
    funcion calcular_moda(lista<flotante> datos) retorna lista
        si no este.validar_datos_numericos(datos) entonces
            retornar crear_lista()
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar crear_lista()
        fin_si
        
        mapa frecuencias = mapa_crear()
        entero max_frecuencia = 0
        
        # Contar frecuencias
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            texto clave = str_desde_numero(elemento_valor)
            
            entero freq_actual = mapa_obtener(frecuencias, clave)
            si freq_actual == nulo entonces
                freq_actual = 0
            fin_si
            
            entero freq_int = freq_actual + 1
            mapa_poner(frecuencias, clave, freq_int)
            
            si freq_int > max_frecuencia entonces
                max_frecuencia = freq_int
            fin_si
            
            i = i + 1
        fin_mientras
        
        # Si todos son únicos, no hay moda
        si max_frecuencia <= 1 entonces
            retornar crear_lista()
        fin_si
        
        # Encontrar todos los valores con max_frecuencia
        lista modas = crear_lista()
        i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            texto clave = str_desde_numero(elemento_valor)
            entero freq = mapa_obtener(frecuencias, clave)
            
            si freq == max_frecuencia entonces
                # Evitar duplicados
                entero j = 0
                bool ya_agregado = falso
                mientras j < lista_tamano(modas) hacer
                    flotante v_moda = lista_obtener(modas, j)
                    si v_moda == elemento_valor entonces
                        ya_agregado = verdadero
                        romper
                    fin_si
                    j = j + 1
                fin_mientras
                
                si no ya_agregado entonces
                    lista_agregar(modas, elemento_valor)
                fin_si
            fin_si
            
            i = i + 1
        fin_mientras
        
        retornar modas
    fin_funcion
    
    # =============================================================================
    # MÉTODOS DE DISPERSIÓN
    # =============================================================================
    
    # Método: calcular_varianza
    # Propósito: Calcular la dispersión promedio cuadrática de los datos
    # Parámetros: lista de números, bool para muestra/población
    # Retorna: valor flotante representando la varianza
    # Notas: Parámetro bool indica si es muestra (n-1) o población (n)
    funcion calcular_varianza(lista<flotante> datos, bool es_muestra) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        si n == 1 y es_muestra entonces
            retornar -999999.0
        fin_si
        
        flotante media = este.calcular_media_aritmetica(datos)
        si media == -999999.0 entonces
            retornar -999999.0
        fin_si
        
        flotante suma_diferencias = 0.0
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            flotante diferencia = elemento_valor - media
            suma_diferencias = suma_diferencias + (diferencia * diferencia)
            i = i + 1
        fin_mientras
        
        flotante divisor = es_muestra ? (convertir_flotante(n) - 1.0) : convertir_flotante(n)
        retornar suma_diferencias / divisor
    fin_funcion
    
    # Método: calcular_desviacion_estandar
    # Propósito: Calcular la raíz cuadrada de la varianza
    # Parámetros: lista de números, bool para muestra/población
    # Retorna: valor flotante representando la desviación estándar
    # Notas: Unidad igual a la de los datos originales
    funcion calcular_desviacion_estandar(lista<flotante> datos, bool es_muestra) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        flotante varianza = este.calcular_varianza(datos, es_muestra)
        si varianza == -999999.0 entonces
            retornar -999999.0
        fin_si
        
        retornar raiz_cuadrada(varianza)
    fin_funcion
    
    # Método: calcular_rango
    # Propósito: Calcular la diferencia entre máximo y mínimo
    # Parámetros: lista de números
    # Retorna: valor flotante representando el rango
    # Notas: Medida simple de dispersión
    funcion calcular_rango(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        flotante minimo = lista_obtener(datos, 0)
        flotante maximo = lista_obtener(datos, 0)
        
        entero i = 1
        mientras i < n hacer
            flotante valor_float = lista_obtener(datos, i)
            si valor_float < minimo entonces
                minimo = valor_float
            fin_si
            si valor_float > maximo entonces
                maximo = valor_float
            fin_si
            i = i + 1
        fin_mientras
        
        retornar maximo - minimo
    fin_funcion
    
    # Método: calcular_rango_intercuartilico
    # Propósito: Calcular la dispersión del 50% central de datos
    # Parámetros: lista de números
    # Retorna: valor flotante representando el IQR
    # Notas: Robusto a valores atípicos
    funcion calcular_rango_intercuartilico(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        flotante q1 = este.calcular_cuartil(datos, 1)
        flotante q3 = este.calcular_cuartil(datos, 3)
        
        si q1 == -999999.0 o q3 == -999999.0 entonces
            retornar -999999.0
        fin_si
        
        retornar q3 - q1
    fin_funcion
    
    # Método: calcular_coeficiente_variacion
    # Propósito: Calcular variabilidad relativa como porcentaje
    # Parámetros: lista de números
    # Retorna: valor flotante representando el CV (%)
    # Notas: Útil para promediar dispersiones de diferentes escalas
    funcion calcular_coeficiente_variacion(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        flotante media = este.calcular_media_aritmetica(datos)
        flotante desv_std = este.calcular_desviacion_estandar(datos, falso)
        
        si media == -999999.0 o desv_std == -999999.0 entonces
            retornar -999999.0
        fin_si
        
        si media == 0.0 entonces
            retornar -999999.0
        fin_si
        
        retornar (desv_std / media) * 100.0
    fin_funcion
    
    # =============================================================================
    # MÉTODOS DE POSICIÓN
    # =============================================================================
    
    # Método: calcular_percentil
    # Propósito: Calcular el valor debajo del cual cae un porcentaje de datos
    # Parámetros: lista de números, valor percentil (0-100)
    # Retorna: valor flotante representando el percentil
    # Notas: Usa interpolación lineal para percentiles no exactos
    funcion calcular_percentil(lista<flotante> datos, flotante percentil) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        si percentil < 0.0 o percentil > 100.0 entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n == 0 entonces
            retornar -999999.0
        fin_si
        
        lista datos_ordenados = este.ordenar_datos(datos)
        
        flotante posicion = (percentil / 100.0) * convertir_flotante(n - 1)
        entero indice_inferior = convertir_entero(posicion)
        flotante fraccion = posicion - convertir_flotante(indice_inferior)
        
        si indice_inferior == n - 1 entonces
            retornar lista_obtener(datos_ordenados, indice_inferior)
        fin_si
        
        flotante valor_inferior = lista_obtener(datos_ordenados, indice_inferior)
        flotante valor_superior = lista_obtener(datos_ordenados, indice_inferior + 1)
        
        retornar valor_inferior + (fraccion * (valor_superior - valor_inferior))
    fin_funcion
    
    # Método: calcular_cuartil
    # Propósito: Calcular los cuatro cuartiles del conjunto de datos
    # Parámetros: lista de números, número de cuartil (1-4)
    # Retorna: valor flotante representando el cuartil solicitado
    # Notas: Q1 = percentil 25, Q2 = mediana, Q3 = percentil 75
    funcion calcular_cuartil(lista<flotante> datos, entero num_cuartil) retorna flotante
        si num_cuartil < 1 o num_cuartil > 4 entonces
            retornar -999999.0
        fin_si
        
        flotante percentil = convertir_flotante(num_cuartil) * 25.0
        retornar este.calcular_percentil(datos, percentil)
    fin_funcion
    
    # Método: calcular_decil
    # Propósito: Calcular los diez deciles del conjunto de datos
    # Parámetros: lista de números, número de decil (1-10)
    # Retorna: valor flotante representando el decil solicitado
    # Notas: D5 = mediana
    funcion calcular_decil(lista<flotante> datos, entero num_decil) retorna flotante
        si num_decil < 1 o num_decil > 10 entonces
            retornar -999999.0
        fin_si
        
        flotante percentil = convertir_flotante(num_decil) * 10.0
        retornar este.calcular_percentil(datos, percentil)
    fin_funcion
    
    # =============================================================================
    # MÉTODOS DE FORMA
    # =============================================================================
    
    # Método: calcular_asimetria
    # Propósito: Medir la asimetría de la distribución de datos
    # Parámetros: lista de números
    # Retorna: valor cualquiera representando el coeficiente de asimetría
    # Notas: >0 sesgo a derecha, <0 sesgo a izquierda, =0 simétrico
    funcion calcular_asimetria(lista datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n < 3 entonces
            retornar -999999.0
        fin_si
        
        flotante media = este.calcular_media_aritmetica(datos)
        flotante desv_std = este.calcular_desviacion_estandar(datos, falso)
        
        si media == -999999.0 o desv_std == -999999.0 o desv_std == 0 entonces
            retornar -999999.0
        fin_si
        
        flotante suma_cubica = 0.0
        entero i = 0
        mientras i < n hacer
            elemento elemento_valor = lista_obtener(datos, i)
            flotante diferencia = elemento_valor - media
            suma_cubica = suma_cubica + (diferencia * diferencia * diferencia)
            i = i + 1
        fin_mientras
        
        flotante n_flotante = n
        flotante asimetria = (suma_cubica / n_flotante) / (desv_std * desv_std * desv_std)
        
        # Corrección de sesgo para muestras pequeñas
        si n > 2 entonces
            flotante correccion = exp(log(n_flotante * (n_flotante - 1)) * 0.5) / (n_flotante - 2)
            asimetria = asimetria * correccion
        fin_si
        
        retornar asimetria
    fin_funcion
    
    # Método: calcular_curtosis
    # Propósito: Medir la "agudeza" o "achatamiento" de la distribución
    # Parámetros: lista de números
    # Retorna: valor flotante representando el coeficiente de curtosis
    # Notas: >3 leptocúrtica, <3 platicúrtica, =3 mesocúrtica (normal)
    funcion calcular_curtosis(lista<flotante> datos) retorna flotante
        si no este.validar_datos_numericos(datos) entonces
            retornar -999999.0
        fin_si
        
        entero n = lista_tamano(datos)
        si n < 4 entonces
            retornar -999999.0
        fin_si
        
        flotante media = este.calcular_media_aritmetica(datos)
        flotante desv_std = este.calcular_desviacion_estandar(datos, falso)
        
        si media == -999999.0 o desv_std == -999999.0 o desv_std == 0.0 entonces
            retornar -999999.0
        fin_si
        
        flotante suma_cuarta = 0.0
        entero i = 0
        mientras i < n hacer
            flotante elemento_valor = lista_obtener(datos, i)
            flotante diferencia = elemento_valor - media
            suma_cuarta = suma_cuarta + (diferencia * diferencia * diferencia * diferencia)
            i = i + 1
        fin_mientras
        
        flotante n_flotante = convertir_flotante(n)
        flotante curtosis = (suma_cuarta / n_flotante) / (desv_std * desv_std * desv_std * desv_std)
        
        # Corrección de sesgo para muestras pequeñas
        si n > 3 entonces
            flotante correccion1 = (n_flotante - 1.0) * (n_flotante - 1.0)
            flotante correccion2 = (n_flotante - 2.0) * (n_flotante - 3.0)
            flotante correccion3 = (3.0 * (n_flotante - 1.0) * (n_flotante - 1.0)) / ((n_flotante - 2.0) * (n_flotante - 3.0))
            curtosis = (correccion1 / correccion2) * curtosis - correccion3
        fin_si
        
        # Ajuste para comparación con distribución normal (curtosis = 3)
        retornar curtosis + 3.0
    fin_funcion
    
    # =============================================================================
    # MÉTODOS DE RESUMEN
    # =============================================================================
    
    # Método: resumen_estadistico_completo
    # Propósito: Generar un resumen completo de estadísticas descriptivas
    # Parámetros: lista de números
    # Retorna: mapa con todas las estadísticas principales
    # Notas: Incluye medidas de tendencia central, dispersión y forma
    funcion resumen_estadistico_completo(lista<flotante> datos) retorna mapa
        mapa resumen = mapa_crear()
        
        si no este.validar_datos_numericos(datos) entonces
            retornar resumen
        fin_si

        # Tendencia central
        flotante media = este.calcular_media_aritmetica(datos)
        mapa_poner(resumen, "media_aritmetica", media)
        
        flotante mediana = este.calcular_mediana(datos)
        mapa_poner(resumen, "mediana", mediana)
        
        # lista modas = este.calcular_moda(datos)
        # mapa_poner(resumen, "moda", modas)
        
        # Dispersión
        mapa_poner(resumen, "varianza_muestra", este.calcular_varianza(datos, verdadero))
        mapa_poner(resumen, "varianza_poblacion", este.calcular_varianza(datos, falso))
        mapa_poner(resumen, "desviacion_estandar_muestra", este.calcular_desviacion_estandar(datos, verdadero))
        mapa_poner(resumen, "desviacion_estandar_poblacion", este.calcular_desviacion_estandar(datos, falso))
        mapa_poner(resumen, "rango", este.calcular_rango(datos))
        
        # fl q_iqr = este.calcular_rango_intercuartilico(datos)
        # mapa_poner(resumen, "rango_intercuartilico", q_iqr)
        
        # fl q_cv = este.calcular_coeficiente_variacion(datos)
        # mapa_poner(resumen, "coeficiente_variacion", q_cv)
        
        # Posición
        mapa_poner(resumen, "q1", este.calcular_cuartil(datos, 1))
        mapa_poner(resumen, "q3", este.calcular_cuartil(datos, 3))
        
        # Forma
        # mapa_poner(resumen, "asimetria", este.calcular_asimetria(datos))
        # mapa_poner(resumen, "curtosis", este.calcular_curtosis(datos))
        
        # Información básica
        mapa_poner(resumen, "n", lista_tamano(datos))
        
        retornar resumen
    fin_funcion

    # Método: resumen_cinco_numeros
    # Propósito: Generar el resumen de cinco números (Tukey)
    # Parámetros: lista de números
    # Retorna: mapa con mínimo, Q1, mediana, Q3, máximo
    # Notas: Base para diagramas de caja y bigotes
    funcion resumen_cinco_numeros(lista<flotante> datos) retorna mapa
        mapa resumen = mapa_crear()
        
        lista datos_ordenados = este.ordenar_datos(datos)
        entero n = lista_tamano(datos_ordenados)
        
        si n > 0 entonces
            mapa_poner(resumen, "minimo", lista_obtener(datos_ordenados, 0))
            mapa_poner(resumen, "q1", este.calcular_cuartil(datos, 1))
            mapa_poner(resumen, "mediana", este.calcular_mediana(datos))
            mapa_poner(resumen, "q3", este.calcular_cuartil(datos, 3))
            mapa_poner(resumen, "maximo", lista_obtener(datos_ordenados, n - 1))
        fin_si
        
        retornar resumen
    fin_funcion

    # Método: detectar_valores_atipicos
    # Propósito: Identificar valores atípicos usando criterio IQR
    # Parámetros: lista de números, factor multiplicador (default 1.5)
    # Retorna: lista de valores considerados atípicos
    # Notas: Valores fuera de [Q1-1.5*IQR, Q3+1.5*IQR]
    funcion detectar_valores_atipicos(lista<flotante> datos, flotante factor) retorna lista
        si no este.validar_datos_numericos(datos) entonces
            retornar crear_lista()
        fin_si
        
        si factor <= 0.0 entonces
            factor = 1.5
        fin_si
        
        flotante q1 = este.calcular_cuartil(datos, 1)
        flotante q3 = este.calcular_cuartil(datos, 3)
        flotante iqr = q3 - q1
        
        flotante limite_inferior = q1 - (factor * iqr)
        flotante limite_superior = q3 + (factor * iqr)
        
        lista atipicos = crear_lista()
        entero n = lista_tamano(datos)
        entero i = 0
        
        mientras i < n hacer
            flotante valor_dato = lista_obtener(datos, i)
            si valor_dato < limite_inferior o valor_dato > limite_superior entonces
                lista_agregar(atipicos, valor_dato)
            fin_si
            i = i + 1
        fin_mientras
        
        retornar atipicos
    fin_funcion

fin_clase

enviar {
    EstadisticaDescriptiva
}

