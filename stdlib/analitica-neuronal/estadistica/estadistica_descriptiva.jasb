# =============================================================================
# PRUEBAS UNITARIAS
# =============================================================================

# Pruebas para métodos auxiliares
funcion probar_metodos_auxiliares() retorna entero
    imprimir "=== PRUEBAS DE MÉTODOS AUXILIARES ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Prueba 1: validar_datos_numericos con datos válidos
    total_pruebas = total_pruebas + 1
    lista datos_validos = crear_lista()
    lista_agregar(datos_validos, 1.5)
    lista_agregar(datos_validos, 2.0)
    lista_agregar(datos_validos, -3.2)
    lista_agregar(datos_validos, 0.0)
    
    si estadistica.validar_datos_numericos(datos_validos) entonces
        imprimir "✓ Prueba 1: validar_datos_numericos (datos válidos) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 1: validar_datos_numericos (datos válidos) - FALLÓ"
    fin_si
    
    # Prueba 2: validar_datos_numericos con nulo
    total_pruebas = total_pruebas + 1
    si no estadistica.validar_datos_numericos(nulo) entonces
        imprimir "✓ Prueba 2: validar_datos_numericos (nulo) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 2: validar_datos_numericos (nulo) - FALLÓ"
    fin_si
    
    # Prueba 3: validar_datos_numericos con lista vacía
    total_pruebas = total_pruebas + 1
    lista datos_vacios = crear_lista()
    si no estadistica.validar_datos_numericos(datos_vacios) entonces
        imprimir "✓ Prueba 3: validar_datos_numericos (lista vacía) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 3: validar_datos_numericos (lista vacía) - FALLÓ"
    fin_si
    
    # Prueba 4: ordenar_datos
    total_pruebas = total_pruebas + 1
    lista datos_desordenados = crear_lista()
    lista_agregar(datos_desordenados, 3.2)
    lista_agregar(datos_desordenados, 1.1)
    lista_agregar(datos_desordenados, 4.5)
    lista_agregar(datos_desordenados, 2.0)
    
    lista datos_ordenados = estadistica.ordenar_datos(datos_desordenados)
    flotante primero = lista_obtener(datos_ordenados, 0)
    flotante ultimo = lista_obtener(datos_ordenados, lista_tamano(datos_ordenados) - 1)
    
    si primero == 1.1 y ultimo == 4.5 entonces
        imprimir "✓ Prueba 4: ordenar_datos - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 4: ordenar_datos - FALLÓ"
    fin_si
    
    # Prueba 5: ordenar_datos con lista vacía
    total_pruebas = total_pruebas + 1
    lista vacia_ordenada = estadistica.ordenar_datos(crear_lista())
    si lista_tamano(vacia_ordenada) == 0 entonces
        imprimir "✓ Prueba 5: ordenar_datos (lista vacía) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 5: ordenar_datos (lista vacía) - FALLÓ"
    fin_si
    
    imprimir ""
    imprimir "Resultados métodos auxiliares: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas) + " pruebas pasadas"
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para métodos de tendencia central
funcion probar_tendencia_central() retorna entero
    imprimir "=== PRUEBAS DE TENDENCIA CENTRAL ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Prueba 1: Media aritmética
    total_pruebas = total_pruebas + 1
    lista datos1 = crear_lista()
    lista_agregar(datos1, 1.0)
    lista_agregar(datos1, 2.0)
    lista_agregar(datos1, 3.0)
    lista_agregar(datos1, 4.0)
    lista_agregar(datos1, 5.0)
    
    flotante media1 = estadistica.calcular_media_aritmetica(datos1)
    si media1 == 3.0 entonces
        imprimir "✓ Media aritmética básica: " + str_desde_numero(media1)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Media aritmética básica: esperado 3.0, obtenido " + str_desde_numero(media1)
    fin_si
    
    # Prueba 2: Media geométrica
    total_pruebas = total_pruebas + 1
    lista datos2 = crear_lista()
    lista_agregar(datos2, 1.0)
    lista_agregar(datos2, 4.0)
    lista_agregar(datos2, 9.0)
    
    flotante media_geo = estadistica.calcular_media_geometrica(datos2)
    si media_geo > 3.5 y media_geo < 3.6 entonces
        imprimir "✓ Media geométrica: " + str_desde_numero(media_geo)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Media geométrica: esperado ~3.58, obtenido " + str_desde_numero(media_geo)
    fin_si
    
    # Prueba 3: Mediana impar
    total_pruebas = total_pruebas + 1
    flotante mediana1 = estadistica.calcular_mediana(datos1)
    si mediana1 == 3.0 entonces
        imprimir "✓ Mediana impar: " + str_desde_numero(mediana1)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Mediana impar: esperado 3.0, obtenido " + str_desde_numero(mediana1)
    fin_si
    
    # Prueba 4: Mediana par
    total_pruebas = total_pruebas + 1
    lista datos3 = crear_lista()
    lista_agregar(datos3, 1.0)
    lista_agregar(datos3, 2.0)
    lista_agregar(datos3, 3.0)
    lista_agregar(datos3, 4.0)
    
    flotante mediana2 = estadistica.calcular_mediana(datos3)
    si mediana2 == 2.5 entonces
        imprimir "✓ Mediana par: " + str_desde_numero(mediana2)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Mediana par: esperado 2.5, obtenido " + str_desde_numero(mediana2)
    fin_si
    
    # Prueba 5: Moda única
    total_pruebas = total_pruebas + 1
    lista datos4 = crear_lista()
    lista_agregar(datos4, 1.0)
    lista_agregar(datos4, 2.0)
    lista_agregar(datos4, 2.0)
    lista_agregar(datos4, 3.0)
    
    lista modas1 = estadistica.calcular_moda(datos4)
    si lista_tamano(modas1) == 1 y lista_obtener(modas1, 0) == 2.0 entonces
        imprimir "✓ Moda única: " + str_desde_numero(lista_obtener(modas1, 0))
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Moda única: esperado [2.0], obtenido tamaño " + str_desde_numero(lista_tamano(modas1))
    fin_si
    
    imprimir ""
    imprimir "Pruebas de tendencia central: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas)
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para métodos de dispersión
funcion probar_dispersion() retorna entero
    imprimir "=== PRUEBAS DE DISPERSIÓN ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Datos de prueba
    lista datos = crear_lista()
    lista_agregar(datos, 1.0)
    lista_agregar(datos, 2.0)
    lista_agregar(datos, 3.0)
    lista_agregar(datos, 4.0)
    lista_agregar(datos, 5.0)
    
    # Prueba 1: Varianza poblacional
    total_pruebas = total_pruebas + 1
    flotante var_pob = estadistica.calcular_varianza(datos, falso)
    si var_pob > 1.9 y var_pob < 2.1 entonces
        imprimir "✓ Varianza poblacional: " + str_desde_numero(var_pob)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Varianza poblacional: esperado ~2.0, obtenido " + str_desde_numero(var_pob)
    fin_si
    
    # Prueba 2: Desviación estándar
    total_pruebas = total_pruebas + 1
    flotante desv_std = estadistica.calcular_desviacion_estandar(datos, falso)
    si desv_std > 1.4 y desv_std < 1.42 entonces
        imprimir "✓ Desviación estándar: " + str_desde_numero(desv_std)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Desviación estándar: esperado ~1.41, obtenido " + str_desde_numero(desv_std)
    fin_si
    
    # Prueba 3: Rango
    total_pruebas = total_pruebas + 1
    flotante rango = estadistica.calcular_rango(datos)
    si rango == 4.0 entonces
        imprimir "✓ Rango: " + str_desde_numero(rango)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Rango: esperado 4.0, obtenido " + str_desde_numero(rango)
    fin_si
    
    imprimir ""
    imprimir "Pruebas de dispersión: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas)
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para métodos de posición
funcion probar_posicion() retorna entero
    imprimir "=== PRUEBAS DE POSICIÓN ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Datos de prueba
    lista datos = crear_lista()
    lista_agregar(datos, 1.0)
    lista_agregar(datos, 2.0)
    lista_agregar(datos, 3.0)
    lista_agregar(datos, 4.0)
    lista_agregar(datos, 5.0)
    
    # Prueba 1: Percentil 50 (debe ser igual a la mediana)
    total_pruebas = total_pruebas + 1
    flotante p50 = estadistica.calcular_percentil(datos, 50.0)
    si p50 == 3.0 entonces
        imprimir "✓ Percentil 50: " + str_desde_numero(p50)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Percentil 50: esperado 3.0, obtenido " + str_desde_numero(p50)
    fin_si
    
    # Prueba 2: Cuartil Q1
    total_pruebas = total_pruebas + 1
    flotante q1 = estadistica.calcular_cuartil(datos, 1)
    si q1 == 2.0 entonces
        imprimir "✓ Cuartil Q1: " + str_desde_numero(q1)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Cuartil Q1: esperado 2.0, obtenido " + str_desde_numero(q1)
    fin_si
    
    # Prueba 3: Cuartil Q3
    total_pruebas = total_pruebas + 1
    flotante q3 = estadistica.calcular_cuartil(datos, 3)
    si q3 == 4.0 entonces
        imprimir "✓ Cuartil Q3: " + str_desde_numero(q3)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Cuartil Q3: esperado 4.0, obtenido " + str_desde_numero(q3)
    fin_si
    
    imprimir ""
    imprimir "Pruebas de posición: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas)
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para métodos de forma
funcion probar_forma() retorna entero
    imprimir "=== PRUEBAS DE FORMA ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Datos simétricos (distribución normal)
    lista datos_sim = crear_lista()
    lista_agregar(datos_sim, 1.0)
    lista_agregar(datos_sim, 2.0)
    lista_agregar(datos_sim, 3.0)
    lista_agregar(datos_sim, 4.0)
    lista_agregar(datos_sim, 5.0)
    
    # Prueba 1: Asimetría (datos simétricos)
    total_pruebas = total_pruebas + 1
    flotante asimetria = estadistica.calcular_asimetria(datos_sim)
    si asimetria > -0.1 y asimetria < 0.1 entonces
        imprimir "✓ Asimetría (simétrico): " + str_desde_numero(asimetria)
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Asimetría (simétrico): esperado ~0.0, obtenido " + str_desde_numero(asimetria)
    fin_si
    
    imprimir ""
    imprimir "Pruebas de forma: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas)
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para métodos de resumen
funcion probar_resumenes() retorna entero
    imprimir "=== PRUEBAS DE RESÚMENES ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Datos de prueba
    lista datos = crear_lista()
    lista_agregar(datos, 1.0)
    lista_agregar(datos, 2.0)
    lista_agregar(datos, 3.0)
    lista_agregar(datos, 4.0)
    lista_agregar(datos, 5.0)
    
    # Prueba 1: Resumen completo
    total_pruebas = total_pruebas + 1
    mapa resumen = estadistica.resumen_estadistico_completo(datos)
    si mapa_obtener(resumen, "media_aritmetica") != nulo y mapa_obtener(resumen, "mediana") != nulo entonces
        imprimir "✓ Resumen completo contiene claves básicas"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Resumen completo缺少 claves básicas"
    fin_si
    
    # Prueba 2: Resumen cinco números
    total_pruebas = total_pruebas + 1
    mapa cinco_numeros = estadistica.resumen_cinco_numeros(datos)
    si mapa_obtener(cinco_numeros, "minimo") != nulo y mapa_obtener(cinco_numeros, "maximo") != nulo entonces
        imprimir "✓ Resumen cinco números contiene claves básicas"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Resumen cinco números缺少 claves básicas"
    fin_si
    
    imprimir ""
    imprimir "Pruebas de resúmenes: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas)
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Pruebas para calcular_media_aritmetica
funcion probar_media_aritmetica() retorna entero
    imprimir "=== PRUEBAS DE MEDIA ARITMÉTICA ==="
    
    EstadisticaDescriptiva estadistica
    entero pruebas_pasadas = 0
    entero total_pruebas = 0
    
    # Prueba 1: Media de números positivos
    total_pruebas = total_pruebas + 1
    lista datos_positivos = crear_lista()
    lista_agregar(datos_positivos, 2.0)
    lista_agregar(datos_positivos, 4.0)
    lista_agregar(datos_positivos, 6.0)
    
    flotante media_positivos = estadistica.calcular_media_aritmetica(datos_positivos)
    si media_positivos == 4.0 entonces
        imprimir "✓ Prueba 1: media_aritmetica (positivos) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 1: media_aritmetica (positivos) - FALLÓ (esperaba 4.0, obtuve " + str_desde_numero(media_positivos) + ")"
    fin_si
    
    # Prueba 2: Media con números negativos
    total_pruebas = total_pruebas + 1
    lista datos_mixtos = crear_lista()
    lista_agregar(datos_mixtos, -2.0)
    lista_agregar(datos_mixtos, 4.0)
    lista_agregar(datos_mixtos, 0.0)
    
    flotante media_mixtos = estadistica.calcular_media_aritmetica(datos_mixtos)
    si media_mixtos == 0.6666667 entonces
        imprimir "✓ Prueba 2: media_aritmetica (mixtos) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 2: media_aritmetica (mixtos) - FALLÓ (esperaba ~0.667, obtuve " + str_desde_numero(media_mixtos) + ")"
    fin_si
    
    # Prueba 3: Media con lista vacía
    total_pruebas = total_pruebas + 1
    flotante media_vacia = estadistica.calcular_media_aritmetica(crear_lista())
    si media_vacia == "indefinido" entonces
        imprimir "✓ Prueba 3: media_aritmetica (lista vacía) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 3: media_aritmetica (lista vacía) - FALLÓ"
    fin_si
    
    # Prueba 4: Media con nulo
    total_pruebas = total_pruebas + 1
    flotante media_nula = estadistica.calcular_media_aritmetica(nulo)
    si media_nula == "indefinido" entonces
        imprimir "✓ Prueba 4: media_aritmetica (nulo) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 4: media_aritmetica (nulo) - FALLÓ"
    fin_si
    
    # Prueba 5: Media con un solo elemento
    total_pruebas = total_pruebas + 1
    lista dato_simple = crear_lista()
    lista_agregar(dato_simple, 5.0)
    
    flotante media_simple = estadistica.calcular_media_aritmetica(dato_simple)
    si media_simple == 5.0 entonces
        imprimir "✓ Prueba 5: media_aritmetica (un elemento) - PASÓ"
        pruebas_pasadas = pruebas_pasadas + 1
    sino
        imprimir "✗ Prueba 5: media_aritmetica (un elemento) - FALLÓ (esperaba 5.0, obtuve " + str_desde_numero(media_simple) + ")"
    fin_si
    
    imprimir ""
    imprimir "Resultados media aritmética: " + str_desde_numero(pruebas_pasadas) + "/" + str_desde_numero(total_pruebas) + " pruebas pasadas"
    imprimir ""
    
    retornar pruebas_pasadas
fin_funcion

# Función principal para ejecutar todas las pruebas
funcion ejecutar_pruebas() retorna entero
    imprimir "Pruebas internas omitidas. Usa la suite unificada test_analitica_clases.jasb."
    retornar 1
fin_funcion

# =============================================================================
# EXPORTACIÓN DE MÓDULO
# =============================================================================
# Exportar la clase y funciones de prueba
enviar { 
    EstadisticaDescriptiva, 
    ejecutar_pruebas 
}
