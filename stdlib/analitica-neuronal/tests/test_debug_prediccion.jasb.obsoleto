# =============================================================================
# TEST DE DIAGNÓSTICO - PREDICCIÓN
# =============================================================================
# Propósito: Diagnosticar problema de overflow y valores 0.00 en predicciones
# =============================================================================

usar todas de "../analitica.jasb"

principal
    imprimir "=== TEST DE DIAGNÓSTICO - PREDICCIÓN ==="
    imprimir ""

    # Inicializar sistema
    inicializar_fachada()

    # =========================================================================
    # TEST 1: VERIFICAR CONVERSIÓN DE TIPOS
    # =========================================================================
    imprimir "--- TEST 1: CONVERSIÓN DE TIPOS ---"
    entero n_entero = 12
    flotante n_flotante = n_entero + 0.0
    imprimir "n_entero = " + str_desde_numero(n_entero)
    imprimir "n_flotante = " + str_desde_numero(n_flotante)

    entero i = 0
    flotante suma = n_flotante + (i + 0.0)
    imprimir "n_flotante + i = " + str_desde_numero(suma)
    imprimir ""

    # =========================================================================
    # TEST 2: DATOS SIMPLES DE REGRESIÓN
    # =========================================================================
    imprimir "--- TEST 2: REGRESIÓN CON DATOS SIMPLES ---"
    lista X_simple = crear_lista()
    lista Y_simple = crear_lista()

    # X = [0, 1, 2, 3, 4]
    # Y = [10, 20, 30, 40, 50]
    lista_agregar(X_simple, 0.0)
    lista_agregar(X_simple, 1.0)
    lista_agregar(X_simple, 2.0)
    lista_agregar(X_simple, 3.0)
    lista_agregar(X_simple, 4.0)

    lista_agregar(Y_simple, 10.0)
    lista_agregar(Y_simple, 20.0)
    lista_agregar(Y_simple, 30.0)
    lista_agregar(Y_simple, 40.0)
    lista_agregar(Y_simple, 50.0)

    imprimir "X = [0, 1, 2, 3, 4]"
    imprimir "Y = [10, 20, 30, 40, 50]"
    imprimir ""

    mapa modelo = g_analitica.prediccion.regresion_lineal_simple(X_simple, Y_simple)
    flotante m = mapa_obtener(modelo, "pendiente")
    flotante b = mapa_obtener(modelo, "intercepto")
    flotante r2 = mapa_obtener(modelo, "r2")

    imprimir "Resultados del modelo:"
    imprimir "  Pendiente (m) = " + str_desde_numero(m)
    imprimir "  Intercepto (b) = " + str_desde_numero(b)
    imprimir "  R² = " + str_desde_numero(r2)
    imprimir ""

    # Predicción manual
    flotante x_pred = 5.0
    flotante y_pred = (m * x_pred) + b
    imprimir "Predicción para x=5.0:"
    imprimir "  y = " + str_desde_numero(y_pred)
    imprimir "  Esperado: 60.0"
    imprimir ""

    # =========================================================================
    # TEST 3: PREDICCIÓN DE DEMANDA PASO A PASO
    # =========================================================================
    imprimir "--- TEST 3: PREDICCIÓN DE DEMANDA PASO A PASO ---"

    lista historico = crear_lista()
    lista_agregar(historico, 100.0)
    lista_agregar(historico, 110.0)
    lista_agregar(historico, 120.0)
    lista_agregar(historico, 130.0)
    lista_agregar(historico, 140.0)

    imprimir "Histórico: [100, 110, 120, 130, 140]"
    imprimir "Tamaño: " + str_desde_numero(lista_tamano(historico))
    imprimir ""

    # Crear índices manualmente
    lista X_indices = crear_lista()
    entero tam = lista_tamano(historico)
    entero idx = 0
    mientras idx < tam hacer
        flotante valor_idx = idx + 0.0
        lista_agregar(X_indices, valor_idx)
        imprimir "  X[" + str_desde_numero(idx) + "] = " + str_desde_numero(valor_idx)
        idx = idx + 1
    fin_mientras
    imprimir ""

    # Entrenar modelo
    mapa modelo_demanda = g_analitica.prediccion.regresion_lineal_simple(X_indices, historico)
    flotante m_demanda = mapa_obtener(modelo_demanda, "pendiente")
    flotante b_demanda = mapa_obtener(modelo_demanda, "intercepto")

    imprimir "Modelo entrenado:"
    imprimir "  m = " + str_desde_numero(m_demanda)
    imprimir "  b = " + str_desde_numero(b_demanda)
    imprimir ""

    # Predicciones manuales
    imprimir "Predicciones manuales (próximos 3 pasos):"
    flotante tam_flotante = tam + 0.0

    flotante paso_0 = tam_flotante + 0.0
    flotante pred_0 = (m_demanda * paso_0) + b_demanda
    imprimir "  Paso " + str_desde_numero(paso_0) + ": " + str_desde_numero(pred_0)

    flotante paso_1 = tam_flotante + 1.0
    flotante pred_1 = (m_demanda * paso_1) + b_demanda
    imprimir "  Paso " + str_desde_numero(paso_1) + ": " + str_desde_numero(pred_1)

    flotante paso_2 = tam_flotante + 2.0
    flotante pred_2 = (m_demanda * paso_2) + b_demanda
    imprimir "  Paso " + str_desde_numero(paso_2) + ": " + str_desde_numero(pred_2)
    imprimir ""

    # =========================================================================
    # TEST 4: FUNCIÓN DE PREDICCIÓN COMPLETA
    # =========================================================================
    imprimir "--- TEST 4: FUNCIÓN modelo_prediccion_demanda_producto ---"

    mapa resultado_prediccion = g_analitica.prediccion.modelo_prediccion_demanda_producto(historico, 3)
    lista predicciones = mapa_obtener(resultado_prediccion, "predicciones")

    imprimir "Predicciones de la función:"
    entero j = 0
    mientras j < lista_tamano(predicciones) hacer
        flotante val_pred = lista_obtener(predicciones, j)
        imprimir "  Predicción[" + str_desde_numero(j) + "] = " + str_desde_numero(val_pred)
        j = j + 1
    fin_mientras
    imprimir ""

    # =========================================================================
    # TEST 5: VERIFICAR SUMA DE ENTEROS
    # =========================================================================
    imprimir "--- TEST 5: VERIFICAR OPERACIONES ARITMÉTICAS ---"

    entero num_a = 12
    entero num_b = 0
    entero suma_entera = num_a + num_b
    imprimir "Suma entera: " + str_desde_numero(num_a) + " + " + str_desde_numero(num_b) + " = " + str_desde_numero(suma_entera)

    flotante a_float = 12.0
    flotante b_float = 0.0
    flotante suma_float = a_float + b_float
    imprimir "Suma flotante: " + str_desde_numero(a_float) + " + " + str_desde_numero(b_float) + " = " + str_desde_numero(suma_float)

    flotante conversion = num_a + 0.0
    flotante suma_mixta = conversion + b_float
    imprimir "Suma mixta: " + str_desde_numero(conversion) + " + " + str_desde_numero(b_float) + " = " + str_desde_numero(suma_mixta)
    imprimir ""

    # =========================================================================
    # RESUMEN
    # =========================================================================
    imprimir "=== RESUMEN DEL DIAGNÓSTICO ==="
    imprimir ""

    si y_pred > 59.0 y y_pred < 61.0 entonces
        imprimir "✓ Regresión lineal simple: FUNCIONA"
    sino
        imprimir "✗ Regresión lineal simple: FALLA"
    fin_si

    si pred_0 > 149.0 y pred_0 < 151.0 entonces
        imprimir "✓ Predicción manual: FUNCIONA"
    sino
        imprimir "✗ Predicción manual: FALLA"
    fin_si

    flotante primera_pred = lista_obtener(predicciones, 0)
    si primera_pred > 149.0 y primera_pred < 151.0 entonces
        imprimir "✓ Función de predicción: FUNCIONA"
    sino
        imprimir "✗ Función de predicción: FALLA (valor=" + str_desde_numero(primera_pred) + ")"
    fin_si

    imprimir ""
    imprimir "=== FIN DEL DIAGNÓSTICO ==="

fin_principal
