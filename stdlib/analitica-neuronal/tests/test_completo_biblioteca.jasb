# =============================================================================
# TEST COMPLETO - BIBLIOTECA ANALÍTICA-NEURONAL JASBOOT
# =============================================================================
# Este test verifica todas las funcionalidades principales de la biblioteca
# =============================================================================

usar todas de "../analitica.jasb"

principal
    imprimir "╔══════════════════════════════════════════════════════════════╗"
    imprimir "║                                                              ║"
    imprimir "║   TEST COMPLETO - BIBLIOTECA ANALÍTICA-NEURONAL JASBOOT      ║"
    imprimir "║                        Versión 2.0                           ║"
    imprimir "║                                                              ║"
    imprimir "╚══════════════════════════════════════════════════════════════╝"
    imprimir ""

    entero tests_totales = 0
    entero tests_exitosos = 0

    # =========================================================================
    # TEST 1: Estadística Descriptiva
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 1: Estadística Descriptiva"
    imprimir "═══════════════════════════════════════════════════════════════"

    lista datos = crear_lista()
    lista_agregar(datos, 10.0)
    lista_agregar(datos, 20.0)
    lista_agregar(datos, 30.0)
    lista_agregar(datos, 40.0)
    lista_agregar(datos, 50.0)

    tests_totales = tests_totales + 1
    flotante media = g_analitica.estadistica.calcular_media_aritmetica(datos)
    imprimir "✓ Media aritmética: " + str_desde_numero(media)
    si media == 30.0 entonces
        imprimir "  ✅ CORRECTO: Media = 30.0"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Se esperaba 30.0"
    fin_si

    tests_totales = tests_totales + 1
    flotante desv_std = g_analitica.estadistica.calcular_desviacion_estandar(datos)
    imprimir "✓ Desviación estándar: " + str_desde_numero(desv_std)
    si desv_std > 14.0 y desv_std < 16.0 entonces
        imprimir "  ✅ CORRECTO: Desviación ≈ 15.0"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Valor fuera de rango esperado"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 2: Regresión Lineal Simple
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 2: Regresión Lineal Simple"
    imprimir "═══════════════════════════════════════════════════════════════"

    lista X = crear_lista()
    lista_agregar(X, 1.0)
    lista_agregar(X, 2.0)
    lista_agregar(X, 3.0)
    lista_agregar(X, 4.0)
    lista_agregar(X, 5.0)

    lista y = crear_lista()
    lista_agregar(y, 2.0)
    lista_agregar(y, 4.0)
    lista_agregar(y, 6.0)
    lista_agregar(y, 8.0)
    lista_agregar(y, 10.0)

    tests_totales = tests_totales + 1
    mapa modelo = g_analitica.prediccion.regresion_lineal_simple(X, y)
    flotante pendiente = mapa_obtener(modelo, "pendiente")
    flotante intercepto = mapa_obtener(modelo, "intercepto")

    imprimir "✓ Pendiente: " + str_desde_numero(pendiente)
    imprimir "✓ Intercepto: " + str_desde_numero(intercepto)

    si pendiente > 1.9 y pendiente < 2.1 entonces
        imprimir "  ✅ CORRECTO: Pendiente ≈ 2.0 (y = 2x)"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Pendiente incorrecta"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 3: Train/Test Split
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 3: Validación - Train/Test Split"
    imprimir "═══════════════════════════════════════════════════════════════"

    lista datos_X = crear_lista()
    lista datos_y = crear_lista()
    entero i = 0
    mientras i < 100 hacer
        lista_agregar(datos_X, i + 0.0)
        lista_agregar(datos_y, (i * 2.0) + 1.0)
        i = i + 1
    fin_mientras

    tests_totales = tests_totales + 1
    mapa split = g_analitica.validacion.train_test_split(datos_X, datos_y, 0.2, 42)
    lista X_train = mapa_obtener(split, "X_train")
    lista X_test = mapa_obtener(split, "X_test")
    lista y_train = mapa_obtener(split, "y_train")
    lista y_test = mapa_obtener(split, "y_test")

    entero n_train = lista_tamano(X_train)
    entero n_test = lista_tamano(X_test)

    imprimir "✓ Tamaño train: " + str_desde_numero(n_train)
    imprimir "✓ Tamaño test: " + str_desde_numero(n_test)

    si n_train == 80 y n_test == 20 entonces
        imprimir "  ✅ CORRECTO: Split 80/20"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Split incorrecto"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 4: Normalización de Datos
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 4: Normalización - Min-Max Scaler"
    imprimir "═══════════════════════════════════════════════════════════════"

    lista datos_norm = crear_lista()
    lista_agregar(datos_norm, 10.0)
    lista_agregar(datos_norm, 50.0)
    lista_agregar(datos_norm, 100.0)

    tests_totales = tests_totales + 1
    mapa scaler = g_analitica.normalizacion.min_max_scaler_fit(datos_norm)
    lista datos_normalizados = g_analitica.normalizacion.min_max_scaler_transform(datos_norm, scaler)

    flotante primer_norm = lista_obtener(datos_normalizados, 0)
    flotante ultimo_norm = lista_obtener(datos_normalizados, 2)

    imprimir "✓ Primer valor normalizado: " + str_desde_numero(primer_norm)
    imprimir "✓ Último valor normalizado: " + str_desde_numero(ultimo_norm)

    si primer_norm == 0.0 y ultimo_norm == 1.0 entonces
        imprimir "  ✅ CORRECTO: Normalización [0, 1]"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Normalización incorrecta"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 5: Predicción con Modelo Entrenado
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 5: Predicción con Modelo Entrenado"
    imprimir "═══════════════════════════════════════════════════════════════"

    tests_totales = tests_totales + 1

    # Usar el modelo entrenado anteriormente para predecir
    flotante nuevo_x = 6.0
    flotante prediccion = (pendiente * nuevo_x) + intercepto
    flotante valor_esperado = 12.0  # y = 2x, entonces 2*6 = 12

    imprimir "✓ Predicción para x=6: " + str_desde_numero(prediccion)
    imprimir "✓ Valor esperado: " + str_desde_numero(valor_esperado)

    flotante diferencia = prediccion - valor_esperado
    si diferencia < 0.0 entonces
        diferencia = 0.0 - diferencia
    fin_si

    si diferencia < 0.5 entonces
        imprimir "  ✅ CORRECTO: Predicción cercana al valor esperado"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Predicción incorrecta"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 6: K-Means Clustering
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 6: Clustering - K-Means"
    imprimir "═══════════════════════════════════════════════════════════════"

    lista puntos = crear_lista()
    lista_agregar(puntos, 1.0)
    lista_agregar(puntos, 2.0)
    lista_agregar(puntos, 10.0)
    lista_agregar(puntos, 11.0)
    lista_agregar(puntos, 20.0)
    lista_agregar(puntos, 21.0)

    tests_totales = tests_totales + 1
    mapa resultado_kmeans = g_analitica.ml.kmeans_1d(puntos, 3)
    lista centroides = mapa_obtener(resultado_kmeans, "centroides")

    entero n_centroides = lista_tamano(centroides)
    imprimir "✓ Número de centroides: " + str_desde_numero(n_centroides)

    si n_centroides == 3 entonces
        imprimir "  ✅ CORRECTO: 3 clusters encontrados"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Número de clusters incorrecto"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 7: Probabilidad
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 7: Distribuciones de Probabilidad"
    imprimir "═══════════════════════════════════════════════════════════════"

    tests_totales = tests_totales + 1
    flotante prob_normal = g_analitica.probabilidad.normal_pdf(0.0, 0.0, 1.0)
    flotante prob_binomial = g_analitica.probabilidad.binomial_pmf(3, 10, 0.5)

    imprimir "✓ Normal PDF(0, 0, 1): " + str_desde_numero(prob_normal)
    imprimir "✓ Binomial PMF(3, 10, 0.5): " + str_desde_numero(prob_binomial)

    si prob_normal > 0.3 y prob_normal < 0.5 entonces
        imprimir "  ✅ CORRECTO: Normal PDF ≈ 0.399"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Probabilidad incorrecta"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 8: Varianza y Covarianza
    # =========================================================================
    imprimir "═══════════════════════════════════════════════════════════════"
    imprimir "TEST 8: Varianza de los Datos"
    imprimir "═══════════════════════════════════════════════════════════════"

    tests_totales = tests_totales + 1
    flotante varianza = g_analitica.estadistica.calcular_varianza(datos, verdadero)

    imprimir "✓ Varianza: " + str_desde_numero(varianza)

    si varianza > 150.0 y varianza < 250.0 entonces
        imprimir "  ✅ CORRECTO: Varianza calculada (≈200)"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ❌ ERROR: Varianza fuera de rango esperado"
    fin_si
    imprimir ""

    # =========================================================================
    # RESUMEN FINAL
    # =========================================================================
    imprimir ""
    imprimir "╔══════════════════════════════════════════════════════════════╗"
    imprimir "║                    RESUMEN DE TESTS                          ║"
    imprimir "╚══════════════════════════════════════════════════════════════╝"
    imprimir ""
    imprimir "Total de tests: " + str_desde_numero(tests_totales)
    imprimir "Tests exitosos: " + str_desde_numero(tests_exitosos)
    imprimir "Tests fallidos: " + str_desde_numero(tests_totales - tests_exitosos)
    imprimir ""

    flotante porcentaje = (tests_exitosos + 0.0) / (tests_totales + 0.0) * 100.0
    imprimir "Porcentaje de éxito: " + str_desde_numero(porcentaje) + "%"
    imprimir ""

    si tests_exitosos == tests_totales entonces
        imprimir "╔══════════════════════════════════════════════════════════════╗"
        imprimir "║                                                              ║"
        imprimir "║              ✅ TODOS LOS TESTS PASARON ✅                   ║"
        imprimir "║                                                              ║"
        imprimir "║       LA BIBLIOTECA ESTÁ 100% FUNCIONAL Y LISTA              ║"
        imprimir "║                                                              ║"
        imprimir "╚══════════════════════════════════════════════════════════════╝"
    sino
        imprimir "⚠️  ADVERTENCIA: Algunos tests fallaron"
        imprimir "    Por favor revise los resultados anteriores"
    fin_si
    imprimir ""

fin_principal
