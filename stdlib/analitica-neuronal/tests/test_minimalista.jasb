# =============================================================================
# TEST MINIMALISTA - BIBLIOTECA ANALÍTICA-NEURONAL
# =============================================================================
# Test simple que verifica funcionalidades básicas garantizadas
# =============================================================================

usar todas de "../estadistica/estadistica_descriptiva.jasb"

principal
    imprimir "╔════════════════════════════════════════════════════════╗"
    imprimir "║  TEST MINIMALISTA - BIBLIOTECA ANALÍTICA-NEURONAL     ║"
    imprimir "║                   Versión 2.0                          ║"
    imprimir "╚════════════════════════════════════════════════════════╝"
    imprimir ""

    entero tests_ok = 0
    entero tests_total = 0

    # =========================================================================
    # TEST 1: Media Aritmética
    # =========================================================================
    imprimir "TEST 1: Cálculo de Media Aritmética"
    lista datos = crear_lista()
    lista_agregar(datos, 10.0)
    lista_agregar(datos, 20.0)
    lista_agregar(datos, 30.0)

    flotante media = calcular_media_aritmetica(datos)
    imprimir "  Datos: [10, 20, 30]"
    imprimir "  Media calculada: " + str_desde_numero(media)
    imprimir "  Media esperada: 20.0"

    tests_total = tests_total + 1
    si media == 20.0 entonces
        imprimir "  ✅ CORRECTO"
        tests_ok = tests_ok + 1
    sino
        imprimir "  ❌ ERROR"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 2: Desviación Estándar
    # =========================================================================
    imprimir "TEST 2: Desviación Estándar"
    flotante desv = calcular_desviacion_estandar(datos)
    imprimir "  Desviación calculada: " + str_desde_numero(desv)
    imprimir "  Rango esperado: 8.0 - 12.0"

    tests_total = tests_total + 1
    si desv > 8.0 y desv < 12.0 entonces
        imprimir "  ✅ CORRECTO"
        tests_ok = tests_ok + 1
    sino
        imprimir "  ❌ ERROR"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 3: Mediana
    # =========================================================================
    imprimir "TEST 3: Cálculo de Mediana"
    flotante mediana = calcular_mediana(datos)
    imprimir "  Datos: [10, 20, 30]"
    imprimir "  Mediana calculada: " + str_desde_numero(mediana)
    imprimir "  Mediana esperada: 20.0"

    tests_total = tests_total + 1
    si mediana == 20.0 entonces
        imprimir "  ✅ CORRECTO"
        tests_ok = tests_ok + 1
    sino
        imprimir "  ❌ ERROR"
    fin_si
    imprimir ""

    # =========================================================================
    # TEST 4: Varianza
    # =========================================================================
    imprimir "TEST 4: Cálculo de Varianza"
    flotante varianza = calcular_varianza(datos, verdadero)
    imprimir "  Varianza calculada: " + str_desde_numero(varianza)
    imprimir "  Rango esperado: 50.0 - 150.0"

    tests_total = tests_total + 1
    si varianza > 50.0 y varianza < 150.0 entonces
        imprimir "  ✅ CORRECTO"
        tests_ok = tests_ok + 1
    sino
        imprimir "  ❌ ERROR"
    fin_si
    imprimir ""

    # =========================================================================
    # RESUMEN FINAL
    # =========================================================================
    imprimir "════════════════════════════════════════════════════════"
    imprimir "               RESUMEN DE RESULTADOS"
    imprimir "════════════════════════════════════════════════════════"
    imprimir ""
    imprimir "  Tests ejecutados: " + str_desde_numero(tests_total)
    imprimir "  Tests exitosos:   " + str_desde_numero(tests_ok)
    imprimir "  Tests fallidos:   " + str_desde_numero(tests_total - tests_ok)
    imprimir ""

    si tests_ok == tests_total entonces
        imprimir "╔════════════════════════════════════════════════════════╗"
        imprimir "║                                                        ║"
        imprimir "║         ✅ TODOS LOS TESTS PASARON ✅                  ║"
        imprimir "║                                                        ║"
        imprimir "║   La biblioteca está funcional y lista para usar      ║"
        imprimir "║                                                        ║"
        imprimir "╚════════════════════════════════════════════════════════╝"
    sino
        flotante porcentaje = (tests_ok + 0.0) / (tests_total + 0.0) * 100.0
        imprimir "⚠️  Porcentaje de éxito: " + str_desde_numero(porcentaje) + "%"
        imprimir ""
        imprimir "Algunos tests fallaron. Revise los resultados anteriores."
    fin_si
    imprimir ""

fin_principal
