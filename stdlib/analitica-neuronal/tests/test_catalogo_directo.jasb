# =============================================================================
# TEST CATÁLOGO - ACCESO DIRECTO A MÓDULOS
# =============================================================================
# Propósito: Validar funcionalidades sin usar fachada para evitar errores
# =============================================================================

# Importaciones directas
usar { EstadisticaDescriptiva } de "../estadistica/estadistica_descriptiva.jasb"
usar { Probabilidad } de "../probabilidad/probabilidad_basica.jasb"
usar { MachineLearning } de "../machine_learning/algoritmos_ml.jasb"
usar { SeriesTemporales } de "../series_temporales/analisis_series_temporales.jasb"
usar { ProcesadorLenguajeNatural } de "../machine_learning/nlp_basico.jasb"
usar { InferenciaEstadistica } de "../inferencia/inferencia_estadistica.jasb"

principal
    imprimir "=== TEST CATÁLOGO - ACCESO DIRECTO ==="
    
    entero tests_totales = 0
    entero tests_exitosos = 0
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: ESTADÍSTICA"
    imprimir "=========================================="
    
    # Crear instancia
    EstadisticaDescriptiva estadistica = EstadisticaDescriptiva()
    estadistica.inicializar()
    
    # Test 1: Media Aritmética
    tests_totales = tests_totales + 1
    lista datos_estadistica = crear_lista()
    lista_agregar(datos_estadistica, 10.0)
    lista_agregar(datos_estadistica, 20.0)
    lista_agregar(datos_estadistica, 30.0)
    
    flotante media = estadistica.calcular_media_aritmetica(datos_estadistica)
    imprimir "Media aritmética: " + str_desde_numero(media)
    si media == 20.0 entonces
        imprimir "  EXITO: Media correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Media incorrecta"
    fin_si
    
    # Test 2: Mediana
    tests_totales = tests_totales + 1
    flotante mediana = estadistica.calcular_mediana(datos_estadistica)
    imprimir "Mediana: " + str_desde_numero(mediana)
    si mediana == 20.0 entonces
        imprimir "  EXITO: Mediana correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Mediana incorrecta"
    fin_si
    
    # Test 3: Desviación Estándar
    tests_totales = tests_totales + 1
    flotante desv_std = estadistica.calcular_desviacion_estandar(datos_estadistica, falso)
    imprimir "Desviación estándar: " + str_desde_numero(desv_std)
    si desv_std > 8.0 y desv_std < 9.0 entonces
        imprimir "  EXITO: Desviación estándar correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Desviación estándar incorrecta"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: PROBABILIDAD"
    imprimir "=========================================="
    
    # Crear instancia
    Probabilidad probabilidad = Probabilidad()
    probabilidad.inicializar()
    
    # Test 4: Factorial
    tests_totales = tests_totales + 1
    entero factorial_5 = probabilidad.factorial(5)
    imprimir "Factorial de 5: " + str_desde_numero(factorial_5)
    si factorial_5 == 120 entonces
        imprimir "  EXITO: Factorial correcto"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Factorial incorrecto"
    fin_si
    
    # Test 5: Combinaciones
    tests_totales = tests_totales + 1
    entero combinaciones = probabilidad.combinaciones(5, 2)
    imprimir "Combinaciones C(5,2): " + str_desde_numero(combinaciones)
    si combinaciones == 10 entonces
        imprimir "  EXITO: Combinaciones correctas"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Combinaciones incorrectas"
    fin_si
    
    # Test 6: Distribución Normal PDF
    tests_totales = tests_totales + 1
    flotante normal_pdf = probabilidad.normal_pdf(0.0, 0.0, 1.0)
    imprimir "Normal PDF(0,0,1): " + str_desde_numero(normal_pdf)
    si normal_pdf > 0.3 y normal_pdf < 0.5 entonces
        imprimir "  EXITO: Normal PDF correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Normal PDF incorrecta"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: MACHINE LEARNING"
    imprimir "=========================================="
    
    # Crear instancia
    MachineLearning ml = MachineLearning()
    ml.inicializar()
    
    # Test 7: K-Means
    tests_totales = tests_totales + 1
    lista datos_kmeans = crear_lista()
    lista_agregar(datos_kmeans, 1.0)
    lista_agregar(datos_kmeans, 2.0)
    lista_agregar(datos_kmeans, 8.0)
    lista_agregar(datos_kmeans, 9.0)
    lista_agregar(datos_kmeans, 15.0)
    lista_agregar(datos_kmeans, 16.0)
    
    mapa resultado_kmeans = ml.kmeans_1d(datos_kmeans, 3)
    lista centroides_km = mapa_obtener(resultado_kmeans, "centroides")
    entero n_clusters = lista_tamano(centroides_km)
    imprimir "K-Means clustering: " + str_desde_numero(n_clusters) + " clusters"
    si n_clusters == 3 entonces
        imprimir "  EXITO: K-Means funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: K-Means no funcional"
    fin_si
    
    # Test 8: KNN Regresión
    tests_totales = tests_totales + 1
    lista X_train = crear_lista()
    lista_agregar(X_train, 1.0)
    lista_agregar(X_train, 2.0)
    lista_agregar(X_train, 3.0)
    
    lista y_train = crear_lista()
    lista_agregar(y_train, 2.0)
    lista_agregar(y_train, 4.0)
    lista_agregar(y_train, 6.0)
    
    flotante knn_pred = ml.knn_regresion_1d(X_train, y_train, 2.0, 1)
    imprimir "KNN Regresión (x=2.0): " + str_desde_numero(knn_pred)
    si knn_pred == 4.0 entonces
        imprimir "  EXITO: KNN Regresión correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: KNN Regresión incorrecta (esperaba 4.0)"
    fin_si
    
    # Test 9: Distancia Euclidiana
    tests_totales = tests_totales + 1
    lista punto_a = crear_lista()
    lista_agregar(punto_a, 0.0)
    lista_agregar(punto_a, 0.0)
    
    lista punto_b = crear_lista()
    lista_agregar(punto_b, 3.0)
    lista_agregar(punto_b, 4.0)
    
    flotante distancia = ml.distancia_euclidiana(punto_a, punto_b)
    imprimir "Distancia euclidiana: " + str_desde_numero(distancia)
    si distancia == 5.0 entonces
        imprimir "  EXITO: Distancia euclidiana correcta"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Distancia euclidiana incorrecta"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: SERIES TEMPORALES"
    imprimir "=========================================="
    
    # Crear instancia
    SeriesTemporales series = SeriesTemporales()
    series.inicializar()
    
    # Test 10: Media Móvil Simple
    tests_totales = tests_totales + 1
    lista datos_series = crear_lista()
    lista_agregar(datos_series, 10.0)
    lista_agregar(datos_series, 20.0)
    lista_agregar(datos_series, 30.0)
    lista_agregar(datos_series, 40.0)
    lista_agregar(datos_series, 50.0)
    
    lista media_movil = series.media_movil_simple(datos_series, 3)
    imprimir "Media móvil (ventana=3): " + str_desde_numero(lista_tamano(media_movil)) + " puntos"
    si lista_tamano(media_movil) > 0 entonces
        imprimir "  EXITO: Media móvil funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Media móvil no funcional"
    fin_si
    
    # Test 11: Suavizamiento Exponencial Simple
    tests_totales = tests_totales + 1
    lista suavizamiento = series.suavizamiento_exponencial_simple(datos_series, 0.3)
    imprimir "Suavizamiento exponencial: " + str_desde_numero(lista_tamano(suavizamiento)) + " puntos"
    si lista_tamano(suavizamiento) > 0 entonces
        imprimir "  EXITO: Suavizamiento exponencial funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Suavizamiento exponencial no funcional"
    fin_si
    
    # Test 12: Autocorrelación
    tests_totales = tests_totales + 1
    flotante autocorr = series.autocorrelacion(datos_series, 1)
    imprimir "Autocorrelación (lag=1): " + str_desde_numero(autocorr)
    si autocorr >= 0.0 y autocorr <= 1.0 entonces
        imprimir "  EXITO: Autocorrelación funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Autocorrelación no funcional"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: NLP"
    imprimir "=========================================="
    
    # Crear instancia
    ProcesadorLenguajeNatural nlp = ProcesadorLenguajeNatural()
    nlp.inicializar()
    
    # Test 13: Tokenización
    tests_totales = tests_totales + 1
    texto texto_nlp = "hola mundo esto es una prueba"
    lista tokens = nlp.tokenizar(texto_nlp)
    imprimir "Tokenización: " + str_desde_numero(lista_tamano(tokens)) + " tokens"
    si lista_tamano(tokens) > 0 entonces
        imprimir "  EXITO: Tokenización funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Tokenización no funcional"
    fin_si
    
    # Test 14: Bag of Words
    tests_totales = tests_totales + 1
    lista vocabulario = crear_lista()
    lista_agregar(vocabulario, "hola")
    lista_agregar(vocabulario, "mundo")
    lista_agregar(vocabulario, "esto")
    
    lista bow = nlp.bag_of_words(tokens, vocabulario)
    imprimir "Bag of Words: " + str_desde_numero(lista_tamano(bow)) + " dimensiones"
    si lista_tamano(bow) > 0 entonces
        imprimir "  EXITO: Bag of Words funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Bag of Words no funcional"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "MÓDULO: INFERENCIA"
    imprimir "=========================================="
    
    # Crear instancia
    InferenciaEstadistica inferencia = InferenciaEstadistica()
    inferencia.inicializar()
    
    # Test 15: Correlación de Pearson
    tests_totales = tests_totales + 1
    lista x_pearson = crear_lista()
    lista_agregar(x_pearson, 1.0)
    lista_agregar(x_pearson, 2.0)
    lista_agregar(x_pearson, 3.0)
    
    lista y_pearson = crear_lista()
    lista_agregar(y_pearson, 2.0)
    lista_agregar(y_pearson, 4.0)
    lista_agregar(y_pearson, 6.0)
    
    flotante correlacion = inferencia.correlacion_pearson(x_pearson, y_pearson)
    imprimir "Correlación de Pearson: " + str_desde_numero(correlacion)
    si correlacion >= 0.9 y correlacion <= 1.0 entonces
        imprimir "  EXITO: Correlación de Pearson funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Correlación de Pearson no funcional"
    fin_si
    
    # Test 16: Intervalo de Confianza
    tests_totales = tests_totales + 1
    mapa intervalo = inferencia.intervalo_confianza_media(datos_estadistica, 0.95)
    flotante ic_inf = mapa_obtener(intervalo, "limite_inferior")
    imprimir "Intervalo de confianza (Linf): " + str_desde_numero(ic_inf)
    si ic_inf != nulo entonces
        imprimir "  EXITO: Intervalo de confianza funcional"
        tests_exitosos = tests_exitosos + 1
    sino
        imprimir "  ERROR: Intervalo de confianza no funcional"
    fin_si
    
    imprimir ""
    imprimir "=========================================="
    imprimir "RESUMEN FINAL"
    imprimir "=========================================="
    
    imprimir "Tests totales: " + str_desde_numero(tests_totales)
    imprimir "Tests exitosos: " + str_desde_numero(tests_exitosos)
    imprimir "Tests fallidos: " + str_desde_numero(tests_totales - tests_exitosos)
    
    flotante porcentaje = (tests_exitosos + 0.0) / (tests_totales + 0.0) * 100.0
    imprimir "Tasa de éxito: " + str_desde_numero(porcentaje) + "%"
    
    imprimir ""
    imprimir "=== ESTADO GENERAL DE LA LIBRERÍA ==="
    si porcentaje >= 80.0 entonces
        imprimir "ESTADO: EXCELENTE - Librería muy funcional"
    sino si porcentaje >= 60.0 entonces
        imprimir "ESTADO: BUENO - Librería funcional con algunos problemas"
    sino si porcentaje >= 40.0 entonces
        imprimir "ESTADO: REGULAR - Librería parcialmente funcional"
    sino
        imprimir "ESTADO: CRÍTICO - Librería mayormente no funcional"
    fin_si
    
    imprimir ""
    imprimir "=== TEST COMPLETADO ==="
    
fin_principal
