    bytes url_bytes = bytes_desde_texto(direccion_url)
    entero dll = ffi_cargar("sdk-dependiente/jasboot-win32-bridge/bin/jasboot_win32_bridge.dll")
    entero fn = ffi_simbolo(dll, "jbw_webview_crear")
    retornar ffi_llamar(fn, app, bytes_puntero(url_bytes), bytes_tamano(url_bytes), 0)
fin_funcion

