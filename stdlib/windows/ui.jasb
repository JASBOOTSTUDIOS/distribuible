enviar funcion windows_rgb(entero rojo, entero verde, entero azul) retorna entero
    retornar rojo + verde * 256 + azul * 65536
fin_funcion

enviar funcion windows_app_crear(texto titulo, entero ancho, entero alto) retorna entero
    bytes titulo_bytes = bytes_desde_texto(titulo)
    entero dll = ffi_cargar("sdk-dependiente/jasboot-win32-bridge/bin/jasboot_win32_bridge.dll")
    entero fn = ffi_simbolo(dll, "jbw_ventana_crear")
    retornar ffi_llamar(fn, bytes_puntero(titulo_bytes), bytes_tamano(titulo_bytes), ancho, alto)
fin_funcion

enviar funcion windows_panel(entero app) retorna entero
    entero dll = ffi_cargar("sdk-dependiente/jasboot-win32-bridge/bin/jasboot_win32_bridge.dll")
    entero fn = ffi_simbolo(dll, "jbw_panel_crear")
    retornar ffi_llamar(fn, app, 0, 0, 0)
fin_funcion

