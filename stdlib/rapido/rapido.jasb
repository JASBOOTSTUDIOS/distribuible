fin_funcion

enviar funcion rapido_registrar_ruta(texto metodo, texto patron, funcion manejador) retorna entero
    texto patron_efectivo = patron
    si longitud_texto(rapido_prefijo_montaje) > 0 entonces
        patron_efectivo = rapido_unir_ruta_montaje(rapido_prefijo_montaje, patron)
    fin_si
    mem_lista_agregar(rapido_lst_metodo, metodo)
    mem_lista_agregar(rapido_lst_patron, patron_efectivo)
    entero k = mem_lista_tamano(rapido_lst_patron)
    mapa_poner(rapido_m_rutas, k, manejador)
    retornar k
fin_funcion

enviar funcion rapido_get(texto patron, funcion manejador) retorna entero
    retornar rapido_registrar_ruta("GET", patron, manejador)
fin_funcion

enviar funcion rapido_post(texto patron, funcion manejador) retorna entero
    retornar rapido_registrar_ruta("POST", patron, manejador)
fin_funcion

enviar funcion rapido_put(texto patron, funcion manejador) retorna entero
    retornar rapido_registrar_ruta("PUT", patron, manejador)
fin_funcion

enviar funcion rapido_borrar(texto patron, funcion manejador) retorna entero
    retornar rapido_registrar_ruta("DELETE", patron, manejador)
fin_funcion

enviar funcion rapido_dispatch(texto sol) retorna texto
    rapido_linea_cache = http_extraer_linea_inicial(sol)
    rapido_j_doc = 0
    rapido_j_listo = 0
    entero mwi = 1
    mientras mwi <= rapido_n_mw hacer
        funcion mw_fn = mapa_obtener(rapido_m_mw, mwi)
        texto res_mw = mw_fn(sol)
        si longitud_texto(res_mw) > 0 entonces
            retornar res_mw
        fin_si
        mwi = mwi + 1
    fin_mientras
    texto met = http_metodo_desde_linea(rapido_linea_cache)
    texto path = rapido_ruta_limpia(http_ruta_desde_linea(rapido_linea_cache))
    entero n = mem_lista_tamano(rapido_lst_metodo)
    entero ri = 0
    mientras ri < n hacer
        si mem_lista_obtener(rapido_lst_metodo, ri) == met entonces
            texto pat = mem_lista_obtener(rapido_lst_patron, ri)
            si pat == path entonces
                funcion h0 = mapa_obtener(rapido_m_rutas, ri + 1)
                retornar h0(sol)
            fin_si
            si rapido_patron_coincide(path, pat) == 1 entonces
                funcion h = mapa_obtener(rapido_m_rutas, ri + 1)
                retornar h(sol)
            fin_si
        fin_si
        ri = ri + 1
    fin_mientras
    retornar rapido_no_encontrado_respuesta()
fin_funcion

// Servidor secuencial: una peticion en vuelo a la vez; el handler no debe bloquear minutos
// (p. ej. cliente HTTPS con timeouts razonables) o las demas conexiones esperan en cola.
enviar funcion rapido_escuchar(texto host, entero puerto, entero max_solicitudes) retorna entero
    retornar api_http_bucle(host, puerto, max_solicitudes, rapido_dispatch)
fin_funcion

// Varias instancias del mismo .jbo en puertos consecutivos (maestro en puerto_base, hijos en +1..+N-1).
// Cada instancia es un proceso VM independiente (mismo paralelismo que varios workers de Node).
// El hijo debe arrancarse con argv: ... <puerto> jasboot_cluster_worker (evita recursión).
// En Windows hace falta que sys_argv(0) sea el ejecutable de la VM (no "node" vía wrapper).
enviar funcion rapido_escuchar_cluster(texto host, entero puerto_base, entero num_workers, entero max_solicitudes) retorna entero
    si sys_argc() >= 4 entonces
        si sys_argv(3) == "jasboot_cluster_worker" entonces
            retornar rapido_escuchar(host, puerto_base, max_solicitudes)
        fin_si
    fin_si
    si num_workers <= 1 entonces
        retornar rapido_escuchar(host, puerto_base, max_solicitudes)
    fin_si
    texto exe = sys_argv(0)
    texto jbo = sys_argv(1)
    entero w = 1
    mientras w < num_workers hacer
        entero p = puerto_base + w
        texto cmd = ""
        si contiene_texto(exe, ".exe") == 1 o contiene_texto(exe, ".EXE") == 1 entonces
            cmd = "start /B \"\" \""
            cmd = concatenar(cmd, exe)
            cmd = concatenar(cmd, "\" \"")
            cmd = concatenar(cmd, jbo)
            cmd = concatenar(cmd, "\" ")
            cmd = concatenar(cmd, str_desde_numero(p))
            cmd = concatenar(cmd, " jasboot_cluster_worker")
        sino
            cmd = "\""
            cmd = concatenar(cmd, exe)
            cmd = concatenar(cmd, "\" \"")
            cmd = concatenar(cmd, jbo)
            cmd = concatenar(cmd, "\" ")
            cmd = concatenar(cmd, str_desde_numero(p))
            cmd = concatenar(cmd, " jasboot_cluster_worker &")
        fin_si
        sistema_ejecutar(cmd)
        w = w + 1
    fin_mientras
    retornar rapido_escuchar(host, puerto_base, max_solicitudes)
fin_funcion

