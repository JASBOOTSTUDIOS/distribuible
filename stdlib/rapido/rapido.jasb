usar todas de "..\\api\\api_basica.jasb"

// =============================================================================
// rapido — modelo alineado con Express (en español), optimizado para Jasboot
// =============================================================================
//
// Express                          | rapido (español)           | estilo Express (alias)
// ---------------------------------+----------------------------+---------------------------
// express() → app                  | (estado global)            | express() — no-op marcador
// app.use(fn)                      | aplicacion_usar(fn)        | app_use(fn)
// app.get/post/put/delete(path,fn) | aplicacion_obtener/...     | app_get, app_post, …
// app.listen(puerto)             | aplicacion_escuchar        | app_listen(puerto)
// app.use(express.json())          | aplicacion_parsear_json()  | express_json() — registra ya
// app.use(cors())                  | aplicacion_permitir_cors() | express_cors()
// res.json({})                     | respuesta_cuerpo_json      | res_json(texto)
// req.params.id                    | peticion_parametro         | req_param
// next()                           | intermediario_continuar    | express_next
// Router en /api                   | montar_rutas … desmontar  | router_montar / router_fin
//
// Limites de Jasboot: no hay app.metodo con punto; no hay (req,res)=> ni express.json() que
// devuelva una funcion — los *middleware* reales son intermediario_* para pasarlos a app_use.
//
// Intermediario (middleware): funcion (texto solicitud) retorna texto.
//   Cadena vacía = pasar al siguiente (equivalente a next()).
//   Texto no vacío = respuesta HTTP completa (fin de la cadena).
//
// Rendimiento: una lectura de la línea inicial por petición, rutas exactas sin dividir_texto,
// lectura de cuerpo POST sin copiar el cuerpo entero solo para medir longitud (api_basica).
// =============================================================================

// Prefijo activo para registrar rutas (estilo app.use("/api", router) de Express).
enviar texto rapido_prefijo_montaje = ""

enviar lista rapido_lst_metodo = mem_lista_crear()
enviar lista rapido_lst_patron = mem_lista_crear()
enviar mapa rapido_m_rutas = mapa_crear()
enviar entero rapido_n_mw = 0
enviar mapa rapido_m_mw = mapa_crear()
enviar lista rapido_lst_cap_nom = mem_lista_crear()
enviar lista rapido_lst_cap_val = mem_lista_crear()
enviar entero rapido_j_doc = 0
enviar entero rapido_j_listo = 0
// Primera linea HTTP de la peticion actual; la rellena rapido_dispatch antes del middleware.
enviar texto rapido_linea_cache = ""

enviar funcion rapido_nombre() retorna texto
    retornar "rapido"
fin_funcion

enviar funcion rapido_ruta_limpia(texto ruta) retorna texto
    si contiene_texto(ruta, "?") == 1 entonces
        retornar extraer_antes_de(ruta, "?")
    fin_si
    retornar ruta
fin_funcion

enviar funcion rapido_solicitud_metodo(texto sol) retorna texto
    retornar api_metodo(sol)
fin_funcion

enviar funcion rapido_solicitud_ruta(texto sol) retorna texto
    retornar api_ruta(sol)
fin_funcion

enviar funcion rapido_limpiar() retorna entero
    mem_lista_limpiar(rapido_lst_metodo)
    mem_lista_limpiar(rapido_lst_patron)
    rapido_m_rutas = mapa_crear()
    rapido_n_mw = 0
    rapido_m_mw = mapa_crear()
    mem_lista_limpiar(rapido_lst_cap_nom)
    mem_lista_limpiar(rapido_lst_cap_val)
    rapido_j_doc = 0
    rapido_j_listo = 0
    rapido_prefijo_montaje = ""
    retornar 1
fin_funcion

// Une prefijo de montaje y subruta como hace Express (p. ej. "/api" + "/salud" -> "/api/salud").
enviar funcion rapido_unir_ruta_montaje(texto prefijo, texto sub) retorna texto
    si longitud_texto(prefijo) == 0 entonces
        retornar sub
    fin_si
    si longitud_texto(sub) == 0 entonces
        retornar prefijo
    fin_si
    texto p = prefijo
    texto s = sub
    si termina_con(p, "/") == 1 y longitud_texto(s) > 0 y extraer_subtexto(s, 0, 1) == "/" entonces
        s = extraer_despues_de(s, "/")
        retornar concatenar(p, s)
    fin_si
    si extraer_subtexto(s, 0, 1) == "/" entonces
        retornar concatenar(p, s)
    fin_si
    si termina_con(p, "/") == 1 entonces
        retornar concatenar(p, s)
    fin_si
    retornar concatenar(concatenar(p, "/"), s)
fin_funcion

// Activa prefijo para siguientes aplicacion_obtener / publicar / ... (bloque estilo Router montado).
enviar funcion montar_rutas(texto prefijo) retorna entero
    rapido_prefijo_montaje = prefijo
    retornar 1
fin_funcion

// Desactiva el prefijo de montaje (cerrar bloque de rutas anidadas).
enviar funcion desmontar_rutas() retorna entero
    rapido_prefijo_montaje = ""
    retornar 1
fin_funcion

enviar funcion rapido_patron_coincide(texto path, texto patron) retorna entero
    mem_lista_limpiar(rapido_lst_cap_nom)
    mem_lista_limpiar(rapido_lst_cap_val)
    // Sin ruta no hay coincidencia (evita que "" y "/" queden ambos con 0 segmentos tras dividir_texto
    // y se acepte la primera ruta GET "/" para cualquier peticion mal parseada).
    si longitud_texto(path) == 0 entonces
        retornar 0
    fin_si
    // Misma ruta exacta: coincidencia sin trocear (evita bug de VM: dividir_texto reusa id de lista
    // por hash(texto); patron y path iguales pisaban la misma lista y mem_lista_obtener fallaba).
    si patron == path entonces
        retornar 1
    fin_si
    lista pp = dividir_texto(patron, "/")
    lista ps = dividir_texto(path, "/")
    entero np = mem_lista_tamano(pp)
    entero ns = mem_lista_tamano(ps)
    // "/" solo produce 0 tokens con dividir_texto; eso ya cubre patron == path arriba. Cualquier otro
    // np==ns==0 es ambiguo: no coincidir.
    si np == 0 y ns == 0 entonces
        mem_lista_liberar(pp)
        mem_lista_liberar(ps)
        retornar 0
    fin_si
    si np != ns entonces
        mem_lista_liberar(pp)
        mem_lista_liberar(ps)
        retornar 0
    fin_si
    entero i = 0
    mientras i < np hacer
        texto pseg = mem_lista_obtener(pp, i)
        texto sseg = mem_lista_obtener(ps, i)
        si longitud_texto(pseg) == 0 entonces
            si longitud_texto(sseg) == 0 entonces
                i = i + 1
            fin_si
            si longitud_texto(sseg) > 0 entonces
                mem_lista_liberar(pp)
                mem_lista_liberar(ps)
                retornar 0
            fin_si
        fin_si
        si longitud_texto(pseg) > 0 entonces
            texto c0 = extraer_subtexto(pseg, 0, 1)
            si c0 == ":" entonces
                texto nm = extraer_despues_de(pseg, ":")
                mem_lista_agregar(rapido_lst_cap_nom, nm)
                mem_lista_agregar(rapido_lst_cap_val, sseg)
                i = i + 1
            fin_si
            si c0 != ":" entonces
                si pseg != sseg entonces
                    mem_lista_liberar(pp)
                    mem_lista_liberar(ps)
                    retornar 0
                fin_si
                i = i + 1
            fin_si
        fin_si
    fin_mientras
    mem_lista_liberar(pp)
    mem_lista_liberar(ps)
    retornar 1
fin_funcion

enviar funcion rapido_param(texto nombre) retorna texto
    entero n = mem_lista_tamano(rapido_lst_cap_nom)
    entero i = 0
    mientras i < n hacer
        si mem_lista_obtener(rapido_lst_cap_nom, i) == nombre entonces
            retornar mem_lista_obtener(rapido_lst_cap_val, i)
        fin_si
        i = i + 1
    fin_mientras
    retornar ""
fin_funcion

enviar funcion rapido_respuesta_opciones_cors() retorna texto
    retornar "HTTP/1.1 204 No Content\r\nAccess-Control-Allow-Origin: *\r\nAccess-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS\r\nAccess-Control-Allow-Headers: Content-Type\r\nConnection: close\r\n\r\n"
fin_funcion

enviar funcion rapido_json(texto cuerpo_json) retorna texto
    texto largo = str_desde_numero(longitud_texto(cuerpo_json))
    texto r = "HTTP/1.1 200 OK\r\nAccess-Control-Allow-Origin: *\r\nContent-Type: application/json; charset=utf-8\r\nConnection: close\r\nContent-Length: "
    r = concatenar(r, largo)
    r = concatenar(r, "\r\n\r\n")
    retornar concatenar(r, cuerpo_json)
fin_funcion

enviar funcion rapido_json_valor(entero doc_json) retorna texto
    retornar rapido_json(json_stringify(doc_json))
fin_funcion

enviar funcion rapido_json_codigo(texto linea_estado, texto cuerpo_json) retorna texto
    texto largo = str_desde_numero(longitud_texto(cuerpo_json))
    texto r = "HTTP/1.1 "
    r = concatenar(r, linea_estado)
    r = concatenar(r, "\r\nAccess-Control-Allow-Origin: *\r\nContent-Type: application/json; charset=utf-8\r\nConnection: close\r\nContent-Length: ")
    r = concatenar(r, largo)
    r = concatenar(r, "\r\n\r\n")
    retornar concatenar(r, cuerpo_json)
fin_funcion

enviar funcion rapido_no_encontrado_respuesta() retorna texto
    retornar rapido_json_codigo("404 Not Found", "{\"error\":\"no_encontrado\"}")
fin_funcion

enviar funcion rapido_cuerpo_json() retorna entero
    retornar rapido_j_doc
fin_funcion

enviar funcion rapido_tiene_cuerpo_json() retorna entero
    retornar rapido_j_listo
fin_funcion

enviar funcion rapido_mw_json(texto sol) retorna texto
    rapido_j_doc = 0
    rapido_j_listo = 0
    texto c = api_cuerpo(sol)
    si longitud_texto(c) == 0 entonces
        retornar ""
    fin_si
    rapido_j_doc = json_parse(c)
    rapido_j_listo = 1
    retornar ""
fin_funcion

enviar funcion rapido_mw_cors(texto sol) retorna texto
    si http_metodo_desde_linea(rapido_linea_cache) == "OPTIONS" entonces
        retornar rapido_respuesta_opciones_cors()
    fin_si
    retornar ""
fin_funcion

enviar funcion rapido_usar(funcion mw) retorna entero
    rapido_n_mw = rapido_n_mw + 1
    mapa_poner(rapido_m_mw, rapido_n_mw, mw)
    retornar rapido_n_mw
fin_funcion

enviar funcion rapido_usar_json() retorna entero
    retornar rapido_usar(rapido_mw_json)
fin_funcion

enviar funcion rapido_usar_cors() retorna entero
